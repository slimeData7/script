        localStats.totalJoined = d.totalJoined or 0
        localStats.totalFailed = d.totalFailed or 0
        localStats.eventsFound = d.eventsFound or 0
    end
end

local function saveAccountStats()
    writeJSON(FILE_ACCOUNT_STATS, wrap({
        totalJoined = localStats.totalJoined,
        totalFailed = localStats.totalFailed,
        eventsFound = localStats.eventsFound,
    }))
end

local function loadLocalSets()
    if not Config.PersistAcrossRejoins then return end
    local sv = readJSON(FILE_SHARED_VISITED)
    if sv and not isStale(sv) then
        local d = sv.data
        if type(d) == "table" then
            for id, v in pairs(d) do
                if id ~= "_ts" then localVisited[id] = v end
            end
        end
    end
    local sf = readJSON(FILE_SHARED_FAILED)
    if sf and not isStale(sf) then
        local d = sf.data
        if type(d) == "table" then
            for id, v in pairs(d) do
                if id ~= "_ts" then localFailed[id] = v end
            end
        end
    end
end

local function saveSharedVisited()
    evictOldest(localVisited, MAX_VISITED_ENTRIES)
    writeJSON(FILE_SHARED_VISITED, wrap({ data = localVisited }))
end

local function saveSharedFailed()
    evictOldest(localFailed, MAX_FAILED_ENTRIES)
    writeJSON(FILE_SHARED_FAILED, wrap({ data = localFailed }))
end

local function markVisited(jobId)
    localVisited[jobId] = { at = ts() }
    if Config.PersistAcrossRejoins then saveSharedVisited() end
end

local function markFailed(jobId)
    localFailed[jobId] = { at = ts() }
    if Config.PersistAcrossRejoins then saveSharedFailed() end
end

local function tryClaimServer(jobId)
    local claimed = readJSON(FILE_SHARED_CLAIMED)
    local now = ts()
    local data = {}
    if claimed and type(claimed.data) == "table" then
        for id, entry in pairs(claimed.data) do
            if id ~= "_ts" and type(entry) == "table" and (now - (entry.at or 0)) < CLAIM_TTL then
                data[id] = entry
            end
        end
    end
    if data[jobId] then return false end
    data[jobId] = { by = accountKey, at = now }
    writeJSON(FILE_SHARED_CLAIMED, wrap({ data = data }))
    task.wait(0.15)
    local verify = readJSON(FILE_SHARED_CLAIMED)
    if verify and type(verify.data) == "table" then
        local entry = verify.data[jobId]
        if entry and entry.by == accountKey then return true end
    end
    return false
end

local function releaseClaim(jobId)
    local claimed = readJSON(FILE_SHARED_CLAIMED)
    if not claimed or type(claimed.data) ~= "table" then return end
    claimed.data[jobId] = nil
    writeJSON(FILE_SHARED_CLAIMED, wrap({ data = claimed.data }))
end

local function tryAcquireFetchLock()
    local lock = readJSON(FILE_FETCH_LOCK)
    local now = ts()
    if lock and type(lock.holder) == "string" then
        local age = now - (lock.at or 0)
        if age < FETCH_LOCK_TTL then
            dprint("Fetch lock held by", lock.holder, "age", age)
            return false
        end
    end
    writeJSON(FILE_FETCH_LOCK, { holder = accountKey, at = now })
    task.wait(0.2)
    local verify = readJSON(FILE_FETCH_LOCK)
    if verify and verify.holder == accountKey then return true end
    return false
end

local function releaseFetchLock()
    local lock = readJSON(FILE_FETCH_LOCK)
    if lock and lock.holder == accountKey then
        fileDelete(FILE_FETCH_LOCK)
    end
end

local function getSharedQueueSize()
    local q = readJSON(FILE_SHARED_QUEUE)
    if q and type(q.data) == "table" then return #q.data end
    return 0
end

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=100&excludeFullGames=true",
        placeId
    )
    if cursor and cursor ~= "" then url = url .. "&cursor=" .. cursor end
    local res = safeRequest({ Url = url, Method = "GET" })
    if not res or not res.Body then return nil, nil end
    if res.StatusCode == 429 then
        dprint("429 rate limit on fetch")
        task.wait(10)
        return nil, nil
    end
    if res.StatusCode ~= 200 then return nil, nil end
    local d = jdec(res.Body)
    if not d then return nil, nil end
    return d.data, d.nextPageCursor
end

local function fetchServers()
    local collected = {}
    local seen      = {}
    local cursor    = nil
    local pages     = 0
    local maxCount  = MAX_SERVERS_PER_MODE[Config.FetchMode] or 300
    local maxPages  = 1
    if Config.FetchMode == "CursorFetch"   then maxPages = 3  end
    if Config.FetchMode == "AdvancedFetch" then maxPages = 10 end

    local sv = readJSON(FILE_SHARED_VISITED)
    local sf = readJSON(FILE_SHARED_FAILED)
    local sc = readJSON(FILE_SHARED_CLAIMED)
    local sharedVisited = (sv and type(sv.data) == "table") and sv.data or {}
    local sharedFailed  = (sf and type(sf.data) == "table") and sf.data or {}
    local sharedClaimed = (sc and type(sc.data) == "table") and sc.data or {}
    local now = ts()

    repeat
        local servers, nextCursor = fetchPage(cursor)
        if not servers then break end
        for _, server in ipairs(servers) do
            local id = server.id
            if id and not seen[id] then
                seen[id] = true
                local playing    = server.playing    or 0
                local maxPlayers = server.maxPlayers or 0
                local skip = false
                if id == game.JobId                                             then skip = true end
                if playing < Config.MinPlayers                                  then skip = true end
                if playing >= maxPlayers                                        then skip = true end
                if Config.MaxPlayers and playing > Config.MaxPlayers            then skip = true end
                if Config.SkipVisitedServers and sharedVisited[id]              then skip = true end
                if sharedFailed[id]                                             then skip = true end
                if sharedClaimed[id] and (now - (sharedClaimed[id].at or 0)) < CLAIM_TTL then skip = true end
                if not skip then
                    table.insert(collected, id)
                    if #collected >= maxCount then break end
                end
            end
        end
        cursor = nextCursor
        pages  = pages + 1
        if #collected >= maxCount then break end
        if cursor then task.wait(0.5) end
    until not cursor or cursor == "" or pages >= maxPages

    return collected
end

local function refillSharedQueue()
    if not tryAcquireFetchLock() then
        dprint("Another account is fetching. Waiting.")
        local waited = 0
        repeat
            task.wait(2)
            waited = waited + 2
        until getSharedQueueSize() >= 10 or waited >= FETCH_LOCK_TTL
        return
    end

    localStats.status = "Fetching servers..."
    dprint("Acquired fetch lock. Fetching.")

    local newIds = fetchServers()
    dprint("Fetched", #newIds, "servers")

    local existing = readJSON(FILE_SHARED_QUEUE)
    local existingSet = {}
    local merged = {}

    if existing and type(existing.data) == "table" and not isStale(existing) then
        for _, id in ipairs(existing.data) do
            if not existingSet[id] then
                existingSet[id] = true
                table.insert(merged, id)
            end
        end
    end

    for _, id in ipairs(newIds) do
        if not existingSet[id] then
            existingSet[id] = true
            table.insert(merged, id)
        end
    end

    writeJSON(FILE_SHARED_QUEUE, wrap({ data = merged, refetchAt = ts() + QUEUE_REFILL_COOLDOWN }))
    releaseFetchLock()
    localQueueSize = #merged
end

local function popFromSharedQueue()
    local q = readJSON(FILE_SHARED_QUEUE)
    if not q or type(q.data) ~= "table" or #q.data == 0 then return nil end

    local sv = readJSON(FILE_SHARED_VISITED)
    local sf = readJSON(FILE_SHARED_FAILED)
    local sc = readJSON(FILE_SHARED_CLAIMED)
    local sharedVisited = (sv and type(sv.data) == "table") and sv.data or {}
    local sharedFailed  = (sf and type(sf.data) == "table") and sf.data or {}
    local sharedClaimed = (sc and type(sc.data) == "table") and sc.data or {}
    local now = ts()

    local picked = nil
    local remaining = {}

    for _, id in ipairs(q.data) do
        if not picked then
            local skip = false
            if Config.SkipVisitedServers and sharedVisited[id]                        then skip = true end
            if sharedFailed[id]                                                        then skip = true end
            if sharedClaimed[id] and (now - (sharedClaimed[id].at or 0)) < CLAIM_TTL then skip = true end
            if not skip then
                picked = id
            else
                table.insert(remaining, id)
            end
        else
            table.insert(remaining, id)
        end
    end

    if not picked then return nil end

    writeJSON(FILE_SHARED_QUEUE, wrap({ data = remaining, refetchAt = q.refetchAt }))
    localQueueSize = #remaining
    return picked
end

local function shouldRefetch()
    local q = readJSON(FILE_SHARED_QUEUE)
    if not q then return true end
    if isStale(q) then return true end
    if type(q.data) == "table" and #q.data < 5 then return true end
    if type(q.refetchAt) == "number" and ts() >= q.refetchAt then return true end
    return false
end

local function getEventInfo()
    local name = ReplicatedStorage:GetAttribute("CurrentEvent")
    local endTime = ReplicatedStorage:GetAttribute("CurrentEventEndTime")
    if not name then return nil, 0 end
    local remaining = endTime and (endTime - os.time()) or 0
    return name, remaining
end

local function formatTime(sec)
    sec = tonumber(sec)
    if not sec or sec <= 0 then return "Ended" end
    return string.format("%02d:%02d", math.floor(sec / 60), math.floor(sec % 60))
end

local function ghContentsUrl()
    return string.format("https://api.github.com/repos/%s/%s/contents/%s", GH.Owner, GH.Repo, GH.FilePath)
end

local function ghHeaders()
    return {
        ["Authorization"] = "token " .. GH.Token,
        ["User-Agent"]    = "Roblox",
        ["Content-Type"]  = "application/json",
    }
end

local function ghFetchCurrent()
    local res = safeRequest({
        Url     = ghContentsUrl() .. "?ref=" .. GH.Branch,
        Method  = "GET",
        Headers = ghHeaders(),
    })
    if not res then return nil, nil, false end
    if res.StatusCode == 404 then return {}, nil, true end
    if res.StatusCode ~= 200 then
        dprint("GH GET failed:", res.StatusCode, res.Body)
        return nil, nil, false
    end
    local meta = jdec(res.Body)
    if not meta then return nil, nil, false end
    local decoded = meta.content and base64Decode((meta.content:gsub("%s", ""))) or ""
    local parsed = jdec(decoded)
    if type(parsed) ~= "table" then parsed = {} end
    return parsed, meta.sha, true
end

local function pruneAndMerge(list, entry)
    local now = os.time()
    local out = {}
    local replaced = false
    for _, e in ipairs(list) do
        if type(e) == "table" and e.jobId and (e.endTime or 0) > now then
            if e.jobId == entry.jobId then
                table.insert(out, entry)
                replaced = true
            else
                table.insert(out, e)
            end
        end
    end
    if not replaced then table.insert(out, entry) end
    return out
end

local function uploadEventToGitHub(eventName, remaining)
    if not GH.Enabled or not GH.Token or GH.Token == "" then return end
    local entry = {
        jobId   = game.JobId,
        event   = eventName,
        endTime = os.time() + remaining,
    }
    for attempt = 1, GH_MAX_RETRIES do
        local list, sha, ok = ghFetchCurrent()
        if not ok then
            dprint("GH fetch failed, retry", attempt)
            task.wait(2 ^ attempt)
        else
            local merged = pruneAndMerge(list, entry)
            local body = {
                message = "event: " .. eventName .. " @ " .. entry.jobId:sub(1, 8),
                content = base64Encode(jenc(merged)),
                branch  = GH.Branch,
            }
            if sha then body.sha = sha end
            local put = safeRequest({
                Url     = ghContentsUrl(),
                Method  = "PUT",
                Headers = ghHeaders(),
                Body    = jenc(body),
            })
            if put and (put.StatusCode == 200 or put.StatusCode == 201) then
                dprint("GH upload ok")
                return true
            elseif put and put.StatusCode == 409 then
                dprint("GH 409 conflict, retry", attempt)
                task.wait(0.5 + math.random() * 1.5)
            else
                dprint("GH PUT failed:", put and put.StatusCode, put and put.Body)
                task.wait(2 ^ attempt)
            end
        end
    end
    dprint("GH upload gave up after", GH_MAX_RETRIES, "tries")
    return false
end

local function checkAndHandleEvent()
    local name, remaining = getEventInfo()
    if not name then return false end
    if not targetSet[name] then
        dprint("Event active but not targeted:", name)
        return false
    end
    if Config.MinTimeRemaining > 0 and remaining < Config.MinTimeRemaining then
        dprint("Event", name, "below min time:", remaining)
        return false
    end
    print("[ServerHop] Target event! " .. name .. " | " .. formatTime(remaining))
    localStats.eventsFound = localStats.eventsFound + 1
    localStats.status      = name:upper() .. " " .. formatTime(remaining)
    saveAccountStats()
    task.spawn(uploadEventToGitHub, name, remaining)
    if Config.StopOnEventServer then
        hopLock           = true
        localStats.status = "Stopped on " .. name
    end
    return true
end

