local function tryBuyPet(refPart)
    if not Options.BuyPetsEnabled.Value then return end
    if petInFlight[refPart] then return end

    local owner = refPart:GetAttribute("OwnerName")
    if owner and #owner > 1 then return end

    local petName = refPart:GetAttribute("PetName")
    local data = petName and PetData[petName]
    if not data then return end
    if not shouldBuyPet(data) then return end

    local price = refPart:GetAttribute("Price") or data.BasePrice
    if not price or getBalance() < price then return end

    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    petInFlight[refPart] = true

    local parent = refPart.Parent
    if parent then
        local _, g = parseWildPetName(parent.Name)
        if g then pendingGuids[petName] = g end
    end

    teleport(refPart.Position + Vector3.new(0, 3, 0))
    task.wait(0.2)
    Remotes.WildPetTame:Fire(refPart)
    task.wait(0.1)
    petInFlight[refPart] = nil
end

