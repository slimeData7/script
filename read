local function withAll(list)
    table.insert(list, 1, "All")
    return list
end

local function safeList(builder)
    local ok, result = pcall(builder)
    if ok and type(result) == "table" then
        return withAll(result)
    end
    return withAll({})
end

local function GetMutationNames()
    return safeList(function()
        local list = {}
        for _, name in ipairs(MUTATIONS) do
            table.insert(list, name)
        end
        return list
    end)
end

local function GetSeedNames()
    return safeList(function()
        local list = {}
        for _, seed in ipairs(SeedData) do
            table.insert(list, seed.SeedName)
        end
        table.sort(list)
        return list
    end)
end

local function GetFruitNames()
    return safeList(function()
        local list = {}
        for name in pairs(SellValueData) do
            table.insert(list, name)
        end
        table.sort(list)
        return list
    end)
end

local function GetPetRarities()
    return safeList(function()
        local list, seen = {}, {}
        for _, pet in pairs(PetData) do
            if type(pet) == "table" and pet.Rarity and not seen[pet.Rarity] then
                seen[pet.Rarity] = true
                table.insert(list, pet.Rarity)
            end
        end
        table.sort(list)
        return list
    end)
end

local function GetPetNames()
    return safeList(function()
        local list = {}
        for _, pet in pairs(PetData) do
            if type(pet) == "table" and pet.DisplayName then
                table.insert(list, pet.DisplayName)
            end
        end
        table.sort(list)
        return list
    end)
end

local function GetCrateNames()
    return safeList(function()
        local list = {}
        for _, crate in ipairs(CrateData.GetAllCrates()) do
            table.insert(list, type(crate) == "table" and crate.Name or crate)
        end
        table.sort(list)
        return list
    end)
end

local function GetGearNames()
    return safeList(function()
        local list = {}
        for _, gear in ipairs(GearShopData.Data) do
            table.insert(list, gear.ItemName)
        end
        table.sort(list)
        return list
    end)
end

local function HandleAllSelection(dropdown, values)
    dropdown:OnChanged(function()
        local selected = dropdown.Value
        if selected["All"] then
            local full = {}
            for _, name in ipairs(values) do
                if name ~= "All" then
                    full[name] = true
                end
            end
            dropdown:SetValue(full)
        end
    end)
end

