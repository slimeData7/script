local function base64Encode(data)
    local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    local result = {}
    for i = 1, #data, 3 do
        local byte1 = string.byte(data, i)
        local byte2 = string.byte(data, i + 1) or 0
        local byte3 = string.byte(data, i + 2) or 0
        local enc1 = math.floor(byte1 / 4)
        local enc2 = (byte1 % 4) * 16 + math.floor(byte2 / 16)
        local enc3 = (byte2 % 16) * 4 + math.floor(byte3 / 64)
        local enc4 = byte3 % 64
        table.insert(result, b64chars:sub(enc1 + 1, enc1 + 1))
        table.insert(result, b64chars:sub(enc2 + 1, enc2 + 1))
        table.insert(result, b64chars:sub(enc3 + 1, enc3 + 1))
        table.insert(result, b64chars:sub(enc4 + 1, enc4 + 1))
    end
    local padding = (3 - (#data % 3)) % 3
    for i = 1, padding do
        result[#result - i + 1] = '='
    end
    return table.concat(result)
end

local function base64Decode(data)
    local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    local lookup = {}
    for i = 1, #b64chars do lookup[b64chars:sub(i, i)] = i - 1 end
    data = data:gsub("[^" .. b64chars .. "=]", "")
    local result = {}
    for i = 1, #data, 4 do
        local c1 = lookup[data:sub(i, i)] or 0
        local c2 = lookup[data:sub(i + 1, i + 1)] or 0
        local c3 = lookup[data:sub(i + 2, i + 2)]
        local c4 = lookup[data:sub(i + 3, i + 3)]
        local b1 = c1 * 4 + math.floor(c2 / 16)
        table.insert(result, string.char(b1))
        if c3 then
            local b2 = (c2 % 16) * 16 + math.floor(c3 / 4)
            table.insert(result, string.char(b2))
        end
        if c4 then
            local b3 = (c3 % 4) * 64 + c4
            table.insert(result, string.char(b3))
        end
    end
    return table.concat(result)
end

local function fileRead(path)
    if not (isfile and isfile(path)) then return nil end
    local ok, c = pcall(readfile, path)
    return (ok and c and c ~= "") and c or nil
end

local function fileWrite(path, content)
    if writefile then pcall(writefile, path, content) end
end

local function fileDelete(path)
    if isfile and isfile(path) and delfile then pcall(delfile, path) end
end

local function readJSON(path)
    local c = fileRead(path)
    if not c then return nil end
    return jdec(c)
end

local function writeJSON(path, data)
    local s = jenc(data)
    if s then fileWrite(path, s) end
end

local function isStale(t, maxAge)
    if type(t) ~= "table" or type(t._ts) ~= "number" then return true end
    return (ts() - t._ts) > (maxAge or FILE_MAX_AGE)
end

local function wrap(data)
    data._ts = ts()
    return data
end

local function evictOldest(tbl, maxSize)
    local keys = {}
    for k in pairs(tbl) do
        if k ~= "_ts" then table.insert(keys, k) end
    end
    if #keys <= maxSize then return end
    table.sort(keys, function(a, b)
        local va = tbl[a]
        local vb = tbl[b]
        local ta = type(va) == "table" and (va.at or 0) or 0
        local tb = type(vb) == "table" and (vb.at or 0) or 0
        return ta < tb
    end)
    local toRemove = #keys - maxSize
    for i = 1, toRemove do
        tbl[keys[i]] = nil
    end
end

local function safeRequest(options)
    if not httpRequest then return nil end
    local ok, r = pcall(httpRequest, options)
    if not ok then dprint("request err:", r) return nil end
    return r
end

local function loadAccountStats()
