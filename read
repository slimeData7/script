local function clampNumberInput(rawValue, default, min, max)
    local n = tonumber(rawValue)
    if not n then return default end
    if min and n < min then return min end
    if max and n > max then return max end
    return n
end

local function isValidWebhookUrl(url)
    if type(url) ~= "string" or url == "" then return false end
    return url:match("^https?://discord%.com/api/webhooks/") ~= nil
        or url:match("^https?://discordapp%.com/api/webhooks/") ~= nil
end

