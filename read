local _petsSyncing = false

local function syncPets()
    local blacklistSet = selectedSet(Options.BlacklistedPets) or {}
    local prioritySet = selectedSet(Options.PriorityPets) or {}

    local byName = buildPetIndex()
    local cap = getMaxEquippedPets()
    local targets = computeTargets(byName, blacklistSet, prioritySet, cap)

    local toEquip, toUnequip = {}, {}
    for name, bucket in pairs(byName) do
        local target = targets[name] or 0
        local have = #bucket.equipped
        if have > target then
            for i = target + 1, have do
                toUnequip[#toUnequip + 1] = bucket.equipped[i]
            end
        elseif have < target then
            local need = math.min(target - have, #bucket.unequipped)
            for i = 1, need do
                toEquip[#toEquip + 1] = bucket.unequipped[i]
            end
        end
    end

    if #toEquip == 0 and #toUnequip == 0 then
        return
    end

    debugLog("Auto Equip", "Unequipping", #toUnequip, "Equipping", #toEquip)

    for _, uuid in ipairs(toUnequip) do
        safeFire(Remotes.RequestUnequip, uuid)
    end

    if #toUnequip > 0 then
        task.wait(0.1)
    end

    local cap2 = getMaxEquippedPets()
    local currentlyEquipped = getEquippedCount()

    local toolByPetId = {}
    for _, tool in pairs(Backpack:GetChildren()) do
        local petId = tool:GetAttribute("PetId")
        if petId then
            toolByPetId[petId] = tool
        end
    end

    for _, uuid in ipairs(toEquip) do
        if currentlyEquipped >= cap2 then
            debugLog("Auto Equip", "Cap reached, stopping equip pass")
            break
        end
        local foundTool = toolByPetId[uuid]
        if foundTool then
            equipAndActivateTool(foundTool)
            currentlyEquipped += 1
        end
    end
end

