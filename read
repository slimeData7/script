local Options = Fluent.Options

local function addFeatureHeader(tab, title, description)
    tab:AddParagraph({ Title = title, Content = description or "" })
end

local function addAllDropdown(tab, key, title, values)
    local dropdown = tab:AddDropdown(key, {
        Title = title,
        Values = values,
        Multi = true,
        Default = {}
    })
    dropdown:OnChanged(function()
        local selected = dropdown.Value
        if selected["All"] then
            local full = {}
            for _, name in ipairs(values) do
                if name ~= "All" then
                    full[name] = true
                end
            end
            dropdown:SetValue(full)
        end
    end)
    return dropdown
end

local function addClampedInput(tab, key, title, default, placeholder, min, max)
    local input = tab:AddInput(key, {
        Title = title,
        Default = default,
        Placeholder = placeholder,
        Numeric = true,
        Finished = true
    })
    input:OnChanged(function()
        local clamped = clampNumberInput(Options[key].Value, default, min, max)
        if tostring(clamped) ~= Options[key].Value then
            Options[key]:SetValue(tostring(clamped))
        end
    end)
    return input
end

local function addEnabledToggle(tab, key, label)
    local toggle = tab:AddToggle(key, { Title = "Enabled", Default = false })
    toggle:OnChanged(function()
        notify(label .. (Options[key].Value and " enabled" or " disabled"))
    end)
    return toggle
end

local function selectedSet(dropdownOptions)
    local value = dropdownOptions.Value
    if value["All"] then
        return nil
    end
    return value
end

local function isSelected(set, name)
    if set == nil or next(set) == nil then return true end
    return set[name] == true
end

