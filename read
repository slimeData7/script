local DENSITY_CELL = 5
local OPT_TTL = 8

local _densGrid = {}
local _occGrid = {}
local _optOcc = {}

local function _dk(x, z)
    return math.floor(x / DENSITY_CELL) .. "," .. math.floor(z / DENSITY_CELL)
end

local function _ok(x, z)
    return math.floor(x + 0.5) .. "," .. math.floor(z + 0.5)
end

local function _densAdd(pos)
    local k = _dk(pos.X, pos.Z)
    _densGrid[k] = (_densGrid[k] or 0) + 1
end

local function densityAt(pos)
    local cx = math.floor(pos.X / DENSITY_CELL)
    local cz = math.floor(pos.Z / DENSITY_CELL)
    local s = 0
    for dx = -1, 1 do
        for dz = -1, 1 do
            s += _densGrid[(cx + dx) .. "," .. (cz + dz)] or 0
        end
    end
    return s
end

local function _occMark(pos) _occGrid[_ok(pos.X, pos.Z)] = true end

local function _optMark(pos)
    _optOcc[_ok(pos.X, pos.Z)] = os.clock() + OPT_TTL
end

local function isOccupied(pos)
    local cx = math.floor(pos.X + 0.5)
    local cz = math.floor(pos.Z + 0.5)
    local now = os.clock()
    for dx = -1, 1 do
        for dz = -1, 1 do
            local k = (cx + dx) .. "," .. (cz + dz)
            if _occGrid[k] then return true end
            local exp = _optOcc[k]
            if exp then
                if exp > now then return true else _optOcc[k] = nil end
            end
        end
    end
    return false
end

local _spawnCF = nil
local _plantWorldPositions = {}

local GARDEN_TTL = 2
local _gardenDirty = true
local _lastGardenSignature = nil
local _lastGardenPoll = 0
local _plantCounts = {}
local _harvestTargets = {}
local _candidDirty = true

local function _plantWorldPos(p)
    local gp = p.Positions
    if not gp or not gp.PosX or not gp.PosZ then return nil end
    local v = Vector3.new(gp.PosX, gp.PosY or 0, gp.PosZ)
    if _spawnCF then return _spawnCF:PointToWorldSpace(v) end
    return v
end

local function _gardenSignature(garden)
    local count = 0
    local ageSum = 0
    for _, p in pairs(garden) do
        count += 1
        ageSum += p.Age or 0
        if p.Fruits then
            for _, f in pairs(p.Fruits) do
                count += 1
                ageSum += f.Age or 0
            end
        end
    end
    return count .. ":" .. math.floor(ageSum)
end

local function _rebuildGardenCache()
    if not GardenSyncCtrl then return end
    local garden = GardenSyncCtrl:GetGarden(userId)
    if not garden then return end

    local signature = _gardenSignature(garden)
    if signature == _lastGardenSignature then
        _gardenDirty = false
        return
    end
    _lastGardenSignature = signature

    _plantCounts = {}
    _harvestTargets = {}
    _densGrid = {}
    _occGrid = {}
    _plantWorldPositions = {}

    local doHarvest = Options.HarvestEnabled.Value
    local mutationSet = selectedSet(Options.HarvestMutations)
    local variantSet = selectedSet(Options.HarvestVariants)
    local instantMutated = Options.HarvestInstantMutated.Value

    for plantId, p in pairs(garden) do
        local name = p.PlantName
        if name then
            _plantCounts[name] = (_plantCounts[name] or 0) + 1
        end

        local wp = _plantWorldPos(p)
        if wp then
            _densAdd(wp)
            _occMark(wp)
            _plantWorldPositions[#_plantWorldPositions + 1] = wp
        end

        if doHarvest then
            if p.Fruits then
                for fruitId, f in pairs(p.Fruits) do
                    if checkFruitCollect(mutationSet, variantSet, instantMutated, f.Mutation, f.Variant, f.Age or 0, f.MaxAge or 0) then
                        local ht = _harvestTargets
                        ht[#ht + 1] = { plantId = plantId, fruitId = fruitId }
                    end
                end
            else
                if checkFruitCollect(mutationSet, variantSet, instantMutated, p.Mutation, p.Variant, p.Age or 0, p.MaxAge or 0) then
                    local ht = _harvestTargets
                    ht[#ht + 1] = { plantId = plantId, fruitId = "" }
                end
            end
        end
    end

    _candidDirty = true
    _gardenDirty = false
end

local function tickGarden()
    local now = os.clock()
    if _gardenDirty or now - _lastGardenPoll >= GARDEN_TTL then
        _lastGardenPoll = now
        _rebuildGardenCache()
    end
end

local function markGardenDirty() _gardenDirty = true end

local _plantAreaParams = nil
local function _buildPlantAreaParams()
    _plantAreaParams = RaycastParams.new()
    _plantAreaParams.FilterType = Enum.RaycastFilterType.Include
    _plantAreaParams.FilterDescendantsInstances = CollectionService:GetTagged("PlantArea")
end

local function _ensureStaticParams()
    if not _plantAreaParams then _buildPlantAreaParams() end
end

local _candidates = {}
local _candidSorted = {}
local _sprinklerCands = {}
local _cachedPlotId = nil
local _plotCenter = nil
local _perimeter = nil

local function _collectPlantAreas(plot)
    local out = {}
    for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
        if part:IsA("BasePart") and part:IsDescendantOf(plot) then
            out[#out + 1] = part
        end
    end
    return out
end

local function _computePerimeter(plantAreas)
    local minX, minZ = math.huge, math.huge
    local maxX, maxZ = -math.huge, -math.huge
    local sumY, nY = 0, 0
    for _, part in ipairs(plantAreas) do
        local p, s = part.Position, part.Size
        local hx, hz = s.X * 0.5, s.Z * 0.5
        if p.X - hx < minX then minX = p.X - hx end
        if p.X + hx > maxX then maxX = p.X + hx end
        if p.Z - hz < minZ then minZ = p.Z - hz end
        if p.Z + hz > maxZ then maxZ = p.Z + hz end
        sumY += p.Y; nY += 1
    end
    if nY == 0 then return nil end
    local y = sumY / nY
    return {
        minX = minX, maxX = maxX, minZ = minZ, maxZ = maxZ, y = y,
        center = Vector3.new((minX + maxX) * 0.5, y, (minZ + maxZ) * 0.5),
    }
end

local function _inPerimeter(pos)
    local pr = _perimeter
    if not pr then return true end
    return pos.X >= pr.minX and pos.X <= pr.maxX
        and pos.Z >= pr.minZ and pos.Z <= pr.maxZ
end

local function _precomputeCandidates(plot, plantAreas)
    _candidates = {}
    _candidDirty = true
    if #plantAreas == 0 then return end
    for _, area in ipairs(plantAreas) do
        local ap = area.Position
        local as = area.Size
        local stX = math.max(1, math.floor(as.X / 2))
        local stZ = math.max(1, math.floor(as.Z / 2))
        for ix = 0, stX do
            for iz = 0, stZ do
                local ox = ((ix / stX) - 0.5) * as.X * 0.85
                local oz = ((iz / stZ) - 0.5) * as.Z * 0.85
                local org = Vector3.new(ap.X + ox, ap.Y + 50, ap.Z + oz)
                local hit = workspace:Raycast(org, Vector3.new(0, -100, 0), _plantAreaParams)
                if hit and hit.Instance:IsDescendantOf(plot) then
                    _candidates[#_candidates + 1] = hit.Position
                end
            end
        end
    end
end

local function _precomputeSprinklerCands(plantAreas)
    local STEP = 5
    local out = {}
    for _, part in ipairs(plantAreas) do
        local sz, cf = part.Size, part.CFrame
        local hX, hY, hZ = sz.X * 0.5, sz.Y * 0.5, sz.Z * 0.5
        local xSt = math.floor(sz.X / STEP)
        local zSt = math.floor(sz.Z / STEP)
        for xi = 0, xSt do
            for zi = 0, zSt do
                out[#out + 1] = cf:PointToWorldSpace(
                    Vector3.new(-hX + xi * STEP, hY, -hZ + zi * STEP)
                )
            end
        end
    end
    return out
end

local function getSortedCandidates()
    if not _candidDirty then return _candidSorted end
    local n = #_candidates
    local scored = table.create(n)
    for i = 1, n do
        scored[i] = { idx = i, score = densityAt(_candidates[i]) }
    end
    table.sort(scored, function(a, b) return a.score > b.score end)
    _candidSorted = scored
    _candidDirty = false
    return scored
end

local function _trySetup(plotId)
    if _cachedPlotId == plotId and _plotCenter then return true end
    local gardens = workspace:FindFirstChild("Gardens")
    local plot = gardens and gardens:FindFirstChild("Plot" .. tostring(plotId))
    if not plot then return false end

    _ensureStaticParams()
    local sp = plot:FindFirstChild("SpawnPoint")
    _spawnCF = sp and sp.CFrame or nil

    local plantAreas = _collectPlantAreas(plot)
    _perimeter = _computePerimeter(plantAreas)
    _plotCenter = (_perimeter and _perimeter.center) or plot:GetPivot().Position
    _precomputeCandidates(plot, plantAreas)
    _sprinklerCands = _precomputeSprinklerCands(plantAreas)

    _cachedPlotId = plotId
    markGardenDirty()
    return _plotCenter ~= nil
end

