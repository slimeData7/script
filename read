local totalDuration = 600

local phases = {
    { Name = "Day", Index = 1, Weathers = { Day = { Chance = 100 } } },
    { Name = "Sunset", Index = 2, Weathers = { Sunset = { Chance = 100 } } },
    { Name = "Night", Index = 3, Weathers = {
        Moon = { Chance = 79 },
        Bloodmoon = { Chance = 2 },
        Goldmoon = { Chance = 13 },
        ["Rainbow Moon"] = { Chance = 6 },
    }},
}

local function pickWeather(weathers, rng)
    local total = 0
    for _, w in weathers do total += w.Chance end
    local roll = rng:NextNumber() * total
    local cumulative = 0
    for name, w in weathers do
        cumulative += w.Chance
        if roll <= cumulative then return name end
    end
end

local function buildForecast()
    local currentCycle = math.floor(os.time() / totalDuration)
    local lines = {}
    for offset = 0, 9 do
        local cycle = currentCycle + offset
        local parts = {}
        for _, phase in phases do
            local seed = cycle * 1000 + phase.Index
            local weather = pickWeather(phase.Weathers, Random.new(seed))
            table.insert(parts, phase.Name .. ": " .. weather)
        end
        table.insert(lines, ("Cycle %d - %s"):format(cycle, table.concat(parts, " | ")))
    end
    return table.concat(lines, "\n")
end

task.spawn(function()
    while true do
        WeatherParagraph:SetDesc(buildForecast())
