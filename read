local function buildPetIndex()
    local pets = replica and replica.Data and replica.Data.Inventory and replica.Data.Inventory.Pets
    local byName = {}
    if type(pets) ~= "table" then return byName end
    for key, pet in pairs(pets) do
        if type(pet) == "table" and pet.Name then
            local uuid = pet.Id or key
            local bucket = byName[pet.Name]
            if not bucket then
                bucket = { equipped = {}, unequipped = {} }
                byName[pet.Name] = bucket
            end
            if pet.Equipped then
                bucket.equipped[#bucket.equipped + 1] = uuid
            else
                bucket.unequipped[#bucket.unequipped + 1] = uuid
            end
        end
    end
    return byName
end

local function getMaxEquippedPets()
    local m = LocalPlayer:GetAttribute("MaxEquippedPets")
    if type(m) == "number" and m > 0 then return math.floor(m) end
    if PetSlotPrices and type(PetSlotPrices.BaseMax) == "number" then
        return math.floor(PetSlotPrices.BaseMax)
    end
    return math.huge
end

local function getEquippedCount()
    local pets = replica and replica.Data and replica.Data.Inventory and replica.Data.Inventory.Pets
    if type(pets) ~= "table" then return 0 end
    local count = 0
    for _, pet in pairs(pets) do
        if type(pet) == "table" and pet.Equipped then
            count += 1
        end
    end
    return count
end

local function computeTargets(byName, blacklist, priority, cap)
    local targets, used = {}, 0

    local function owned(name)
        local b = byName[name]
        return b and (#b.equipped + #b.unequipped) or 0
    end
    local function take(name, n)
        if n <= 0 then return end
        local already = targets[name] or 0
        local room = math.min(n, owned(name) - already, cap - used)
        if room > 0 then
            targets[name] = already + room
            used += room
        end
    end

    local names = {}
    for name in pairs(byName) do
        if not blacklist[name] then names[#names + 1] = name end
    end
    table.sort(names)

    for _, name in ipairs(names) do
        if priority[name] then take(name, math.huge) end
    end
    for _, name in ipairs(names) do
        if not priority[name] then take(name, math.huge) end
    end

    return targets, used
end

