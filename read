end

local function getBottomRectClosestPoint(part, point)
    local size = part.Size
    local cf = part.CFrame * CFrame.new(0, -size.Y / 2, 0)
    local localPoint = cf:PointToObjectSpace(point)
    local halfX, halfZ = size.X / 2, size.Z / 2
    local clampedX = math.clamp(localPoint.X, -halfX, halfX)
    local clampedZ = math.clamp(localPoint.Z, -halfZ, halfZ)
    return cf:PointToWorldSpace(Vector3.new(clampedX, 0, clampedZ))
end

local function pointInBottomRectXZ(part, point)
    local size = part.Size
    local cf = part.CFrame * CFrame.new(0, -size.Y / 2, 0)
    local localPoint = cf:PointToObjectSpace(point)
    return math.abs(localPoint.X) <= size.X / 2 and math.abs(localPoint.Z) <= size.Z / 2
end

local function moveTowards(from, to, maxDistance)
    local offset = to - from
    local distance = offset.Magnitude
    if distance <= maxDistance then return to end
    return from + offset.Unit * maxDistance
end

local function tweenTo(hrp, targetPos)
    local remainingDistance = (hrp.Position - targetPos).Magnitude
    local TWEEN_SPEED = getgenv().tweenSpeed
    if remainingDistance <= TWEEN_SPEED then
        hrp.CFrame = CFrame.new(targetPos)
        return
    end
    getgenv().tweening = true
    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(remainingDistance / TWEEN_SPEED, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(targetPos) }
    )
    tween:Play()
    tween.Completed:Wait()
    getgenv().tweening = false
end

local canTeleportDirect = false
local function teleport(target, teleportDirect)
    if teleportDirect == nil then
        teleportDirect = canTeleportDirect
    end
    if getgenv().tweening then return false end

    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    if not teleportDirect then
        if typeof(target) == "string" then
            local cf = getgenv().stuffPositions and getgenv().stuffPositions[target]
            if not cf then return false end
            if xzDistanceSq(hrp.Position, cf.Position) > TELEPORT_THRESHOLD_SQ then
                Remotes.TeleportRequest:Fire(target)
            end
            return true
        end

        local targetPos = typeof(target) == "CFrame" and target.Position or target

        if xzDistanceSq(hrp.Position, targetPos) > TELEPORT_THRESHOLD_SQ then
            local bestDistance = (hrp.Position - targetPos).Magnitude
            local bestTeleport

            local teleportsFolder = workspace:FindFirstChild("Teleports")
            if teleportsFolder then
                for _, thing in ipairs(teleportsFolder:GetChildren()) do
                    local pos
                    if thing:IsA("BasePart") then
                        pos = thing.Position
                    else
                        local part = thing:FindFirstChildWhichIsA("BasePart")
                        pos = part and part.Position
                    end
                    if pos then
                        local distance = (pos - targetPos).Magnitude
                        if distance < bestDistance then
                            bestDistance = distance
                            bestTeleport = thing
                        end
                    end
                end
            end

            if bestTeleport then
                Remotes.TeleportRequest:Fire(bestTeleport)
                repeat
                    character = LocalPlayer.Character
                    hrp = character and character:FindFirstChild("HumanoidRootPart")
                    if not hrp then task.wait() end
                until hrp
            end
        end

        tweenTo(hrp, targetPos)
        return true
    end

    local targetPos
    if typeof(target) == "string" then
        local cf = getgenv().stuffPositions and getgenv().stuffPositions[target]
        if not cf then return false end
        targetPos = cf.Position
    elseif typeof(target) == "CFrame" then
        targetPos = target.Position
    else
        targetPos = target
    end

    local safezonePart = MapFolder:WaitForChild("SafeZones"):WaitForChild("Part")
    local gardenCF = getgenv().stuffPositions and getgenv().stuffPositions["Garden"]

    local safezoneEdge = getBottomRectClosestPoint(safezonePart, targetPos)
    local safezoneDistance = (safezoneEdge - targetPos).Magnitude
    local gardenDistance = gardenCF and (gardenCF.Position - targetPos).Magnitude or math.huge
    local currentDistance = (hrp.Position - targetPos).Magnitude

    if safezoneDistance <= gardenDistance and safezoneDistance <= currentDistance then
        Remotes.TeleportRequest:Fire("Seeds")
        task.wait(0.2)
        character = LocalPlayer.Character
        hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        hrp.CFrame = CFrame.new(safezoneEdge)
        task.wait(0.2)
        local stepPos = moveTowards(hrp.Position, targetPos, 70)
        hrp.CFrame = CFrame.new(stepPos)
        task.wait()
        tweenTo(hrp, targetPos)
        return true
    end

    if gardenDistance <= currentDistance then
        Remotes.TeleportRequest:Fire("Garden")
        task.wait(0.2)
        character = LocalPlayer.Character
        hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        local stepPos = moveTowards(hrp.Position, targetPos, 70)
        hrp.CFrame = CFrame.new(stepPos)
        task.wait()
        tweenTo(hrp, targetPos)
        return true
    end

    local closeToGarden = gardenCF and (hrp.Position - gardenCF.Position).Magnitude <= 3
    local insideSafezone = pointInBottomRectXZ(safezonePart, hrp.Position)
    if not closeToGarden and not insideSafezone then
        tweenTo(hrp, targetPos)
    end
    return true
end

local function matchesList(set, value)
    return isSelected(set, value or "Normal")
end

local function checkFruitCollect(mutationSet, variantSet, instantMutated, mutation, variant, age, maxAge)
    local eligible = matchesList(mutationSet, mutation) and matchesList(variantSet, variant)
    if not eligible then return false end
    local instant = mutation and instantMutated
    return instant or (maxAge > 0 and age >= maxAge)
end

local _fruitCountAll = 0
local _fruitCountNonFav = 0
local _seedInventory = {}
local _sprinklerInventory = {}
local _bpToolConns = {}

local function _isFruit(t)
    return t:GetAttribute("Fruit") ~= nil and t:GetAttribute("FruitName") ~= nil
end

local function _isSeed(t)
    return t:IsA("Tool") and t:GetAttribute("SeedTool") ~= nil
end

local function _isSprinkler(t)
    return t:IsA("Tool") and t:GetAttribute("Sprinkler") ~= nil
end

local function _listAdd(map, key, tool)
    local list = map[key]
    if not list then list = {}; map[key] = list end
    list[#list + 1] = tool
end

local function _listRemove(map, key, tool)
    local list = map[key]
    if not list then return end
    local i = table.find(list, tool)
    if i then
        list[i] = list[#list]
        list[#list] = nil
    end
    if #list == 0 then map[key] = nil end
end

local function _onToolAdded(tool)
    if _isFruit(tool) then
        _fruitCountAll += 1
        if tool:GetAttribute("IsFavorite") ~= true then
            _fruitCountNonFav += 1
        end
    end
    if _isSeed(tool) then
        _listAdd(_seedInventory, tool:GetAttribute("SeedTool"), tool)
    end
    if _isSprinkler(tool) then
        _listAdd(_sprinklerInventory, tool:GetAttribute("Sprinkler"), tool)
    end
end

local function _onToolRemoved(tool)
    if _isFruit(tool) then
        _fruitCountAll = math.max(0, _fruitCountAll - 1)
        if tool:GetAttribute("IsFavorite") ~= true then
            _fruitCountNonFav = math.max(0, _fruitCountNonFav - 1)
        end
    end
    if _isSeed(tool) then
        _listRemove(_seedInventory, tool:GetAttribute("SeedTool"), tool)
    end
    if _isSprinkler(tool) then
        _listRemove(_sprinklerInventory, tool:GetAttribute("Sprinkler"), tool)
    end
end

local function _setupBackpackTracking(bp)
    for _, c in ipairs(_bpToolConns) do c:Disconnect() end
    _bpToolConns = {}
    _fruitCountAll, _fruitCountNonFav = 0, 0
    _seedInventory, _sprinklerInventory = {}, {}
    for _, t in ipairs(bp:GetChildren()) do _onToolAdded(t) end
    _bpToolConns[1] = bp.ChildAdded:Connect(_onToolAdded)
    _bpToolConns[2] = bp.ChildRemoved:Connect(_onToolRemoved)
end

_setupBackpackTracking(Backpack)
LocalPlayer.ChildAdded:Connect(function(c)
    if c:IsA("Backpack") then _setupBackpackTracking(c) end
end)

local function getFruitCount(ignoreFavs)
    return ignoreFavs and _fruitCountNonFav or _fruitCountAll
end

local DENSITY_CELL = 5
local OPT_TTL = 8

local _densGrid = {}
local _occGrid = {}
local _optOcc = {}

local function _dk(x, z)
    return math.floor(x / DENSITY_CELL) .. "," .. math.floor(z / DENSITY_CELL)
end

local function _ok(x, z)
    return math.floor(x + 0.5) .. "," .. math.floor(z + 0.5)
end

local function _densAdd(pos)
    local k = _dk(pos.X, pos.Z)
    _densGrid[k] = (_densGrid[k] or 0) + 1
end

local function densityAt(pos)
    local cx = math.floor(pos.X / DENSITY_CELL)
    local cz = math.floor(pos.Z / DENSITY_CELL)
    local s = 0
    for dx = -1, 1 do
        for dz = -1, 1 do
            s += _densGrid[(cx + dx) .. "," .. (cz + dz)] or 0
        end
    end
    return s
end

local function _occMark(pos) _occGrid[_ok(pos.X, pos.Z)] = true end

local function _optMark(pos)
    _optOcc[_ok(pos.X, pos.Z)] = os.clock() + OPT_TTL
end

local function isOccupied(pos)
    local cx = math.floor(pos.X + 0.5)
    local cz = math.floor(pos.Z + 0.5)
    local now = os.clock()
    for dx = -1, 1 do
        for dz = -1, 1 do
            local k = (cx + dx) .. "," .. (cz + dz)
            if _occGrid[k] then return true end
            local exp = _optOcc[k]
            if exp then
                if exp > now then return true else _optOcc[k] = nil end
            end
        end
    end
    return false
end

local _spawnCF = nil
local _plantWorldPositions = {}

local GARDEN_TTL = 2
local _gardenDirty = true
local _lastGardenPoll = 0
local _plantCounts = {}
local _harvestTargets = {}
local _candidDirty = true

local function _plantWorldPos(p)
    local gp = p.Positions
    if not gp or not gp.PosX or not gp.PosZ then return nil end
    local v = Vector3.new(gp.PosX, gp.PosY or 0, gp.PosZ)
    if _spawnCF then return _spawnCF:PointToWorldSpace(v) end
    return v
end

local function _rebuildGardenCache()
    if not GardenSyncCtrl then return end
    local garden = GardenSyncCtrl:GetGarden(userId)
    if not garden then return end

    _plantCounts = {}
    _harvestTargets = {}
    _densGrid = {}
    _occGrid = {}
    _plantWorldPositions = {}

    local doHarvest = Options.HarvestEnabled.Value
    local mutationSet = selectedSet(Options.HarvestMutations)
    local variantSet = selectedSet(Options.HarvestVariants)
    local instantMutated = Options.HarvestInstantMutated.Value

    for plantId, p in pairs(garden) do
        local name = p.PlantName
        if name then
            _plantCounts[name] = (_plantCounts[name] or 0) + 1
        end

        local wp = _plantWorldPos(p)
        if wp then
            _densAdd(wp)
            _occMark(wp)
            _plantWorldPositions[#_plantWorldPositions + 1] = wp
        end

        if doHarvest then
            if p.Fruits then
                for fruitId, f in pairs(p.Fruits) do
                    if checkFruitCollect(mutationSet, variantSet, instantMutated, f.Mutation, f.Variant, f.Age or 0, f.MaxAge or 0) then
                        local ht = _harvestTargets
                        ht[#ht + 1] = { plantId = plantId, fruitId = fruitId }
                    end
                end
            else
                if checkFruitCollect(mutationSet, variantSet, instantMutated, p.Mutation, p.Variant, p.Age or 0, p.MaxAge or 0) then
                    local ht = _harvestTargets
                    ht[#ht + 1] = { plantId = plantId, fruitId = "" }
                end
            end
        end
    end

    _candidDirty = true
    _gardenDirty = false
end

local function tickGarden()
    local now = os.clock()
    if _gardenDirty or now - _lastGardenPoll >= GARDEN_TTL then
        _lastGardenPoll = now
        _rebuildGardenCache()
    end
end

local function markGardenDirty() _gardenDirty = true end

local _plantAreaParams = nil
local function _buildPlantAreaParams()
    _plantAreaParams = RaycastParams.new()
    _plantAreaParams.FilterType = Enum.RaycastFilterType.Include
    _plantAreaParams.FilterDescendantsInstances = CollectionService:GetTagged("PlantArea")
end

local function _ensureStaticParams()
    if not _plantAreaParams then _buildPlantAreaParams() end
end

local _candidates = {}
local _candidSorted = {}
local _sprinklerCands = {}
local _cachedPlotId = nil
local _plotCenter = nil
local _perimeter = nil

local function _collectPlantAreas(plot)
    local out = {}
    for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
        if part:IsA("BasePart") and part:IsDescendantOf(plot) then
            out[#out + 1] = part
        end
    end
    return out
end

local function _computePerimeter(plantAreas)
    local minX, minZ = math.huge, math.huge
    local maxX, maxZ = -math.huge, -math.huge
    local sumY, nY = 0, 0
    for _, part in ipairs(plantAreas) do
        local p, s = part.Position, part.Size
        local hx, hz = s.X * 0.5, s.Z * 0.5
        if p.X - hx < minX then minX = p.X - hx end
        if p.X + hx > maxX then maxX = p.X + hx end
        if p.Z - hz < minZ then minZ = p.Z - hz end
        if p.Z + hz > maxZ then maxZ = p.Z + hz end
        sumY += p.Y; nY += 1
    end
    if nY == 0 then return nil end
    local y = sumY / nY
    return {
        minX = minX, maxX = maxX, minZ = minZ, maxZ = maxZ, y = y,
        center = Vector3.new((minX + maxX) * 0.5, y, (minZ + maxZ) * 0.5),
    }
end

local function _inPerimeter(pos)
    local pr = _perimeter
    if not pr then return true end
    return pos.X >= pr.minX and pos.X <= pr.maxX
        and pos.Z >= pr.minZ and pos.Z <= pr.maxZ
end

local function _precomputeCandidates(plot, plantAreas)
    _candidates = {}
    _candidDirty = true
    if #plantAreas == 0 then return end
    for _, area in ipairs(plantAreas) do
        local ap = area.Position
        local as = area.Size
        local stX = math.max(1, math.floor(as.X / 2))
        local stZ = math.max(1, math.floor(as.Z / 2))
        for ix = 0, stX do
            for iz = 0, stZ do
                local ox = ((ix / stX) - 0.5) * as.X * 0.85
                local oz = ((iz / stZ) - 0.5) * as.Z * 0.85
                local org = Vector3.new(ap.X + ox, ap.Y + 50, ap.Z + oz)
                local hit = workspace:Raycast(org, Vector3.new(0, -100, 0), _plantAreaParams)
                if hit and hit.Instance:IsDescendantOf(plot) then
                    _candidates[#_candidates + 1] = hit.Position
                end
            end
        end
    end
end

local function _precomputeSprinklerCands(plantAreas)
    local STEP = 5
    local out = {}
    for _, part in ipairs(plantAreas) do
        local sz, cf = part.Size, part.CFrame
        local hX, hY, hZ = sz.X * 0.5, sz.Y * 0.5, sz.Z * 0.5
        local xSt = math.floor(sz.X / STEP)
        local zSt = math.floor(sz.Z / STEP)
        for xi = 0, xSt do
            for zi = 0, zSt do
                out[#out + 1] = cf:PointToWorldSpace(
                    Vector3.new(-hX + xi * STEP, hY, -hZ + zi * STEP)
                )
            end
        end
    end
    return out
end

local function getSortedCandidates()
    if not _candidDirty then return _candidSorted end
    local n = #_candidates
    local scored = table.create(n)
    for i = 1, n do
        scored[i] = { idx = i, score = densityAt(_candidates[i]) }
    end
    table.sort(scored, function(a, b) return a.score > b.score end)
    _candidSorted = scored
    _candidDirty = false
    return scored
end

local function _trySetup(plotId)
    if _cachedPlotId == plotId and _plotCenter then return true end
    local gardens = workspace:FindFirstChild("Gardens")
    local plot = gardens and gardens:FindFirstChild("Plot" .. tostring(plotId))
    if not plot then return false end

    _ensureStaticParams()
    local sp = plot:FindFirstChild("SpawnPoint")
    _spawnCF = sp and sp.CFrame or nil

    local plantAreas = _collectPlantAreas(plot)
    _perimeter = _computePerimeter(plantAreas)
    _plotCenter = (_perimeter and _perimeter.center) or plot:GetPivot().Position
    _precomputeCandidates(plot, plantAreas)
    _sprinklerCands = _precomputeSprinklerCands(plantAreas)

    _cachedPlotId = plotId
    markGardenDirty()
    return _plotCenter ~= nil
end

