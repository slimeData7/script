local function HandleAllSelection(dropdown, values, label)
    dropdown:OnChanged(function()
        local selected = dropdown.Value
        if selected["All"] then
            local full = {}
            for _, name in ipairs(values) do
                if name ~= "All" then
                    full[name] = true
                end
            end
            dropdown:SetValue(full)
        end
        debugLog(label or "Dropdown", "selection changed")
    end)
end

local function logToggle(name, label)
    return function()
        local state = Fluent.Options[name] and Fluent.Options[name].Value
        debugLog(label or name, state and "enabled" or "disabled")
    end
end

