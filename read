local MAX_LOG_LINES = 300
local SETTLE_TIME = 0.1

local function debugLog(tag, ...)
    local parts = { ... }
    for i = 1, select("#", ...) do
        parts[i] = tostring(parts[i])
    end
    local line = string.format("[%s] %s", tag, table.concat(parts, " "))
    local log = getgenv().IdiotHubLog
    log[#log + 1] = { text = line, time = os.time(), level = "info" }
    if #log > MAX_LOG_LINES then table.remove(log, 1) end
    if getgenv().IdiotHubDebug then
        print("[IdiotHub]", "[" .. tag .. "]", ...)
    end
end

local function debugWarn(tag, ...)
    local parts = { ... }
    for i = 1, select("#", ...) do
        parts[i] = tostring(parts[i])
    end
    local line = string.format("[%s] %s", tag, table.concat(parts, " "))
    local log = getgenv().IdiotHubLog
    log[#log + 1] = { text = line, time = os.time(), level = "warn" }
    if #log > MAX_LOG_LINES then table.remove(log, 1) end
    if getgenv().IdiotHubDebug then
        warn("[IdiotHub]", "[" .. tag .. "]", ...)
    end
end

local function featureLoop(name, interval, body)
    task.spawn(function()
        while true do
            task.wait(interval)
            local ok, err = xpcall(body, debug.traceback)
            if not ok then
                debugWarn(name, "errored:", err)
            end
        end
    end)
end

local ActionQueue = {}
do
    local _lock = false
    local _executing = nil

    function ActionQueue.acquire(actionName, timeoutSeconds)
        timeoutSeconds = timeoutSeconds or 1
        local startTime = os.clock()
        while os.clock() - startTime < timeoutSeconds do
            if not _lock then
                _lock = true
                _executing = actionName
                return true
            end
            task.wait()
        end
        return false
    end

    function ActionQueue.release(actionName)
        if _executing == actionName then
            _executing = nil
            _lock = false
        end
    end
end

local function withAll(list)
    table.insert(list, 1, "All")
    return list
end

local function safeList(label, builder)
    local ok, result = xpcall(builder, debug.traceback)
    if ok and type(result) == "table" then
        return withAll(result)
    end
    debugWarn(label, "list build failed:", result)
    return withAll({})
end

local function GetMutationNames()
    return safeList("Mutations", function()
        local list = {}
        for name in pairs(MutationData) do
            table.insert(list, name)
        end
        table.sort(list)
        return list
    end)
end

local function GetSeedNames()
    return safeList("Seeds", function()
        local list = {}
        for _, seed in ipairs(SeedData) do
            table.insert(list, seed.SeedName)
        end
        return list
    end)
end

local function GetFruitNames()
    return safeList("Fruits", function()
        local list = {}
        for name in pairs(SellValueData) do
            table.insert(list, name)
        end
        return list
    end)
end

local function GetPetRarities()
    return safeList("PetRarities", function()
        local list, seen = {}, {}
        for _, pet in pairs(PetData) do
            if type(pet) == "table" and pet.Rarity and not seen[pet.Rarity] then
                seen[pet.Rarity] = true
                table.insert(list, pet.Rarity)
            end
        end
        return list
    end)
end

local function GetPetNames()
    return safeList("PetNames", function()
