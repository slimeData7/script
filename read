        { name = "Rarity", value = tostring(data.Rarity), inline = true },
        { name = "server-job-id", value = tostring(game.JobId), inline = false },
        { name = "pet-unique-guid", value = tostring(guid or "N/A"), inline = false },
    }
    local note = Options.PetsNote.Value
    if note and note ~= "" then
        table.insert(fields, { name = "Note", value = note, inline = false })
    end
    local embed = {
        title = title,
        color = 0x5865F2,
        fields = fields,
        footer = { text = "discord.gg/idiothub" },
    }
    local thumbnailUrl = getIconUrl(_petBuyIconCache, data.Image)
    if thumbnailUrl then embed.thumbnail = { url = thumbnailUrl } end

    local payload
    local ok = pcall(function()
        payload = HttpService:JSONEncode({ embeds = { embed } })
    end)
    if not ok or not payload then
        debugWarn("Auto Buy Pets", "Failed to encode webhook payload")
        return
    end

    local reqOk, response = pcall(function()
        return request({
            Url = webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = payload,
        })
    end)
    if not reqOk or not response or not response.StatusCode or response.StatusCode >= 300 then
        debugWarn("Auto Buy Pets", "Webhook send failed")
    end
end

local function getRarityForPetName(petName)
    local data = PetData[petName]
    return data and data.Rarity
end

local function shouldBuyPet(data)
    local raritySet = selectedSet(Options.TargetRarities)
    local nameSet = selectedSet(Options.TargetPets)
    if nameSet and nameSet[data.DisplayName] then return true end
    if raritySet then
        local rarity = getRarityForPetName(data.DisplayName)
        if rarity and raritySet[rarity] then return true end
    end
    if nameSet == nil or raritySet == nil then return true end
    return false
end

local petBuying = {}
local petPendingConfirm = {}
local petConfirmedGuids = {}
local PetBuyState = { active = 0 }

local function findGuidForPet(petName)
    if not wildPetSpawns then return nil end
    for _, child in ipairs(wildPetSpawns:GetChildren()) do
        local pn, g = parseWildPetName(child.Name)
        if pn == petName and g then return g end
    end
    return nil
end

local function executeBuyPet(refPart, petName, data, guid)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    petPendingConfirm[petName] = {
        Price = refPart:GetAttribute("Price") or data.BasePrice,
        guid = guid,
    }

    for _ = 0, 2 do
        if guid and petConfirmedGuids[guid] then break end
        if not refPart.Parent then break end
        local owner = refPart:GetAttribute("OwnerName")
        if owner and #owner > 1 then break end

        if ActionQueue.acquire("BuyPets") then
            if not refPart.Parent then
                ActionQueue.release("BuyPets")
                break
            end

            teleport(CFrame.new(refPart.Position + Vector3.new(0, 3, 0)))
            task.wait(0.2)

            if refPart.Parent then
                local ok, err = pcall(function()
                    Remotes.WildPetTame:Fire(refPart)
                end)
                if not ok then
                    debugWarn("Auto Buy Pets", "WildPetTame fire failed:", err)
                end
            end
            ActionQueue.release("BuyPets")

            local deadline = os.clock() + 2
            while os.clock() < deadline do
                if guid and petConfirmedGuids[guid] then break end
                if not refPart.Parent then break end
                task.wait(0.1)
            end
            if guid and petConfirmedGuids[guid] then break end
        end
    end

    petPendingConfirm[petName] = nil
end

local function tryBuyPet(refPart)
    if not Options.BuyPetsEnabled.Value then return end
    if petBuying[refPart] then return end

    local owner = refPart:GetAttribute("OwnerName")
    if owner and #owner > 1 then return end

    local petName = refPart:GetAttribute("PetName")
    local data = petName and PetData[petName]
    if not data then return end
    if not shouldBuyPet(data) then return end

    local price = refPart:GetAttribute("Price") or data.BasePrice
    if not price or getBalance() < price then return end

    local parent = refPart.Parent
    local guid = nil
    if parent then
        local _, g = parseWildPetName(parent.Name)
        guid = g
    end
    if guid and (petBuying[guid] or petConfirmedGuids[guid]) then return end

    petBuying[refPart] = true
    if guid then petBuying[guid] = true end

    PetBuyState.active += 1
    local ok, err = pcall(executeBuyPet, refPart, petName, data, guid)
    if not ok then
        debugWarn("Auto Buy Pets", "executeBuyPet errored:", err)
    end
    PetBuyState.active -= 1

    petBuying[refPart] = nil
    if guid then petBuying[guid] = nil end
end

if Remotes.WildPetCollected then
    Remotes.WildPetCollected.OnClientEvent:Connect(function(...)
        local petName = select(2, ...)
        if not petName then return end
        local meta = petPendingConfirm[petName]
        local data = PetData[petName]
        if not data then return end
        local guid = meta and meta.guid or findGuidForPet(petName)
        if guid then petConfirmedGuids[guid] = true end
        local price = (meta and meta.Price) or data.BasePrice or 0
        local oneIn = calcOneIn(data.SpawnChance)
        task.spawn(sendBuyPetWebhook, data, price, oneIn, guid)
        debugLog("Auto Buy Pets", "Bought", petName)
    end)
end

if wildPetRef then
    wildPetRef.ChildAdded:Connect(function(refPart)
        task.spawn(tryBuyPet, refPart)
    end)

    task.spawn(function()
        while true do
            task.wait(15)
            for _, refPart in ipairs(wildPetRef:GetChildren()) do
                task.spawn(tryBuyPet, refPart)
            end
        end
    end)
end

