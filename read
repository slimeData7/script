local function sendPetCaptureWebhook(webhookUrl, note, data, price, oneIn, guid)
    if not isValidWebhookUrl(webhookUrl) then return end

    local article = data.DisplayName:match("^[AEIOUaeiou]") and "an" or "a"
    local title = "Captured " .. article .. " 1 in " .. formatNumber(oneIn) .. " " .. data.DisplayName .. "!"
    local fields = {
        { name = "Player", value = "||" .. LocalPlayer.Name .. "||", inline = true },
        { name = "Price", value = formatNumber(price), inline = true },
        { name = "Rarity", value = tostring(data.Rarity), inline = true },
        { name = "server-job-id", value = tostring(game.JobId), inline = false },
        { name = "pet-unique-guid", value = tostring(guid or "N/A"), inline = false },
    }
    if note and note ~= "" then
        table.insert(fields, { name = "Note", value = note, inline = false })
    end
    local embed = {
        title = title,
        color = 0x5865F2,
        fields = fields,
        footer = { text = "discord.gg/idiothub" },
    }
    local thumbnailUrl = getIconUrl(_petBuyIconCache, data.Image)
    if thumbnailUrl then embed.thumbnail = { url = thumbnailUrl } end

    local payload
    local ok = pcall(function()
        payload = HttpService:JSONEncode({ embeds = { embed } })
    end)
    if not ok or not payload then
        debugWarn("Pet Capture", "Failed to encode webhook payload")
        return
    end

    local reqOk, response = pcall(function()
        return request({
            Url = webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = payload,
        })
    end)
    if not reqOk or not response or not response.StatusCode or response.StatusCode >= 300 then
        debugWarn("Pet Capture", "Webhook send failed")
    end
end

local PetPurchaseCore = {}
do
    local buying = {}
    local pendingConfirm = {}
    local confirmedGuids = {}
    local activeCount = 0

    function PetPurchaseCore.findGuidForPet(petName)
        if not wildPetSpawns then return nil end
        for _, child in ipairs(wildPetSpawns:GetChildren()) do
            local pn, g = parseWildPetName(child.Name)
            if pn == petName and g then return g end
        end
        return nil
    end

    local function executeCapture(refPart, petName, data, guid, captureRemote)
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        pendingConfirm[petName] = {
            Price = refPart:GetAttribute("Price") or data.BasePrice,
            guid = guid,
        }

        for _ = 0, 2 do
            if guid and confirmedGuids[guid] then break end
            if not refPart.Parent then break end
            local owner = refPart:GetAttribute("OwnerName")
            if owner and #owner > 1 then break end

            teleport(refPart.Position + Vector3.new(0, 3, 0))
            task.wait(0.2)

            safeFire(captureRemote, refPart)

            local deadline = os.clock() + 2
            while os.clock() < deadline do
                if guid and confirmedGuids[guid] then break end
                if not refPart.Parent then break end
                task.wait(0.1)
            end
            if guid and confirmedGuids[guid] then break end
        end

        pendingConfirm[petName] = nil
    end

    function PetPurchaseCore.tryCapture(config)
        local refPart = config.refPart
        local petName = config.petName
        local data = config.data
        local captureRemote = config.captureRemote
        local shouldBuy = config.shouldBuy
        local enabled = config.enabled

        if not enabled then return end
        if buying[refPart] then return end

        local owner = refPart:GetAttribute("OwnerName")
        if owner and #owner > 1 then return end
        if not shouldBuy then return end

        local price = refPart:GetAttribute("Price") or data.BasePrice
        if not price or getBalance() < price then return end

        local parent = refPart.Parent
        local guid = nil
        if parent then
            local _, g = parseWildPetName(parent.Name)
            guid = g
        end
        if guid and (buying[guid] or confirmedGuids[guid]) then return end

        buying[refPart] = true
        if guid then buying[guid] = true end

        activeCount += 1
        local ok, err = pcall(executeCapture, refPart, petName, data, guid, captureRemote)
        if not ok then
            debugWarn("Pet Capture", "executeCapture errored:", err)
        end
        activeCount -= 1

        buying[refPart] = nil
        if guid then buying[guid] = nil end
    end

    function PetPurchaseCore.onCaptureConfirmed(petName, onConfirmed)
        local meta = pendingConfirm[petName]
        local data = PetData[petName]
        if not data then return end
        local guid = meta and meta.guid or PetPurchaseCore.findGuidForPet(petName)
        if guid then confirmedGuids[guid] = true end
        local price = (meta and meta.Price) or data.BasePrice or 0
        onConfirmed(data, price, guid)
    end
end

local function shouldBuyWildPet(data)
    local raritySet = selectedSet(Options.TargetRarities)
    local nameSet = selectedSet(Options.TargetPets)
    if nameSet and nameSet[data.DisplayName] then return true end
    if raritySet and raritySet[data.Rarity] then return true end
    if nameSet == nil or raritySet == nil then return true end
    return false
end

if Remotes.WildPetCollected then
    Remotes.WildPetCollected.OnClientEvent:Connect(function(...)
        local petName = select(2, ...)
        if not petName then return end
        PetPurchaseCore.onCaptureConfirmed(petName, function(data, price, guid)
            local oneIn = calcOneIn(data.SpawnChance)
            local webhookUrl = Options.PetsWebhookURL.Value
            local note = Options.PetsNote.Value
            local minLuck = clampNumberInput(Options.MinLuckSent.Value, 0, 0, nil)
            if oneIn >= minLuck then
                task.spawn(sendPetCaptureWebhook, webhookUrl, note, data, price, oneIn, guid)
            end
            debugLog("Auto Buy Pets", "Bought", petName)
        end)
    end)
end

if wildPetRef then
    local function handleRefPart(refPart)
        local petName = refPart:GetAttribute("PetName")
        local data = petName and PetData[petName]
        if not data then return end
        PetPurchaseCore.tryCapture({
            refPart = refPart,
            petName = petName,
            data = data,
            captureRemote = Remotes.WildPetTame,
            shouldBuy = shouldBuyWildPet(data),
            enabled = Options.BuyPetsEnabled.Value,
        })
    end

    wildPetRef.ChildAdded:Connect(function(refPart)
        task.spawn(handleRefPart, refPart)
    end)

    featureLoop("WildPetSweep", 15, function()
        for _, refPart in ipairs(wildPetRef:GetChildren()) do
            task.spawn(handleRefPart, refPart)
        end
    end)
end

