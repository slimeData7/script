local function _isFruit(t)
    return t:GetAttribute("Fruit") ~= nil and t:GetAttribute("FruitName") ~= nil
end

local function _isSeed(t)
    return t:IsA("Tool") and t:GetAttribute("SeedTool") ~= nil
end

local function _isSprinkler(t)
    return t:IsA("Tool") and t:GetAttribute("Sprinkler") ~= nil
end

local function _listAdd(map, key, tool)
    local list = map[key]
    if not list then list = {}; map[key] = list end
    list[#list + 1] = tool
end

local function _listRemove(map, key, tool)
    local list = map[key]
    if not list then return end
    local i = table.find(list, tool)
    if i then
        list[i] = list[#list]
        list[#list] = nil
    end
    if #list == 0 then map[key] = nil end
end

local function _onToolAdded(tool)
    if _isFruit(tool) then
        _fruitCountAll += 1
        if tool:GetAttribute("IsFavorite") ~= true then
            _fruitCountNonFav += 1
        end
    end
    if _isSeed(tool) then
        _listAdd(_seedInventory, tool:GetAttribute("SeedTool"), tool)
    end
    if _isSprinkler(tool) then
        _listAdd(_sprinklerInventory, tool:GetAttribute("Sprinkler"), tool)
    end
end

local function _onToolRemoved(tool)
    if _isFruit(tool) then
        _fruitCountAll = math.max(0, _fruitCountAll - 1)
        if tool:GetAttribute("IsFavorite") ~= true then
            _fruitCountNonFav = math.max(0, _fruitCountNonFav - 1)
        end
    end
    if _isSeed(tool) then
        _listRemove(_seedInventory, tool:GetAttribute("SeedTool"), tool)
    end
    if _isSprinkler(tool) then
        _listRemove(_sprinklerInventory, tool:GetAttribute("Sprinkler"), tool)
    end
end

