local function _getCachedSellValue(tool)
    local v = _sellValueCache[tool]
    if v ~= nil then
        return v ~= SELL_MISS and v or nil
    end
    local r = _fruitReg[tool]
    if not r then return nil end
    local ok, computed = pcall(FruitValueCalc, r.name, tool:GetAttribute("SizeMultiplier") or 1, r.mutation, LocalPlayer, tool:GetAttribute("DecayAlpha"))
    if not ok then
        debugWarn("SellValue", "FruitValueCalc failed for", r.name, "-", computed)
        computed = nil
    end
    _sellValueCache[tool] = computed ~= nil and computed or SELL_MISS
    return computed
end

local function _markFavDirty(tool, rec)
    if not rec.isFavorite then
        _favQueue[tool] = true
    end
end

local function _registerFruit(tool)
    if _fruitReg[tool] then return end

    local isFav = tool:GetAttribute("IsFavorite") == true
    local rec = {
        id = tool:GetAttribute("Id"),
        name = tool:GetAttribute("FruitName"),
        mutation = tool:GetAttribute("Mutation"),
        variant = tool:GetAttribute("Variant"),
        weight = tool:GetAttribute("Weight"),
        isFavorite = isFav,
    }
    _fruitReg[tool] = rec

    if not isFav then
        _favQueue[tool] = true
        _sellSet[tool] = true
    end

    local conns = table.create(6)
    _fruitConns[tool] = conns

    conns[1] = tool:GetAttributeChangedSignal("IsFavorite"):Connect(function()
        local fav = tool:GetAttribute("IsFavorite") == true
        rec.isFavorite = fav
        if fav then
            _favQueue[tool] = nil
            _favQueueSwap[tool] = nil
            _sellSet[tool] = nil
        else
            _favQueue[tool] = true
            _sellSet[tool] = true
        end
    end)

    conns[2] = tool:GetAttributeChangedSignal("Mutation"):Connect(function()
        rec.mutation = tool:GetAttribute("Mutation")
        _sellValueCache[tool] = nil
        _markFavDirty(tool, rec)
    end)

    conns[6] = tool:GetAttributeChangedSignal("Variant"):Connect(function()
        rec.variant = tool:GetAttribute("Variant")
        _markFavDirty(tool, rec)
    end)

    conns[3] = tool:GetAttributeChangedSignal("Weight"):Connect(function()
        rec.weight = tool:GetAttribute("Weight")
        _markFavDirty(tool, rec)
    end)

    conns[4] = tool:GetAttributeChangedSignal("SizeMultiplier"):Connect(function()
        _sellValueCache[tool] = nil
        _markFavDirty(tool, rec)
    end)

    conns[5] = tool:GetAttributeChangedSignal("DecayAlpha"):Connect(function()
        _sellValueCache[tool] = nil
        _markFavDirty(tool, rec)
    end)
end

local function _unregisterFruit(tool)
    local conns = _fruitConns[tool]
    if not conns then return end
    for _, c in ipairs(conns) do c:Disconnect() end
    _fruitConns[tool] = nil
    _fruitReg[tool] = nil
    _favQueue[tool] = nil
    _favQueueSwap[tool] = nil
    _sellSet[tool] = nil
    _sellValueCache[tool] = nil
end

