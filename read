local function buildSprinklerState(synced)
    local counts, occupied = {}, {}
    for _, s in pairs(synced) do
        local name = s.SprinklerName
        counts[name] = (counts[name] or 0) + 1
        local pos = s.Positions
        if pos and RadiusMap[name] and _spawnCF then
            local r = RadiusMap[name]
            occupied[#occupied + 1] = {
                Pos = _spawnCF:PointToWorldSpace(Vector3.new(pos.PosX, pos.PosY, pos.PosZ)),
                R2 = r * r,
                Name = name,
            }
        end
    end
    return counts, occupied
end

local function isCovered(occupied, pos, name)
    local px, pz = pos.X, pos.Z
    for _, o in ipairs(occupied) do
        if o.Name == name then
            local dx = o.Pos.X - px
            local dz = o.Pos.Z - pz
            if dx * dx + dz * dz < o.R2 then return true end
        end
    end
    return false
end

local function scoreSprinklerCands()
    local plants = _plantWorldPositions
    local n = #_sprinklerCands
    local out = table.create(n)
    local DR2 = 15 * 15
    for i = 1, n do
        local wp = _sprinklerCands[i]
        local wx, wz = wp.X, wp.Z
        local d = 0
        for _, pp in ipairs(plants) do
            local dx = wx - pp.X
            local dz = wz - pp.Z
            if dx * dx + dz * dz <= DR2 then d += 1 end
        end
        out[i] = { Position = wp, Density = d }
    end
    table.sort(out, function(a, b) return a.Density > b.Density end)
    return out
end

