        ZIndex           = 5,
    }, header)
    make("UIGradient", { Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Color3.new(0,0,0)), ColorSequenceKeypoint.new(0.2, Color3.new(1,1,1)), ColorSequenceKeypoint.new(0.8, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(0,0,0)) }) }, headerBorder)

    make("TextLabel", {
        Size                   = UDim2.new(0.5, 0, 0, 34),
        Position               = UDim2.fromOffset(24, 12),
        BackgroundTransparency = 1,
        Text                   = "Event Hopper",
        TextColor3             = PALETTE.text,
        Font                   = Enum.Font.GothamBold,
        TextSize               = 22,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 5,
    }, header)

    make("TextLabel", {
        Size                   = UDim2.new(0.5, 0, 0, 22),
        Position               = UDim2.fromOffset(24, 44),
        BackgroundTransparency = 1,
        Text                   = table.concat(Config.TargetEvents, " / ") .. "  •  " .. tostring(lp.Name),
        TextColor3             = PALETTE.accent,
        Font                   = Enum.Font.Gotham,
        TextSize               = 14,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 5,
    }, header)

    local cardsRow = make("Frame", {
        Size             = UDim2.new(1, -40, 0, 180),
        Position         = UDim2.fromOffset(20, 92),
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
        ZIndex           = 4,
    }, content)

    local function makeCard(parent, idx, total, label, valueColor)
        local gap   = 16
        local cardW = (1 / total)
        local card  = make("Frame", {
            Size             = UDim2.new(cardW, idx < total and -gap or 0, 1, 0),
            Position         = UDim2.new(cardW * (idx - 1), idx > 1 and gap * (idx - 1) or 0, 0, 0),
            BackgroundColor3 = PALETTE.panel,
            BorderSizePixel  = 0,
            ZIndex           = 5,
        }, parent)
        corner(card, 14)
        stroke(card, PALETTE.border, 1)
        make("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(11, 14, 24)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(7,  9,  16)),
            }),
            Rotation = 90,
        }, card)
        local cardTop = make("Frame", {
            Size             = UDim2.new(0.5, 0, 0, 3),
            Position         = UDim2.fromScale(0.25, 0),
            BackgroundColor3 = valueColor,
            BackgroundTransparency = 0.3,
            BorderSizePixel  = 0,
            ZIndex           = 6,
        }, card)
        corner(cardTop, 2)
        make("TextLabel", {
            Size                   = UDim2.new(1, -24, 0, 22),
            Position               = UDim2.fromOffset(16, 20),
            BackgroundTransparency = 1,
            Text                   = label,
            TextColor3             = PALETTE.dim,
            Font                   = Enum.Font.Gotham,
            TextSize               = 13,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 6,
        }, card)
        local val = make("TextLabel", {
            Size                   = UDim2.new(1, -24, 0, 72),
            Position               = UDim2.fromOffset(16, 46),
            BackgroundTransparency = 1,
            Text                   = "0",
            TextColor3             = valueColor,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 58,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 6,
        }, card)
        return val
    end

    local joinedVal = makeCard(cardsRow, 1, 4, "SERVERS JOINED", PALETTE.green)
    local failedVal = makeCard(cardsRow, 2, 4, "FAILED",          PALETTE.red)
    local eventVal  = makeCard(cardsRow, 3, 4, "EVENTS FOUND",    PALETTE.gold)
    local queueVal  = makeCard(cardsRow, 4, 4, "QUEUE",           PALETTE.accent)

    local statusBar = make("Frame", {
        Size             = UDim2.new(1, -40, 0, 60),
        Position         = UDim2.fromOffset(20, 292),
        BackgroundColor3 = PALETTE.panel,
        BorderSizePixel  = 0,
        ZIndex           = 4,
    }, content)
    corner(statusBar, 12)
    stroke(statusBar, PALETTE.accent, 1)
    make("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(12, 16, 30)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(7,  9,  18)),
        }),
        Rotation = 0,
    }, statusBar)

    local dot = make("Frame", {
        Size             = UDim2.new(0, 12, 0, 12),
        Position         = UDim2.fromOffset(18, 24),
        BackgroundColor3 = PALETTE.accent,
        BorderSizePixel  = 0,
        ZIndex           = 5,
    }, statusBar)
    corner(dot, 6)

    local statusLbl = make("TextLabel", {
        Size                   = UDim2.new(1, -50, 1, 0),
        Position               = UDim2.fromOffset(40, 0),
        BackgroundTransparency = 1,
        Text                   = "Starting...",
        TextColor3             = PALETTE.accent,
        Font                   = Enum.Font.GothamBold,
        TextSize               = 16,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 5,
    }, statusBar)

    task.spawn(function()
        while sg.Parent do
            TweenService:Create(dot, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { BackgroundTransparency = 0.65 }):Play()
            task.wait(0.9)
            TweenService:Create(dot, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), { BackgroundTransparency = 0 }):Play()
            task.wait(0.9)
        end
    end)

    content.Position = UDim2.new(0, 0, -1, 0)
    TweenService:Create(content, TweenInfo.new(0.65, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.fromScale(0, 0)
    }):Play()

    local lastStatus = ""
    RunService.Heartbeat:Connect(function()
        if not sg.Parent then return end
        joinedVal.Text = tostring(localStats.totalJoined)
        failedVal.Text = tostring(localStats.totalFailed)
        eventVal.Text  = tostring(localStats.eventsFound)
        queueVal.Text  = tostring(localQueueSize)

        if localStats.status ~= lastStatus then
            lastStatus = localStats.status
            TweenService:Create(statusLbl, TweenInfo.new(0.1), { TextTransparency = 1 }):Play()
            task.delay(0.1, function()
                if not sg.Parent then return end
                statusLbl.Text = localStats.status
                local col = PALETTE.accent
                if localStats.status:find("RAINBOW")  then col = PALETTE.gold  end
                if localStats.status:find("INFERNAL") then col = PALETTE.red   end
                if localStats.status:find("Stopped")  then col = PALETTE.gold  end
                if localStats.status:find("Joined")   then col = PALETTE.green end
                if localStats.status:find("Failed")   then col = PALETTE.red   end
                if localStats.status:find("Fetch")    then col = PALETTE.dim   end
                statusLbl.TextColor3 = col
                dot.BackgroundColor3 = col
                TweenService:Create(statusLbl, TweenInfo.new(0.15), { TextTransparency = 0 }):Play()
            end)
        end
    end)
end

local function applyOptimization()
    pcall(function() settings().Rendering.QualityLevel = 1 end)
    pcall(function()
        Lighting.GlobalShadows   = false
        Lighting.FogEnd          = 9e9
        Lighting.Brightness      = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
    pcall(function()
        local LODController = workspace:FindFirstChildOfClass("LODController")
        if LODController then LODController.FramesBudget = 0 end
    end)
end

local function teleportToServer(jobId, attempt)
    attempt = attempt or 1
    localStats.status = "Hopping → " .. jobId:sub(1, 8) .. "..."
    dprint("Teleport attempt", attempt, "->", jobId)

    local ok, err = pcall(TeleportService.TeleportToPlaceInstance, TeleportService, placeId, jobId, lp)

    if not ok then
        dprint("Teleport error:", err)
        if Config.RetryFailedTeleport and attempt < Config.MaxTeleportRetries then
            task.wait(2 ^ attempt)
            return teleportToServer(jobId, attempt + 1)
        end
        releaseClaim(jobId)
        markFailed(jobId)
        localStats.totalFailed = localStats.totalFailed + 1
        localStats.status      = "Failed: " .. jobId:sub(1, 8)
        saveAccountStats()
        return false
    end

    markVisited(jobId)
    localStats.totalJoined = localStats.totalJoined + 1
    localStats.status      = "Joined #" .. localStats.totalJoined
    dprint("Teleport dispatched. joined =", localStats.totalJoined)
    saveAccountStats()
    task.wait(10)
    return true
end

local function run()
    print("[ServerHop] Starting — Account:", accountKey, "Targets:", table.concat(Config.TargetEvents, ", "))

    buildUI()
    applyOptimization()
    loadAccountStats()
    loadLocalSets()

    markVisited(game.JobId)

    task.wait(math.random(0, 3) + (tonumber(accountKey:sub(-3)) or 0) % 5)

    local found = checkAndHandleEvent()
    if found and Config.StopOnEventServer then
        print("[ServerHop] Target event on current server. Stopped.")
        return
    end

    if shouldRefetch() then refillSharedQueue() end

    while not hopLock do
        if shouldRefetch() then
            refillSharedQueue()
        end

        local q = readJSON(FILE_SHARED_QUEUE)
        localQueueSize = (q and type(q.data) == "table") and #q.data or 0

        if localQueueSize == 0 then
            print("[ServerHop] Queue empty. Stopping.")
            localStats.status = "No servers found"
            break
        end

        local jobId = popFromSharedQueue()
        if not jobId then
            task.wait(1)
            continue
        end

        if not tryClaimServer(jobId) then
            dprint("Claim failed for", jobId, "— already taken")
            task.wait(0.3)
            continue
        end

        local success = teleportToServer(jobId)

        if success then
            task.wait(3)
            checkAndHandleEvent()
            if hopLock then break end
        end

        task.wait(0.5)
    end

    print("[ServerHop] Session ended.")
    localStats.status = "Session ended"
end

run()
