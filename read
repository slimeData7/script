task.spawn(function()
    local PLANT_SETTLE = 0.1
    while true do
        task.wait(2)
        if Options.PlantEnabled.Value and playerAlive() and LocalPlayer:FindFirstChildOfClass("Backpack") then
            local plotId = LocalPlayer:GetAttribute("PlotId")
            if plotId and _trySetup(plotId) then
                tickGarden()

                local seedSet = selectedSet(Options.PlantSeeds)
                local ignoreSet = selectedSet(Options.PlantIgnoreCrops) or {}
                local plantAmount = tonumber(Options.PlantAmount.Value) or 1
                local ignorePos = Options.PlantIgnorePosition.Value == true

                local seedTools = {}
                for name, toolList in pairs(_seedInventory) do
                    if ignoreSet[name] then continue end
                    if not isSelected(seedSet, name) then continue end
                    local remaining = plantAmount - (_plantCounts[name] or 0)
                    if remaining <= 0 then continue end
                    for _, tool in ipairs(toolList) do
                        if remaining <= 0 then break end
                        local stack = tool:GetAttribute("Count") or 1
                        local useAmt = math.min(stack, remaining)
                        if useAmt > 0 then
                            seedTools[#seedTools + 1] = { tool = tool, amount = useAmt }
                            remaining -= useAmt
                        end
                    end
                end

                if #_candidates > 0 and #seedTools > 0 then
                    local char = LocalPlayer.Character
                    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        local sorted = getSortedCandidates()
                        local sortIdx = 1

                        local function nextSpot()
                            while sortIdx <= #sorted do
                                local pos = _candidates[sorted[sortIdx].idx]
                                sortIdx += 1
                                if _inPerimeter(pos) then
                                    if ignorePos or not isOccupied(pos) then return pos end
                                end
                            end
                            return nil
                        end

                        local function ensureEquipped(tool)
                            if not tool or not tool.Parent then return false end
                            local held = char:FindFirstChildWhichIsA("Tool")
                            if held == tool then return true end
                            humanoid:EquipTool(tool)
                            local deadline = os.clock() + 0.3
                            repeat
                                task.wait()
                                if not tool.Parent then return false end
                                held = char:FindFirstChildWhichIsA("Tool")
                                if held == tool then return true end
                            until os.clock() > deadline
                            return false
                        end

                        local placed = 0
                        for _, entry in ipairs(seedTools) do
                            local seedTool = entry.tool
                            local count = entry.amount
                            while count > 0 do
                                local spot = nextSpot()
                                if not spot then break end
                                if not ensureEquipped(seedTool) then break end
                                local seedName = seedTool:GetAttribute("SeedTool")
                                if not seedName then break end

                                teleport(CFrame.new(spot + Vector3.new(0, 3, 0)))
                                task.wait(PLANT_SETTLE)
                                Remotes.PlantSeed:Fire(spot, seedName, seedTool)

                                _occMark(spot)
                                _optMark(spot)
                                _densAdd(spot)
                                _candidDirty = true
                                placed += 1
                                count -= 1
                            end
                            if sortIdx > #sorted then break end
                        end

                        humanoid:UnequipTools()
                        if placed > 0 then markGardenDirty() end
                    end
                end
            end
        end
    end
end)

local RadiusMap = {}
do
    local SprinklerData = require(ReplicatedStorage.SharedModules.SprinklerData)
    for _, entry in pairs(SprinklerData) do
        if entry.SprinklerName then
            RadiusMap[entry.SprinklerName] = entry.Radius
        else
            for _, inner in pairs(entry) do
                if inner.SprinklerName then
                    RadiusMap[inner.SprinklerName] = inner.Radius
                end
            end
        end
    end
end

local function buildSprinklerState(synced)
    local counts, occupied = {}, {}
    for _, s in pairs(synced) do
        local name = s.SprinklerName
        counts[name] = (counts[name] or 0) + 1
        local pos = s.Positions
        if pos and RadiusMap[name] and _spawnCF then
            local r = RadiusMap[name]
            occupied[#occupied + 1] = {
                Pos = _spawnCF:PointToWorldSpace(Vector3.new(pos.PosX, pos.PosY, pos.PosZ)),
                R2 = r * r,
                Name = name,
            }
        end
    end
    return counts, occupied
end

local function isCovered(occupied, pos, name)
    local px, pz = pos.X, pos.Z
    for _, o in ipairs(occupied) do
        if o.Name == name then
            local dx = o.Pos.X - px
            local dz = o.Pos.Z - pz
            if dx * dx + dz * dz < o.R2 then return true end
        end
    end
    return false
end

local function scoreSprinklerCands()
    local plants = _plantWorldPositions
    local n = #_sprinklerCands
    local out = table.create(n)
    local DR2 = 15 * 15
    for i = 1, n do
        local wp = _sprinklerCands[i]
        local wx, wz = wp.X, wp.Z
        local d = 0
        for _, pp in ipairs(plants) do
            local dx = wx - pp.X
            local dz = wz - pp.Z
            if dx * dx + dz * dz <= DR2 then d += 1 end
        end
        out[i] = { Position = wp, Density = d }
    end
    table.sort(out, function(a, b) return a.Density > b.Density end)
    return out
end

