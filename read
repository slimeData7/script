local MAX_LOG_LINES = 300
local MAX_NOTIFICATIONS = 5

local function pushNotification(text)
    local list = G.Notifications
    table.insert(list, 1, { text = text, time = os.time() })
    while #list > MAX_NOTIFICATIONS do
        table.remove(list)
    end
    local ok = pcall(function()
        Fluent:Notify({ Title = "IdiotHub", Content = text, Duration = 4 })
    end)
    if not ok and G.NotifyParagraph then
        pcall(function()
            local lines = {}
            for _, n in ipairs(list) do
                lines[#lines + 1] = n.text
            end
            G.NotifyParagraph:SetDesc(table.concat(lines, "\n"))
        end)
    end
end

local function debugLog(tag, ...)
    local parts = { ... }
    for i = 1, select("#", ...) do
        parts[i] = tostring(parts[i])
    end
    local line = string.format("[%s] %s", tag, table.concat(parts, " "))
    local log = G.Log
    log[#log + 1] = { text = line, time = os.time(), level = "info" }
    if #log > MAX_LOG_LINES then table.remove(log, 1) end
    if G.Debug then
        print("[IdiotHub]", "[" .. tag .. "]", ...)
    end
end

local function debugWarn(tag, ...)
    local parts = { ... }
    for i = 1, select("#", ...) do
        parts[i] = tostring(parts[i])
    end
    local line = string.format("[%s] %s", tag, table.concat(parts, " "))
    local log = G.Log
    log[#log + 1] = { text = line, time = os.time(), level = "warn" }
    if #log > MAX_LOG_LINES then table.remove(log, 1) end
    if G.Debug then
        warn("[IdiotHub]", "[" .. tag .. "]", ...)
    end
    pushNotification(line)
end

local function notify(text)
    debugLog("Notify", text)
    pushNotification(text)
end

local MUTATIONS = { "Bloodlit", "Chained", "Electric", "Frozen", "Gold", "Rainbow", "Starstruck" }

local function withAll(list)
    table.sort(list)
    table.insert(list, 1, "All")
    return list
end

local function safeList(label, builder)
    local ok, result = xpcall(builder, debug.traceback)
    if ok and type(result) == "table" then
        return withAll(result)
    end
    debugWarn(label, "list build failed:", result)
    return withAll({})
end

