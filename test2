local function findUpgradeRemote(folder)
	if not folder then return nil end
	local function search(inst, depth)
		if depth > 5 then return nil end
		if inst:IsA("RemoteFunction") and inst.Name == "Upgrade" then
			return inst
		end
		for _, child in ipairs(inst:GetChildren()) do
			local res = search(child, depth + 1)
			if res then return res end
		end
		return nil
	end
	return search(folder, 0)
end

local function getUpgradeableEarners()
	local earners = {}
	if not tycoonInstance or not Balance or not upgradesComp or not balances then return earners end
	local cash = 0
	local success = pcall(function() cash = balances:GetCash() end)
	if not success then return earners end
	local purchasesFolder = tycoonInstance:FindFirstChild("Purchases")
	if not purchasesFolder then return earners end
	for _, earnerFolder in ipairs(purchasesFolder:GetChildren()) do
		local name = earnerFolder.Name
		if Balance.UpgradePrices and Balance.UpgradePrices[name] then
			local prices = Balance.UpgradePrices[name]
			local currentLevel = 0
			local ok, level = pcall(function() return upgradesComp:GetLevel(name) end)
			if ok and level then currentLevel = level end
			if currentLevel >= #prices then goto continue end
			local nextPrice = prices[currentLevel + 1]
			if not nextPrice then goto continue end
			local canAfford = false
			local okAfford = pcall(function() canAfford = nextPrice <= cash end)
			if not okAfford or not canAfford then goto continue end
			local remote = findUpgradeRemote(earnerFolder)
			if not remote then goto continue end
			table.insert(earners, {
				name = name,
				remote = remote,
				level = currentLevel,
				maxLevel = #prices,
				nextPrice = nextPrice,
			})
		end
		::continue::
	end
	table.sort(earners, function(a, b) return a.nextPrice < b.nextPrice end)
	return earners
end

