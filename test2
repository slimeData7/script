local autoWakeEnabled = false
local wakeTracked = {}
local wakeSelectedStreams = {}

local function getManualStreamNames()
    local names = {}
    for _, entry in streams:GetChildren() do
        if not entry:GetAttribute("Automatic") then
            table.insert(names, entry.Name)
        end
    end
    table.sort(names)
    return names
end

local function shouldWake(name)
    if next(wakeSelectedStreams) == nil then return true end
    return wakeSelectedStreams[name] == true
end

local function startWakeLoop(entry)
    task.spawn(function()
        while autoWakeEnabled do
            if not entry:GetAttribute("Automatic") and shouldWake(entry.Name) then
                pcall(function() wakeRemote:InvokeServer(entry.Name) end)
            end
            local interval = entry:GetAttribute("Interval") or 1
            task.wait(interval)
        end
    end)
end

local function startAllWakeLoops()
    wakeTracked = {}
    for _, entry in streams:GetChildren() do
        if not wakeTracked[entry.Name] then
            wakeTracked[entry.Name] = true
            startWakeLoop(entry)
        end
    end
    streams.ChildAdded:Connect(function(entry)
        if autoWakeEnabled and not wakeTracked[entry.Name] then
            wakeTracked[entry.Name] = true
            startWakeLoop(entry)
        end
    end)
end

