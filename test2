local PREFIXES = {
	{ "Staircase", "Staircase" }, { "Republic", "Republic" }, { "Robotics", "Robotics" },
	{ "Trading",   "Trading"   }, { "Labs",     "Labs"     }, { "Depot",   "Depot"     },
	{ "Dash",      "Dash"      }, { "X",        "X"        },
}

local function getCategory(name)
	for _, pair in ipairs(PREFIXES) do
		if name:find("^" .. pair[1]) then return pair[2] end
	end
	return "Other"
end

local function getUniqueCategories()
	local cats = {}
	if analyzer then
		pcall(function()
			for name in pairs(analyzer:GetPurchases()) do cats[getCategory(name)] = true end
		end)
	end
	local list = { "All" }
	for cat in pairs(cats) do table.insert(list, cat) end
	table.sort(list)
	return list
end

local function getPurchaseStats()
	local totalBought, totalItems = 0, 0
	if not analyzer or not purchasesComp then return totalBought, totalItems end
	pcall(function()
		for name in pairs(analyzer:GetPurchases()) do
			totalItems = totalItems + 1
			if purchasesComp:IsPurchased(name) then totalBought = totalBought + 1 end
		end
	end)
	return totalBought, totalItems
end

local function getAffordableItems(category)
	local items = {}
	if not analyzer or not purchasesComp or not balances then return items end
	pcall(function()
		local cash = balances:GetCash()
		for name, purchase in pairs(analyzer:GetPurchases()) do
			if not purchasesComp:IsPurchased(name) and purchase:IsEnabled() then
				local price = purchase:GetPrice()
				if price and price <= cash then
					local cat = getCategory(name)
					if category == "All" or cat == category then
						table.insert(items, { name = name, display = purchase.DisplayName or name, price = price, purchaseObj = purchase })
					end
				end
			end
		end
	end)
	table.sort(items, function(a, b) return a.price < b.price end)
	return items
end

local function buyItem(purchase)
	pcall(function()
		local remote = purchase.Instance:FindFirstChild("Purchase")
		if not remote or not remote:IsA("RemoteFunction") then return end
		remote:InvokeServer(false)
	end)
end

