local minigameStartRemote = coreRemoteRequest and safeWait(coreRemoteRequest, "MinigameRaceService.Start", 10) or nil
local minigameEndRemote = coreRemoteRequest and safeWait(coreRemoteRequest, "MinigameRaceService.End", 10) or nil

local autoMinigameEnabled = false
local minigameThread = nil
local minigamesWon = 0
local timesCheered = 0

local function getRaceAvailableTime()
	local result = 0
	pcall(function()
		local playerValues = player:FindFirstChild("Values")
		if not playerValues then return end
		local minigameRaceAvailable = playerValues:FindFirstChild("MinigameRaceAvailable")
		if not minigameRaceAvailable then return end
		result = math.max(0, minigameRaceAvailable.Value - workspace:GetServerTimeNow())
	end)
	return result
end

local function getCheerInterval()
	local result = 2
	pcall(function()
		local tycoonValues = tycoonInstance and tycoonInstance:FindFirstChild("Values")
		if not tycoonValues then return end
		local minigameCheer = tycoonValues:FindFirstChild("MinigameCheerInterval")
		if not minigameCheer then return end
		result = minigameCheer.Value or 2
	end)
	return result
end

local function startRace()
	if not minigameStartRemote then return nil end
	local ok, result = pcall(function() return minigameStartRemote:InvokeServer() end)
	return ok and result or nil
end

local function selectBall()
	pcall(function()
		local raceSetup = workspace:FindFirstChild("RaceSetup")
		if raceSetup then
			local balls = {}
			for _, child in ipairs(raceSetup:GetChildren()) do
				local prompt = child:FindFirstChildWhichIsA("ProximityPrompt", true)
				if prompt then table.insert(balls, prompt) end
			end
			if #balls > 0 then
				fireproximityprompt(balls[math.random(1, #balls)])
			end
		end
	end)
end

local function cheerOnce()
	pcall(function()
		local UIS = game:GetService("UserInputService")
		UIS:SendKeyEvent(true, Enum.KeyCode.E, false)
		task.wait(0.05)
		UIS:SendKeyEvent(false, Enum.KeyCode.E, false)
		timesCheered = timesCheered + 1
	end)
end

local function endRace()
	if not minigameEndRemote then return 0 end
	local ok, result = pcall(function() return minigameEndRemote:InvokeServer() end)
	if ok and result and result > 0 then
		minigamesWon = minigamesWon + 1
		return result
	end
	return 0
end

local function getRaceEndTime()
	local result = 45
	pcall(function()
		local raceSetup = workspace:FindFirstChild("RaceSetup")
		if not raceSetup then return end
		local raceTimer = raceSetup:FindFirstChild("Timer")
		if not raceTimer then return end
		result = math.max(0, raceTimer.Value or 45)
	end)
	return result
end

local function minigameLoop()
	minigameThread = task.spawn(function()
		while autoMinigameEnabled do
			local availableTime = getRaceAvailableTime()
			if availableTime <= 0 then
				local raceData = startRace()
				if raceData then
					task.wait(0.5)
					selectBall()
					task.wait(0.5)
					local cheerInterval = getCheerInterval()
					local raceEndTime = getRaceEndTime()
					local raceStartTick = tick()
					while autoMinigameEnabled and (tick() - raceStartTick) < raceEndTime do
						cheerOnce()
						task.wait(cheerInterval)
					end
					task.wait(0.5)
					local earned = endRace()
					if earned > 0 then
						Rayfield:Notify({ Title = "Race Won", Content = "Earned: $" .. earned, Duration = 1.5 })
					end
					while autoMinigameEnabled and getRaceAvailableTime() > 0 do
						task.wait(0.5)
					end
				else
					task.wait(1)
				end
			else
				task.wait(0.5)
			end
		end
	end)
end

