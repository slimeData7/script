local sessionLemonsCollected = 0
local sessionFireTouchFired = 0

local function getFruits(tree)
	local fruits = {}
	pcall(function()
		for _, child in ipairs(tree:GetChildren()) do
			if child.Name == "Fruit" then table.insert(fruits, child) end
		end
	end)
	return fruits
end

local function teleportToTree(tree)
	pcall(function()
		local part = tree.PrimaryPart or tree:FindFirstChildWhichIsA("BasePart")
		if part then
			hrp.CFrame = part.CFrame + Vector3.new(0, 3, 0)
			task.wait(0.05)
		end
	end)
end

local function collectFruit(fruit)
	local clickDetector = fruit:FindFirstChildWhichIsA("ClickDetector", true)
	if clickDetector then
		pcall(function() fireclickdetector(clickDetector) end)
		sessionLemonsCollected = sessionLemonsCollected + 1
		return
	end
	local prompt = fruit:FindFirstChildWhichIsA("ProximityPrompt", true)
	if prompt then
		pcall(function() fireproximityprompt(prompt) end)
		sessionLemonsCollected = sessionLemonsCollected + 1
		return
	end
	local part = fruit:IsA("BasePart") and fruit or fruit:FindFirstChildWhichIsA("BasePart")
	if part then
		pcall(function()
			firetouchinterest(hrp, part, 0)
			firetouchinterest(hrp, part, 1)
		end)
		sessionFireTouchFired = sessionFireTouchFired + 1
		sessionLemonsCollected = sessionLemonsCollected + 1
	end
end

