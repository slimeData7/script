local function handleOffer()
	if offerDebounce or not phoneOfferRemote then return end
	offerDebounce = true
	local raiseTimes = 0
	if offerMode == "Raise x1" then raiseTimes = 1
	elseif offerMode == "Raise x2" then raiseTimes = 2
	elseif offerMode == "Raise x3" then raiseTimes = 3
	end
	for _ = 1, raiseTimes do
		pcall(function() phoneOfferRemote:FireServer("Raise") end)
		task.wait(2)
	end
	pcall(function() phoneOfferRemote:FireServer("Accept") end)
	Rayfield:Notify({
		Title = "Phone Offer",
		Content = "Accepted" .. (raiseTimes > 0 and " after " .. raiseTimes .. " raise(s)" or ""),
		Duration = 2
	})
	task.wait(5)
	offerDebounce = false
end

