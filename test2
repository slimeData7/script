local wakeTracked        = {}
local wakeSelectedStreams = {}

local function getManualStreamNames()
	local names = {}
	if not streams then return names end
	pcall(function()
		for _, entry in streams:GetChildren() do
			if not entry:GetAttribute("Automatic") then table.insert(names, entry.Name) end
		end
	end)
	table.sort(names)
	return names
end

local function shouldWake(name)
	if next(wakeSelectedStreams) == nil then return true end
	return wakeSelectedStreams[name] == true
end

local function startWakeLoop(entry)
	task.spawn(function()
		while true do
			local flag = rayfieldLibrary.Flags.AutoWakeToggle
			if not flag or not flag.CurrentValue then break end
			pcall(function()
				if not entry:GetAttribute("Automatic") and shouldWake(entry.Name) and wakeRemote then
					wakeRemote:InvokeServer(entry.Name)
				end
			end)
			local interval = 1
			pcall(function() interval = entry:GetAttribute("Interval") or 1 end)
			task.wait(interval)
		end
	end)
end

local function startAllWakeLoops()
	if not streams then return end
	wakeTracked = {}
	pcall(function()
		for _, entry in streams:GetChildren() do
			if not wakeTracked[entry.Name] then
				wakeTracked[entry.Name] = true
				startWakeLoop(entry)
			end
		end
		streams.ChildAdded:Connect(function(entry)
			local flag = rayfieldLibrary.Flags.AutoWakeToggle
			if flag and flag.CurrentValue and not wakeTracked[entry.Name] then
				wakeTracked[entry.Name] = true
				startWakeLoop(entry)
			end
		end)
	end)
end

