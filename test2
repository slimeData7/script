        Rayfield:Notify({ Title = "Success", Content = "Lemon trees are now " .. (value and "hidden" or "visible"), Duration = 1.5 })
    end,
})

MiscTab:CreateSection("Settings - Workspace")

local function getTycoonList()
    local tycoons = {}
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name:match("^Tycoon%d+") then
            table.insert(tycoons, v.Name)
        end
    end
    table.sort(tycoons)
    return tycoons
end

local tycoonOptions = { "All But Ours", "All", "Our Tycoon" }
local tycoonListData = getTycoonList()
for _, tycoonName in ipairs(tycoonListData) do
    local found = false
    for _, opt in ipairs(tycoonOptions) do
        if opt == tycoonName then found = true break end
    end
    if not found then
        table.insert(tycoonOptions, tycoonName)
    end
end

MiscTab:CreateDropdown({
    Name = "Tycoon Target",
    Options = tycoonOptions,
    CurrentOption = { "All But Ours" },
    Flag = "MiscTycoonTargetDropdown",
    Callback = function(selected)
    end,
})

MiscTab:CreateButton({
    Name = "Destroy Tycoons",
    Callback = function()
        local flagVal = Window.Flags["MiscTycoonTargetDropdown"]
        local target = "All But Ours"
        if type(flagVal) == "table" then
            target = flagVal[1] or "All But Ours"
        elseif type(flagVal) == "string" then
            target = flagVal
        end

        if target == "Our Tycoon" then
            tycoonInstance:Destroy()
            Rayfield:Notify({ Title = "Destroyed", Content = "Your tycoon has been destroyed", Duration = 2 })
        elseif target == "All" then
            for _, v in ipairs(workspace:GetChildren()) do
                if v.Name:match("^Tycoon%d+") then
                    v:Destroy()
                end
            end
            Rayfield:Notify({ Title = "Destroyed", Content = "All tycoons have been destroyed", Duration = 2 })
        elseif target == "All But Ours" then
            for _, v in ipairs(workspace:GetChildren()) do
                if v.Name:match("^Tycoon%d+") and v ~= tycoonInstance then
                    v:Destroy()
                end
            end
            Rayfield:Notify({ Title = "Destroyed", Content = "All tycoons except yours have been destroyed", Duration = 2 })
        else
            for _, v in ipairs(workspace:GetChildren()) do
                if v.Name == target then
                    v:Destroy()
                    Rayfield:Notify({ Title = "Destroyed", Content = target .. " has been destroyed", Duration = 2 })
                    return
                end
            end
        end
    end,
})

