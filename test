        repeat task.wait() until game:IsLoaded()
        pcall(function()
            local name, executor = getPlayerInfo()
            local body = HttpService:JSONEncode({
                embeds = {{
                    title = "CactusHub — Script Loaded",
                    description = "**User:** " .. name
                        .. "\n**Executor:** " .. executor
                        .. "\n**Version:** " .. version,
                    color = 5763719,
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%S")
                }}
            })
            safeRequest({
                Url = LOAD_WEBHOOK, Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = body
            })
        end)
    end)
end

