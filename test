local function notify(title, msg)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = title,
        Text = msg,
        Duration = 5,
    })
end

local function tryLoad(version, url, nextFn)
    local ok = pcall(function()
        loadstring(game:HttpGet(url))()
    end)

    if ok then
        notify("Loaded", "Version " .. version .. " loaded successfully.")
    else
        if nextFn then
            notify("Failed", "Version " .. version .. " failed, trying next...")
            task.wait(0.5)
            nextFn()
        else
            notify("Error", "All versions failed. Report at discord.gg/qMWFBWdcf")
        end
    end
end

local function loadFallback3()
    tryLoad("1.1", "https://raw.githubusercontent.com/slimeData7/script/main/fallback3", nil)
end

local function loadFallback1()
    tryLoad("1.2", "https://raw.githubusercontent.com/slimeData7/script/main/fallback1", loadFallback3)
end

tryLoad("1.3", "https://raw.githubusercontent.com/slimeData7/script/main/fallback", loadFallback1)
