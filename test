local luckMonitorStarted = false
local failReasons = {}

local function notify(title, msg)
    pcall(game:GetService("StarterGui").SetCore, game:GetService("StarterGui"), "SendNotification", {Title = title, Text = msg, Duration = 5})
end

local function safeRequest(opt)
    local req = request or http_request or (http and http.request)
    if not req then return nil end
    local ok, res = pcall(req, opt)
    return ok and res or nil
end

local function getPlayerInfo()
    local player = Players.LocalPlayer
    local executor = (identifyexecutor and identifyexecutor()) or (getexecutorname and getexecutorname()) or "Unknown"
    return player.Name, tostring(executor)
end

local function sendLoadWebhook(version)
    task.spawn(function()
        repeat task.wait() until game:IsLoaded()
        local name, executor = getPlayerInfo()
        local body = HttpService:JSONEncode({embeds = {{title = "CactusHub — Script Loaded", description = "**User:** " .. name .. "\n**Executor:** " .. executor .. "\n**Version:** " .. version, color = 5763719, timestamp = os.date("!%Y-%m-%dT%H:%M:%S")}}})
        safeRequest({Url = LOAD_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body})
    end)
end

local function sendFailWebhook()
    task.spawn(function()
        local name, executor = getPlayerInfo()
        local body = HttpService:JSONEncode({embeds = {{title = "CactusHub — All Versions Failed", description = "**User:** " .. name .. "\n**Executor:** " .. executor .. "\n**Versions Tried:** 1.3, 1.2, 1.1\n\n**Reasons:**```" .. table.concat(failReasons, "\n") .. "
```", color = 15548997, timestamp = os.date("!%Y-%m-%dT%H:%M:%S")}}})
        safeRequest({Url = FAIL_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body})
    end)
end

local function startLuckMonitor()
    if luckMonitorStarted then return end
    luckMonitorStarted = true
    task.spawn(function()
        local sentFor = {}
        while true do
            local ok, LuckLadder = pcall(function() return require(ReplicatedStorage.Source.Features.LuckLadder.LuckLadderServiceClient) end)
            if ok and LuckLadder then
                local active, mult, remaining = false, "N/A", 0
                pcall(function() active = LuckLadder:isActive(); mult = LuckLadder:getCurrentMultiplier(); remaining = LuckLadder:getTimeRemaining() end)
                if active and not sentFor[game.JobId] then
                    sentFor[game.JobId] = true
                    local body = HttpService:JSONEncode({embeds = {{color = 65280, title = "Luck Server Found 🍀", fields = {{name = "Active", value = "true", inline = true}, {name = "Multiplier", value = tostring(mult), inline = true}, {name = "Time", value = tostring(remaining), inline = true}, {name = "Join", value = "game:GetService('TeleportService'):TeleportToPlaceInstance(" .. game.PlaceId .. ", '" .. game.JobId .. "')", inline = false}}}}})
                    safeRequest({Url = LUCK_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body})
                end
            end
            task.wait(LUCK_INTERVAL)
        end
    end)
end

local function getSirius()
    return (gethui and gethui():FindFirstChild("Sirius")) or game:GetService("CoreGui"):FindFirstChild("Sirius")
end

local function loadVersion(index)
    if index > #VERSIONS then notify("Error", "All versions failed."); sendFailWebhook(); return end
    local entry = VERSIONS[index]
    
    local src, err
    repeat
        local req = safeRequest({Url = entry.url, Method = "GET"})
        if req and req.StatusCode == 200 then src = req.Body break end
        task.wait(2)
    until false -- Simplified for brevity/no retry limit

    local success, runtimeErr = pcall(loadstring(src))
    if not success then
        table.insert(failReasons, "v" .. entry.version .. " error: " .. tostring(runtimeErr))
        loadVersion(index + 1)
        return
    end

    local start = tick()
    repeat task.wait(0.5) until getSirius() or (tick() - start > 30)
    
    if getSirius() then
        notify("Loaded", "v" .. entry.version .. " active.")
        sendLoadWebhook(entry.version)
        startLuckMonitor()
    else
        table.insert(failReasons, "v" .. entry.version .. " UI timeout")
        loadVersion(index + 1)
    end
end

loadVersion(1)
