-- ─── Utilities ───────────────────────────────────────────────────────────────

local function notify(title, msg)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title, Text = msg, Duration = 5
        })
    end)
end

local function safeRequest(opt)
    local req = request or http_request or (http and http.request)
    if not req then return nil end
    local ok, res = pcall(req, opt)
    return ok and res or nil
end

local function getPlayerInfo()
    local player = Players.LocalPlayer
    local executor = (identifyexecutor and identifyexecutor())
        or (getexecutorname and getexecutorname())
        or "Unknown"
    return player.Name, tostring(executor)
end

-- ─── Fetch: retries forever, handles rate limits ──────────────────────────────

local function fetchWithRetry(url)
    local attempt = 0
    while true do
        attempt += 1
        local res = safeRequest({ Url = url, Method = "GET" })
        if res then
            if res.StatusCode == 200 and res.Body and res.Body ~= "" then
                return res.Body
            elseif res.StatusCode == 429 then
                local wait = tonumber(res.Headers and res.Headers["Retry-After"]) or 10
                warn("CactusHub | Rate limited, waiting " .. wait .. "s")
                task.wait(wait)
            elseif res.StatusCode >= 500 then
                warn("CactusHub | Server error " .. res.StatusCode .. ", retrying in 5s (attempt " .. attempt .. ")")
                task.wait(5)
            else
                warn("CactusHub | Status " .. tostring(res.StatusCode) .. ", retrying in 3s (attempt " .. attempt .. ")")
                task.wait(3)
            end
        else
            warn("CactusHub | Request returned nil, retrying in 3s (attempt " .. attempt .. ")")
            task.wait(3)
        end
    end
end

-- ─── Webhooks ─────────────────────────────────────────────────────────────────

