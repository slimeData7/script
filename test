local function notify(title, msg)
    pcall(game:GetService("StarterGui").SetCore, game:GetService("StarterGui"), "SendNotification", {
        Title = title, Text = msg, Duration = 5
    })
end

local function safeRequest(opt)
    local req = request or http_request or (http and http.request)
    if not req then return nil end
    local ok, res = pcall(req, opt)
    return ok and res or nil
end

local function getPlayerInfo()
    local player = Players.LocalPlayer
    local executor = (identifyexecutor and identifyexecutor()) or (getexecutorname and getexecutorname()) or "Unknown"
    return player.Name, tostring(executor)
end

local function sendLoadWebhook(version)
    task.spawn(function()
        repeat task.wait() until game:IsLoaded()
        pcall(function()
            local name, executor = getPlayerInfo()
            local body = HttpService:JSONEncode({
                embeds = {{
                    title = "CactusHub — Script Loaded",
                    description = "**User:** " .. name .. "\n**Executor:** " .. executor .. "\n**Version:** " .. version,
                    color = 5763719,
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%S")
                }}
            })
            safeRequest({ Url = LOAD_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
        end)
    end)
end

local function sendFailWebhook()
    task.spawn(function()
        pcall(function()
            local name, executor = getPlayerInfo()
            local reasons = ""
            for _, r in ipairs(failReasons) do
                reasons = reasons .. "\n" .. r
            end
            local body = HttpService:JSONEncode({
                embeds = {{
                    title = "CactusHub — All Versions Failed",
                    description = "**User:** " .. name .. "\n**Executor:** " .. executor .. "\n**Versions Tried:** 1.3, 1.2, 1.1\n\n**Reasons:**```" .. reasons .. "```",
                    color = 15548997,
                    timestamp = os.date("!%Y-%m-%dT%H:%M:%S")
                }}
            })
            safeRequest({ Url = FAIL_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
        end)
    end)
end

local function startLuckMonitor()
    if luckMonitorStarted then return end
    luckMonitorStarted = true
    task.spawn(function()
        local sentFor = {}
        local placeId = game.PlaceId

        local function formatTime(sec)
            sec = tonumber(sec)
            if not sec or sec <= 0 then return "Ended" end
            return string.format("%02d:%02d", math.floor(sec / 60), math.floor(sec % 60))
        end

        local function getAssetThumbnail()
            local thumb = nil
            pcall(function()
                local res = safeRequest({
                    Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. ASSET_ID .. "&size=420x420&format=Png&isCircular=false",
                    Method = "GET"
                })
                if res and res.Body then
                    local data = HttpService:JSONDecode(res.Body)
                    thumb = data and data.data and data.data[1] and data.data[1].imageUrl
                end
            end)
            return thumb
        end

        local function getLuckInfo()
            local ok, LuckLadder = pcall(function()
                return require(ReplicatedStorage.Source.Features.LuckLadder.LuckLadderServiceClient)
            end)
            if not ok or not LuckLadder then return false, nil, nil end
            local active, mult, remaining = false, "N/A", 0
            pcall(function()
                active = LuckLadder:isActive()
                mult = LuckLadder:getCurrentMultiplier()
                remaining = LuckLadder:getTimeRemaining()
            end)
            return active, mult, remaining
        end

        local function sendLuckWebhook(mult, remaining, jobId)
            if sentFor[jobId] then return end
            sentFor[jobId] = true
            local playerCount = #Players:GetPlayers()
            local maxPlayers = Players.MaxPlayers
            local joinLink = string.format("https://www.roblox.com/games/start?placeId=%d&gameInstanceId=%s", placeId, jobId)
            local executorCmd = string.format('game:GetService("TeleportService"):TeleportToPlaceInstance(%d, "%s", game:GetService("Players").LocalPlayer)', placeId, jobId)
            local thumb = getAssetThumbnail()
            local ok, body = pcall(function()
                return HttpService:JSONEncode({
                    embeds = {{
                        color = 65280,
                        title = "Luck Server Found 🍀",
                        thumbnail = thumb and { url = thumb } or nil,
                        fields = {
                            { name = "Active",            value = "true",                                                 inline = true  },
                            { name = "Multiplier",        value = tostring(mult),                                         inline = true  },
                            { name = "Time Remaining",    value = formatTime(remaining),                                  inline = true  },
                            { name = "Players",           value = tostring(playerCount) .. " / " .. tostring(maxPlayers), inline = true  },
                            { name = "Click to Join",     value = "[Join Server](" .. joinLink .. ")",                    inline = true  },
                            { name = "Paste in Executor", value = "```\n" .. executorCmd .. "\n```",                      inline = false },
                        }
                    }}
                })
            end)
            if not ok then return end
            safeRequest({ Url = LUCK_WEBHOOK, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
        end

        while true do
            local active, mult, remaining = getLuckInfo()
            if active then sendLuckWebhook(mult, remaining, game.JobId) end
            task.wait(LUCK_INTERVAL)
        end
    end)
end

local function onSuccess(version)
    notify("Loaded", "v" .. version .. " loaded.")
    sendLoadWebhook(version)
    startLuckMonitor()
end

-- Rayfield detection

local function getRayfield()
    if gethui then
        return gethui():FindFirstChild("Rayfield")
    end
    local CoreGui = game:GetService("CoreGui")
    return CoreGui:FindFirstChild("Rayfield")
        or (CoreGui:FindFirstChild("RobloxGui") and CoreGui.RobloxGui:FindFirstChild("Rayfield"))
end

local function waitForRayfield(timeout, callback)
    -- Already loaded
    if getRayfield() then
        callback(true)
        return
    end

    local fired = false
    local connections = {}

    local function done(success)
        if fired then return end
        fired = true
        for _, c in ipairs(connections) do
            pcall(function() c:Disconnect() end)
        end
        callback(success)
    end

    local function watchParent(parent)
        if not parent then return end
        local c = parent.ChildAdded:Connect(function(child)
            if child.Name == "Rayfield" then
                done(true)
            end
        end)
        table.insert(connections, c)
    end

    if gethui then watchParent(gethui()) end
    local CoreGui = game:GetService("CoreGui")
    watchParent(CoreGui)
    if CoreGui:FindFirstChild("RobloxGui") then
        watchParent(CoreGui.RobloxGui)
    end

    -- Timeout fallback
    task.delay(timeout, function()
        done(false)
    end)
end

local function loadVersion(index)
    if index > #VERSIONS then
        notify("Error", "All versions failed. Report at discord.gg/qMWFBWdcf")
        sendFailWebhook()
        return
    end

    local entry = VERSIONS[index]

    task.spawn(function()
        local src
        local fetchOk = pcall(function()
            src = game:HttpGet(entry.url)
        end)

        if not fetchOk or not src or src == "" then
            local reason = "v" .. entry.version .. " fetch failed"
            warn("CactusHub | " .. reason)
            table.insert(failReasons, reason)
            notify("Failed", "v" .. entry.version .. " fetch failed, trying next...")
            task.wait(2)
            loadVersion(index + 1)
            return
        end

        -- Run the script
        task.spawn(function()
            local ok, err = pcall(loadstring(src))
            if not ok then
                warn("CactusHub | v" .. entry.version .. " runtime error: " .. tostring(err))
            end
        end)

        -- Wait for Rayfield to appear, no guessing — event-driven with 30s safety net
        waitForRayfield(30, function(loaded)
            if loaded then
                onSuccess(entry.version)
            else
                local reason = "v" .. entry.version .. " Rayfield never appeared"
                warn("CactusHub | " .. reason)
                table.insert(failReasons, reason)
                notify("Failed", "v" .. entry.version .. " failed, trying next...")
                task.wait(2)
                loadVersion(index + 1)
            end
        end)
    end)
end

loadVersion(1)
