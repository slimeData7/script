local FAIL_WEBHOOK = "https://discord.com/api/webhooks/1484979057342025849/Lmt1_pr3ZhczCAOWJLFh9id9Oa1BJjmVXOf_HlDJWND-aoXHAZu4VQF9z0pOgozJLJCe"
local LUCK_WEBHOOK = "https://discord.com/api/webhooks/1511601904889892897/6RXabOVta5tJivjtFy9bE2w311srNmcp-k5DT0XsNXR71Z9JygY2FGiEb_O1NirFh9V7"
