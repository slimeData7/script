local DROPDOWN_SAVE_PATH = "PrivateScript/dropdowns.json"

local function saveDropdowns()
    pcall(function()
        local data = {
            BlackMarket = CONFIG.BlackMarket.Selected,
            BlackMarketSelectAll = CONFIG.BlackMarket.SelectAll,
            CollectFilter = CONFIG.AutoCollect.Filter,
            Shops = {},
        }
        for shopName, shopData in pairs(CONFIG.Shops) do
            data.Shops[shopName] = {
                Selected = shopData.Selected,
                SelectAll = shopData.SelectAll,
            }
        end
        writefile(DROPDOWN_SAVE_PATH, HttpService:JSONEncode(data))
    end)
end

local function loadDropdowns()
    pcall(function()
        if not isfile(DROPDOWN_SAVE_PATH) then return end
        local raw = readfile(DROPDOWN_SAVE_PATH)
        local data = HttpService:JSONDecode(raw)
        if data.BlackMarket then CONFIG.BlackMarket.Selected = data.BlackMarket end
        if data.BlackMarketSelectAll ~= nil then CONFIG.BlackMarket.SelectAll = data.BlackMarketSelectAll end
        if data.CollectFilter then CONFIG.AutoCollect.Filter = data.CollectFilter end
        if data.Shops then
            for shopName, shopData in pairs(data.Shops) do
                if CONFIG.Shops[shopName] then
                    CONFIG.Shops[shopName].Selected = shopData.Selected or {}
                    CONFIG.Shops[shopName].SelectAll = shopData.SelectAll or false
                end
            end
        end
    end)
end

