end)

-- Auto Raid loop
task.spawn(function()
    local lastRaidPoint = nil
    while true do
        task.wait(3)
        if not CONFIG.AutoRaid.Enabled then continue end
        local raidPoint = findRaidCapturePoint()
        if raidPoint and raidPoint ~= lastRaidPoint then
            lastRaidPoint = raidPoint
            notifyUser("Auto Raid", "Raid event detected! Teleporting...")
            task.wait(0.5)
            teleportToInstance(raidPoint)
            task.wait(1)
            local attempts = 0
            while CONFIG.AutoRaid.Enabled and raidPoint and raidPoint.Parent and attempts < 30 do
                local owner = raidPoint:GetAttribute("Owner")
                if owner == player.Name then break end
                fireConquer(raidPoint)
                task.wait(2)
                attempts = attempts + 1
            end
        elseif not raidPoint then
            lastRaidPoint = nil
        end
    end
end)

-- Auto Sell loop
task.spawn(function()
    while true do
        task.wait(5)
        if not CONFIG.AutoSell.Enabled then continue end
        local intervalSecs = SELL_INTERVALS[CONFIG.AutoSell.Interval] or 0
        if intervalSecs == 0 then continue end
        if tick() - lastAutoSell >= intervalSecs then
            lastAutoSell = tick()
            fireSell(CONFIG.AutoSell.Mode)
            notifyUser("Auto Sell", "Auto sold items (" .. CONFIG.AutoSell.Mode .. ")")
        end
    end
end)

-- Auto Buy Black Market loop
task.spawn(function()
    while true do
        task.wait(CONFIG.BMCheckDelay)
        if not CONFIG.BlackMarket.Enabled then continue end
        if CONFIG.BlackMarket.Selected == "None" then continue end
        if not blackMarketBridge then continue end
        if not isBlackMarketOpen() then continue end

        for _, item in ipairs(ShopsConfig.BlackMarket or {}) do
            if item and item.name == CONFIG.BlackMarket.Selected then
                if not isInStock("BlackMarket", item.name) then break end
                if not canAfford(item.Price or 0) then break end
                pcall(function()
                    blackMarketBridge:Fire({ shop = "BlackMarket", item = item.name })
                end)
                break
            end
        end
    end
end)

-- Auto Buy Shops loop
task.spawn(function()
    while true do
        task.wait(CONFIG.Delay)
        if not shopBridge then continue end

        for shopName, config in pairs(CONFIG.Shops) do
            if not config.Enabled then continue end
            if config.Selected == "None" then continue end

            local items = ShopsConfig[shopName]
            if not items or type(items) ~= "table" then continue end

            local itemConfig = nil
            for _, item in ipairs(items) do
                if item and item.name == config.Selected then
                    itemConfig = item
                    break
                end
            end
            if not itemConfig then continue end

            if not isInStock(shopName, config.Selected) then continue end
            if not canAfford(itemConfig.Price or 0) then continue end

            pcall(function()
                shopBridge:Fire({ shop = shopName, item = config.Selected })
            end)
        end
    end
end)

