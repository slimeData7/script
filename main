local function formatPlaytime(seconds)
	seconds = math.floor(tonumber(seconds) or 0)
	local h = math.floor(seconds / 3600)
	local m = math.floor((seconds % 3600) / 60)
	if h > 0 then
		return string.format("%dh %dm", h, m)
	end
	return string.format("%dm", m)
end

local function getBlockCount(blockName)
	local blocks = PlayerStateClient.Get("Blocks")
	if not blocks then return 0 end
	local total = 0
	for _, entry in pairs(blocks) do
		if entry.Name == blockName then
			total = total + (entry.Quantity or 1)
		end
	end
	return total
end

local function formatPrice(n)
	n = tonumber(n) or 0
	local sign = n < 0 and "-" or ""
	n = math.abs(n)

	if n >= 1e12 then
		return sign .. string.format("%.2fT", n / 1e12)
	elseif n >= 1e9 then
		return sign .. string.format("%.2fB", n / 1e9)
	elseif n >= 1e6 then
		return sign .. string.format("%.2fM", n / 1e6)
	elseif n >= 1e3 then
		return sign .. string.format("%.2fK", n / 1e3)
	end

	return sign .. string.format("%d", n)
end

local ICON_CACHE = {}

local function resolveCarIcon(blockName)
	local drops = ItemConfig.Drops[blockName]
	if not drops then return nil end

	local rarest = nil
	local lowestWeight = math.huge
	for _, drop in ipairs(drops) do
		if drop.Weight < lowestWeight then
			lowestWeight = drop.Weight
			rarest = drop
		end
	end
	if not rarest then return nil end

	local carData = CarConfig.GetCarData(rarest.Name)
	if not carData or not carData.Icon then return nil end

	local assetNumber = string.match(tostring(carData.Icon), "rbxassetid://(%d+)")
	if not assetNumber then return nil end

	if ICON_CACHE[assetNumber] then
		return ICON_CACHE[assetNumber]
	end

	local thumbnailUrl = nil
	for attempt = 1, 10 do
		pcall(function()
			local r = request({
				Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetNumber .. "&size=420x420&format=Png&isCircular=false",
				Method = "GET"
			})
			if r and r.Success then
				local decoded = Http
