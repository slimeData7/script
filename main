for _, x in pairs(getconnections(game.Players.LocalPlayer.Idled)) do x:Disable() end

local bb = game:GetService('VirtualUser')
game:GetService("Players").LocalPlayer.Idled:connect(function()
    bb:CaptureController()
    bb:ClickButton2(Vector2.new())
end)

local _env = (getgenv and getgenv()) or _G
if _env.__IdiotHubExecuted then return end
_env.__IdiotHubExecuted = true

getgenv().CONFIG = getgenv().CONFIG or {}
getgenv().CONFIG.AUTO_BUY_PETS = {
    ENABLED = true,
    NAMES = {
        "Raccoon",
        "Monkey",
        "Unicorn",
        "Golden Dragonfly",
        "Black Dragon",
        "Ice Serpent",
    },
    RARITIES = {},
    MINIMUM_LUCK_SENT = 0,
    SEND_SKIPPED = true,
    CONFIRM_TIMEOUT = 2,
    BUY_RETRIES = 2,
    ICON_RETRIES = 25,
    WEBHOOK_URL = "https://discord.com/api/webhooks/1505625971519389930/M486V4Vxl8aRftnn9E5coxtrREdECj3k9oM6xeP3yFMR8fw97e-8SSc8WUhyJrxUjkNC",
    DISCORD_ID = "1135837863603351573",
    NOTE = "",
}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local CFG = getgenv().CONFIG

local Networking = require(ReplicatedStorage.SharedModules.Networking)
local PetData = require(ReplicatedStorage.SharedData.PetData)
local replica = require(ReplicatedStorage.ClientModules.PlayerStateClient):WaitForLocalReplica(30)

local function resolveRemote(path)
    local current = Networking
    for part in path:gmatch("[^.]+") do
        current = current[part]
        if not current then return nil end
    end
    return current
end

local WildPetTame = resolveRemote("Pets.WildPetTame")
local WildPetCollected = resolveRemote("Pets.WildPetCollected")

local map = workspace:WaitForChild("Map", 30)
local wildPetRef = map and map:WaitForChild("WildPetRef", 30)

local iconCache = {}

local function getBalance()
    return replica and replica.Data and replica.Data.Sheckles or 0
end

local function formatNumber(n)
    n = tonumber(n) or 0
    if n >= 1e9 then return string.format("%.1fB", n / 1e9)
    elseif n >= 1e6 then return string.format("%.1fM", n / 1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n / 1e3)
    else return tostring(math.round(n)) end
end

local function calcOneIn(spawnChance)
    if not spawnChance or spawnChance <= 0 then return 0 end
    return math.round(1 / (spawnChance / 100))
end

local function parseWildPetName(name)
    local guid = name:match("^WildPet_(.+)$")
    if not guid or guid == "" then return nil end
    return guid
end

local function redactGuid(guid)
    if not guid or guid == "" then return "N/A" end
    return "||...." .. guid:sub(-4) .. "||"
end

local function getIconUrl(iconAssetId)
    if not iconAssetId or iconAssetId == "N/A" or iconAssetId == "" then return nil end
    local assetNumber = tostring(iconAssetId):match("rbxassetid://(%d+)")
    if not assetNumber then return nil end
    if iconCache[assetNumber] then return iconCache[assetNumber] end

    local maxRetries = CFG.AUTO_BUY_PETS.ICON_RETRIES or 25
    for attempt = 1, maxRetries do
        local url
        pcall(function()
            local r = request({
                Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetNumber .. "&size=420x420&format=Png&isCircular=false",
                Method = "GET"
            })
            if r and r.Success then
                local ok, decoded = pcall(HttpService.JSONDecode, HttpService, r.Body)
                if ok and decoded and decoded.data and decoded.data[1] then
                    local d = decoded.data[1]
                    if d.state == "Completed" and d.imageUrl and d.imageUrl ~= "" then
                        url = d.imageUrl
                    end
                end
            end
        end)
        if url then
            iconCache[assetNumber] = url
            return url
        end
        task.wait(math.min(0.2 * attempt, 2))
    end
    return nil
end

local webhookQueue = {}
local webhookRunning = false

local function processWebhookQueue()
    if webhookRunning then return end
    webhookRunning = true
    task.spawn(function()
        while #webhookQueue > 0 do
            local payload = table.remove(webhookQueue, 1)
            local attempt = 0
            while attempt < 5 do
                attempt += 1
                local resp
                pcall(function()
                    resp = request({
                        Url = CFG.AUTO_BUY_PETS.WEBHOOK_URL,
                        Method = "POST",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body = payload
                    })
                end)
                if resp and resp.StatusCode == 429 then
                    local retryAfter = 1
                    pcall(function()
                        local ok, decoded = pcall(HttpService.JSONDecode, HttpService, resp.Body)
                        if ok and decoded and decoded.retry_after then
                            retryAfter = tonumber(decoded.retry_after) or 1
                        end
                    end)
                    task.wait(retryAfter)
                else
                    break
                end
            end
            task.wait(0.4)
        end
        webhookRunning = false
    end)
end

local function sendPetWebhook(data, price, oneIn, guid, state, spawnedAt, sniped)
    local cfg = CFG.AUTO_BUY_PETS
    if oneIn < cfg.MINIMUM_LUCK_SENT then return end
    if not cfg.WEBHOOK_URL or cfg.WEBHOOK_URL == "" then return end
    local article = data.DisplayName:match("^[AEIOUaeiou]") and "an" or "a"
    local statusNote = sniped
        and "Pet was successfully sniped gg nigga!"
        or "Pet was spawned but has not been sniped cuz its prob ahh"
    local fields = {
        { name = "Price", value = formatNumber(price), inline = true },
        { name = "Rarity", value = tostring(data.Rarity), inline = true },
        { name = "State", value = tostring(state or "N/A"), inline = true },
        { name = "Spawned At", value = spawnedAt and ("<t:" .. math.floor(spawnedAt) .. ":R>") or "N/A", inline = true },
        { name = "Status", value = statusNote, inline = false },
        { name = "server-job-id", value = tostring(game.JobId), inline = false },
        { name = "pet-unique-guid", value = redactGuid(guid), inline = false },
    }
    if cfg.NOTE and cfg.NOTE ~= "" then
        table.insert(fields, { name = "Note", value = cfg.NOTE, inline = false })
    end
    local embed = {
        title = "Some new shi spawned " .. article .. " 1 in " .. formatNumber(oneIn) .. " " .. data.DisplayName .. "!",
        color = sniped and 0x57F287 or 0xED4245,
        fields = fields,
        footer = { text = "discord.gg/idiothub" }
    }
    local thumb = getIconUrl(data.Image)
    if thumb then embed.thumbnail = { url = thumb } end
    local mention = (sniped and cfg.DISCORD_ID and cfg.DISCORD_ID ~= "") and ("<@" .. cfg.DISCORD_ID .. ">") or nil
    local payload
    if not pcall(function()
        payload = HttpService:JSONEncode({ content = mention, embeds = { embed } })
    end) then return end
    table.insert(webhookQueue, payload)
    processWebhookQueue()
end

local skippedSent = {}
local buying = {}
local confirmedGuids = {}
local pendingConfirm = {}

local function shouldBuyPet(data)
    local cfg = CFG.AUTO_BUY_PETS
    for _, name in ipairs(cfg.NAMES) do
        if data.DisplayName == name then return true end
    end
    for _, rarity in ipairs(cfg.RARITIES) do
        if data.Rarity == rarity then return true end
    end
    return false
end

local function getPetInfo(refPart)
    local petName = refPart:GetAttribute("PetName")
    if not petName then return nil end
    local data = PetData[petName]
    if not data then return nil end
    return petName, data
end

local function waitForAttributes(refPart, timeout)
    if refPart:GetAttribute("PetName") then return true end
    local deadline = os.clock() + (timeout or 1)
    while os.clock() < deadline do
        if not refPart.Parent then return false end
        if refPart:GetAttribute("PetName") then return true end
        task.wait()
    end
    return refPart:GetAttribute("PetName") ~= nil
end

local function executeBuy(refPart, petName, data, guid)
    local cfg = CFG.AUTO_BUY_PETS
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    pendingConfirm[petName] = {
        State = refPart:GetAttribute("State"),
        SpawnedAt = refPart:GetAttribute("SpawnedAt"),
        guid = guid,
    }

    hrp.CFrame = CFrame.new(refPart.Position + Vector3.new(0, 3, 0))

    local retries = cfg.BUY_RETRIES or 0
    for _ = 0, retries do
        if guid and confirmedGuids[guid] then break end
        if not refPart.Parent then break end
        local owner = refPart:GetAttribute("OwnerName")
        if owner and #owner > 1 then break end
        WildPetTame:Fire(refPart)
        local deadline = os.clock() + (cfg.CONFIRM_TIMEOUT or 2)
        while os.clock() < deadline do
            if guid and confirmedGuids[guid] then break end
            if not refPart.Parent then break end
            task.wait(0.1)
        end
        if guid and confirmedGuids[guid] then break end
    end

    if not (guid and confirmedGuids[guid]) then
        local meta = pendingConfirm[petName]
        pendingConfirm[petName] = nil
        if meta then
            task.spawn(sendPetWebhook, data, refPart:GetAttribute("Price") or data.BasePrice or 0,
                calcOneIn(data.SpawnChance), guid, meta.State, meta.SpawnedAt, false)
        end
    end
end

local function evaluatePet(refPart)
    local cfg = CFG.AUTO_BUY_PETS
    if not cfg.ENABLED then return nil end
    if not refPart.Parent then return nil end

    local owner = refPart:GetAttribute("OwnerName")
    if owner and #owner > 1 then return nil end

    local guid = parseWildPetName(refPart.Name)
    if guid and (buying[guid] or confirmedGuids[guid]) then return nil end

    local petName, data = getPetInfo(refPart)
    if not data then return nil end

    if not shouldBuyPet(data) then
        if cfg.SEND_SKIPPED and guid and not skippedSent[guid] then
            skippedSent[guid] = true
            task.spawn(sendPetWebhook, data, data.BasePrice or 0,
                calcOneIn(data.SpawnChance), guid,
                refPart:GetAttribute("State"), refPart:GetAttribute("SpawnedAt"), false)
        end
        return nil
    end

    local price = refPart:GetAttribute("Price") or data.BasePrice
    if not price or getBalance() < price then return nil end

    return {
        refPart = refPart,
        petName = petName,
        data = data,
        guid = guid,
        oneIn = calcOneIn(data.SpawnChance),
        price = price,
    }
end

local function processCandidate(c)
    if c.guid then buying[c.guid] = true end
    executeBuy(c.refPart, c.petName, c.data, c.guid)
    if c.guid then buying[c.guid] = nil end
end

local function handleSpawn(refPart)
    task.spawn(function()
        if not waitForAttributes(refPart, 1) then return end
        local c = evaluatePet(refPart)
        if c then processCandidate(c) end
    end)
end

WildPetCollected.OnClientEvent:Connect(function(...)
    local petName = select(2, ...)
    if not petName then return end
    local data = PetData[petName]
    if not data then return end
    local meta = pendingConfirm[petName]
    local guid = meta and meta.guid
    if guid then confirmedGuids[guid] = true end
    pendingConfirm[petName] = nil
    task.spawn(sendPetWebhook, data, data.BasePrice or 0,
        calcOneIn(data.SpawnChance), guid, meta and meta.State, meta and meta.SpawnedAt, true)
end)

if wildPetRef then
    wildPetRef.ChildAdded:Connect(handleSpawn)

    local candidates = {}
    for _, refPart in ipairs(wildPetRef:GetChildren()) do
        if waitForAttributes(refPart, 0.25) then
            local c = evaluatePet(refPart)
            if c then table.insert(candidates, c) end
        end
    end
    table.sort(candidates, function(a, b) return a.oneIn > b.oneIn end)
    for _, c in ipairs(candidates) do
        processCandidate(c)
    end
end
