local webhookRarities = { Godly = true, Celestial = true }
local giftCooldowns = {}
local lastCashSnapshot = { cash = 0, time = tick() }

local function getCashPerHour()
	local now = tick()
	local timeDiff = now - lastCashSnapshot.time
	if timeDiff < 60 then return 0 end
	local cash = PlayerStateClient.Get("Cash") or 0
	local cashDiff = cash - lastCashSnapshot.cash
	lastCashSnapshot = { cash = cash, time = now }
	return (cashDiff / timeDiff) * 3600
end

task.spawn(function()
	while true do
		task.wait(60)
		getCashPerHour()
	end
end)

local Settings = {
	AutoCollectCash = false,
	AutoBuyBlocks = false,
	AutoUpgradeCars = false,
	AutoPlaceCars = false,
	AutoBuySlots = false,
	AutoGift = false,
	AutoOpenLuckyBlock = false,
	AutoSellCars = false,
	AutoBuyRainbowCelestial = false,
	AutoBuyInfernalCelestial = false,
	AutoBuyRainbowSecret = false,
	OptimizeGpu = false,
	DestroyOtherPlots = false,
	GiftTarget = "",
	LuckyBlockTarget = "Godly Lucky Block",
	CarsToSell = {},
	TargetRarities = { Godly = true },
}

local function formatPlaytime(seconds)
	seconds = math.floor(tonumber(seconds) or 0)
	local h = math.floor(seconds / 3600)
	local m = math.floor((seconds % 3600) / 60)
	if h > 0 then return string.format("%dh %dm", h, m) end
	return string.format("%dm", m)
end

local function getBlockCount(blockName, justObtainedUuid)
	local blocks = PlayerStateClient.Get("Blocks")
	if not blocks then return justObtainedUuid and 1 or 0 end
	local total = 0
	for uuid, entry in pairs(blocks) do
		if entry.Name == blockName then
			total += (entry.Quantity or 1)
		end
	end
	if justObtainedUuid and not blocks[justObtainedUuid] then
		total += 1
	end
	return total
end

local function formatPrice(n)
	n = tonumber(n) or 0
	local sign = n < 0 and "-" or ""
	n = math.abs(n)
	if n >= 1e18 then return sign .. string.format("%.2fQi", n / 1e18)
	elseif n >= 1e15 then return sign .. string.format("%.2fQa", n / 1e15)
	elseif n >= 1e12 then return sign .. string.format("%.2fT", n / 1e12)
	elseif n >= 1e9 then return sign .. string.format("%.2fB", n / 1e9)
	elseif n >= 1e6 then return sign .. string.format("%.2fM", n / 1e6)
	elseif n >= 1e3 then return sign .. string.format("%.2fK", n / 1e3)
	end
	return sign .. tostring(math.floor(n))
end

local function getFilledSlotCount()
	local plotSlots = PlayerStateClient.GetPath("Plot.Slots")
	if not plotSlots then return 0 end
	local count = 0
	for _, slotData in pairs(plotSlots) do
		if type(slotData) == "table" and slotData.Occupied then
			count += 1
		end
	end
	return count
end

local ICON_CACHE = {}

local function resolveCarIcon(blockName)
	local drops = ItemConfig.Drops[blockName]
	if not drops then return nil end
	local rarest, lowestWeight = nil, math.huge
	for _, drop in ipairs(drops) do
		if drop.Weight < lowestWeight then
			lowestWeight = drop.Weight
			rarest = drop
		end
	end
	if not rarest then return nil end
	local carData = CarConfig.GetCarData(rarest.Name)
	if not carData or not carData.Icon then return nil end
	local assetNumber = string.match(tostring(carData.Icon), "rbxassetid://(%d+)")
	if not assetNumber then return nil end
	if ICON_CACHE[assetNumber] then return ICON_CACHE[assetNumber] end
	local thumbnailUrl = nil
	for attempt = 1, 10 do
		pcall(function()
			local r = request({
				Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetNumber .. "&size=420x420&format=Png&isCircular=false",
				Method = "GET"
			})
			if r and r.Success then
				local decoded = HttpService:JSONDecode(r.Body)
				if decoded and decoded.data and decoded.data[1] and decoded.data[1].imageUrl ~= "" then
					thumbnailUrl = decoded.data[1].imageUrl
				end
			end
		end)
		if thumbnailUrl then break end
		if attempt < 10 then task.wait(0.5) end
	end
	if thumbnailUrl then ICON_CACHE[assetNumber] = thumbnailUrl end
	return thumbnailUrl
end

local function sendWebhook(blockName, mutation, rarity, price, uuid)
	task.spawn(function()
		local thumbnailUrl = resolveCarIcon(blockName)
		local cash = PlayerStateClient.Get("Cash") or 0
		local playtime = PlayerStateClient.Get("TotalPlayTime") or 0
		local pickaxe = PlayerStateClient.Get("EquippedPickaxe") or "Unknown"
		local blockCount = getBlockCount(blockName, uuid)
		local currentEvent = PlayerStateClient.Get("CurrentEvent") or "None"
		local cashPerHour = getCashPerHour()
		local filledSlots = getFilledSlotCount()
		local totalSlots = PlayerStateClient.GetPath("UpgradeLevel") or 9
		local rarityEmoji = rarityEmojis[rarity] or "❓"
		local mutationEmoji = mutation and mutation ~= "Normal" and (mutationEmojis[mutation] or "✨") or nil

		local fields = {
			{ name = "👤 Username", value = localPlayer.Name, inline = true },
			{ name = "🧱 Block", value = blockName .. " (" .. blockCount .. "x)", inline = true },
			{ name = "⛏️ Pickaxe", value = pickaxe, inline = true },
		}

		if mutationEmoji then
			table.insert(fields, { name = mutationEmoji .. " Mutation", value = mutation, inline = true })
		end

		table.insert(fields, { name = "💰 Price", value = formatPrice(price), inline = true })
		table.insert(fields, { name = "🏦 Cash", value = formatPrice(cash), inline = true })
		table.insert(fields, { name = "📈 Cash/Hour", value = formatPrice(cashPerHour), inline = true })
		table.insert(fields, { name = "⏱️ Playtime", value = formatPlaytime(playtime), inline = true })
		table.insert(fields, { name = "🚗 Slots", value = filledSlots .. "/" .. totalSlots, inline = true })

		if currentEvent ~= "None" then
			table.insert(fields, { name = "🎉 Event", value = currentEvent, inline = true })
		end

		local embed = {
			title = rarityEmoji .. " " .. rarity .. " Block Purchased!",
			color = mutationColors[mutation] or rarityColors[rarity] or 3066993,
			fields = fields,
			timestamp = DateTime.now():ToIsoDate(),
			footer = { text = "🤖 Auto Buy" },
		}
		if thumbnailUrl then embed.thumbnail = { url = thumbnailUrl } end

		local ok, encoded = pcall(HttpService.JSONEncode, HttpService, { embeds = { embed } })
		if not ok then return end
		pcall(function()
			request({ Url = WEBHOOK_URL, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = encoded })
		end)
	end)
end

local function autoGiftAll(targetPlayer)
	if not targetPlayer then return end
	local now = tick()
	for _, container in ipairs({ localPlayer:FindFirstChild("Backpack"), localPlayer.Character }) do
		if not container then continue end
		for _, tool in ipairs(container:GetChildren()) do
			if tool:IsA("Tool") and tool:GetAttribute("ItemType") == "Car" then
				local uuid = tool:GetAttribute("UUID")
				if uuid and now - (giftCooldowns[uuid] or 0) >= GIFT_COOLDOWN then
					GiftRemote:FireServer(targetPlayer, "Car", uuid)
					giftCooldowns[uuid] = now
				end
			end
		end
	end
end

local function getPlayerList()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then table.insert(list, p.Name) end
	end
	return list
end

local function getAvailableLuckyBlocks()
	local blocks = PlayerStateClient.Get("Blocks")
	if not blocks then return {} end
	local seen, list = {}, {}
	for _, entry in pairs(blocks) do
		if entry.Name and entry.Name:match("Lucky Block") and not seen[entry.Name] then
			seen[entry.Name] = true
			table.insert(list, entry.Name)
		end
	end
	table.sort(list)
	return list
end

local function getUniqueCars()
	local cars = PlayerStateClient.Get("Cars")
	if not cars then return {} end
	local seen, list = {}, {}
	for _, car in pairs(cars) do
		if car.Name and not seen[car.Name] then
			seen[car.Name] = true
			table.insert(list, car.Name)
		end
	end
	table.sort(list)
	return list
end

local function equipPickaxe()
	local char = localPlayer.Character
	if not char then return end
	local tool = char:FindFirstChildWhichIsA("Tool")
	if tool and tool:GetAttribute("ItemType") == "Pickaxe" then return end
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	for _, v in ipairs(localPlayer.Backpack:GetChildren()) do
		if v:IsA("Tool") and v:GetAttribute("ItemType") == "Pickaxe" then
			humanoid:EquipTool(v)
			return
		end
	end
end

local placeRarityRank = {
	Common = 1, Uncommon = 2, Rare = 3, Epic = 4, Legendary = 5,
	Mythic = 6, Cosmic = 7, Secret = 8, Celestial = 9, Godly = 10, Exclusive = 11,
}
local rarityRank = { Godly = 4, Celestial = 3, Secret = 2, Cosmic = 1 }

local function getOwnerPlot()
	for _, location in ipairs(PlotLocations:GetChildren()) do
		if location:IsA("BasePart") and location:GetAttribute("OwnerId") == localPlayer.UserId then
			return Plots:FindFirstChild(location.Name)
		end
	end
end

local function destroyOtherPlots()
	for _, plot in ipairs(Plots:GetChildren()) do
		local location = PlotLocations:FindFirstChild(plot.Name)
		if location and location:GetAttribute("OwnerId") ~= localPlayer.UserId then
			plot:Destroy()
		end
	end
end

local function destroyMapChildren()
	local map = Workspace:FindFirstChild("Map")
	if not map then return end
	for _, child in ipairs(map:GetChildren()) do
		if child.Name ~= "World" then
			child:Destroy()
		end
	end
end

task.spawn(function()
	while true do
		if Settings.OptimizeGpu then
			game:GetService("RunService"):Set3dRenderingEnabled(true)
		else
			game:GetService("RunService"):Set3dRenderingEnabled(false)
		end
		task.wait(1)
	end
end)

task.spawn(function()
	if Settings.DestroyOtherPlots then
		destroyOtherPlots()
		destroyMapChildren()
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoCollectCash then
			local plot = getOwnerPlot()
			if plot then
				local slots = plot:FindFirstChild("Slots")
				if slots then
					for _, slot in ipairs(slots:GetChildren()) do
						local slotNumber = tonumber(slot.Name)
						if slotNumber then
							local slotData = PlayerStateClient.GetFromDict("Plot.Slots", slotNumber)
							if slotData and slotData.Occupied and slotData.Type == "Car" and slotData.Cash and slotData.Cash > 0 then
								CollectCash:FireServer(slotNumber)
							end
						end
					end
				end
			end
		end
		task.wait(0.5)
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoUpgradeCars then
			local plot = getOwnerPlot()
			if plot then
				local slots = plot:FindFirstChild("Slots")
				if slots then
					local candidates = {}
					for _, slot in ipairs(slots:GetChildren()) do
						local slotNumber = tonumber(slot.Name)
						if slotNumber then
							local slotData = PlayerStateClient.GetFromDict("Plot.Slots", slotNumber)
							if slotData and slotData.Occupied and slotData.Type == "Car" then
								local carData = CarConfig.GetCarData(slotData.Name)
								if carData and rarityRank[carData.Rarity] then
									local cost = CarConfig.CalculateUpgradeCost(slotData.Name, slotData.Level or 1, slotData.Mutation)
									if cost then
										table.insert(candidates, { slotNumber = slotNumber, cost = cost, rank = rarityRank[carData.Rarity] })
									end
								end
							end
						end
					end
					table.sort(candidates, function(a, b) return a.rank > b.rank end)
					local cash = PlayerStateClient.Get("Cash") or 0
					for _, candidate in ipairs(candidates) do
						if candidate.cost <= cash then
							UpgradeCar:FireServer(candidate.slotNumber)
							cash -= candidate.cost
						end
					end
				end
			end
		end
		task.wait(0.5)
	end
end)

SpawnBlock.OnClientEvent:Connect(function(owner, blockName, mutation, uuid)
	if owner ~= localPlayer then return end
	local blockData = BlockConfig.GetBlockData(blockName)
	if not blockData then return end

	local mutationData = MutationConfig.GetMutationData(mutation)
	local price = blockData.Price
	if price and mutationData and mutationData.IncomeMultiplier then
		price *= mutationData.IncomeMultiplier
	end

	local bought = false

	if Settings.AutoBuyBlocks and Settings.TargetRarities[blockData.Rarity] then
		BuyBlock:FireServer(uuid)
		bought = true
	elseif Settings.AutoBuyRainbowCelestial and blockData.Rarity == "Celestial" and mutation == "Rainbow" then
		BuyBlock:FireServer(uuid)
		bought = true
	elseif Settings.AutoBuyInfernalCelestial and blockData.Rarity == "Celestial" and mutation == "Infernal" then
		BuyBlock:FireServer(uuid)
		bought = true
	elseif Settings.AutoBuyRainbowSecret and blockData.Rarity == "Secret" and mutation == "Rainbow" then
		BuyBlock:FireServer(uuid)
		bought = true
	end

	if bought and webhookRarities[blockData.Rarity] then
		sendWebhook(blockName, mutation, blockData.Rarity, price, uuid)
	end
end)

local function getEmptySlots(plot)
	local empty = {}
	local upgradeLevel = PlayerStateClient.GetPath("UpgradeLevel") or 9
	local slots = plot:FindFirstChild("Slots")
	if not slots then return empty end
	for _, slot in ipairs(slots:GetChildren()) do
		local slotNumber = tonumber(slot.Name)
		if slotNumber and slotNumber <= upgradeLevel then
			local slotData = PlayerStateClient.GetFromDict("Plot.Slots", slotNumber)
			if not slotData or (not slotData.Occupied and not slotData.Pending) then
				table.insert(empty, slotNumber)
			end
		end
	end
	table.sort(empty)
	return empty
end

local function getCarTools()
	local tools = {}
	local function scan(container)
		if not container then return end
		for _, item in ipairs(container:GetChildren()) do
			if item:IsA("Tool") and item:GetAttribute("ItemType") == "Car" then
				local carData = CarConfig.GetCarData(item.Name)
				if carData then
					table.insert(tools, { tool = item, rank = placeRarityRank[carData.Rarity] or 0 })
				end
			end
		end
	end
	scan(localPlayer:FindFirstChild("Backpack"))
	scan(localPlayer.Character)
	table.sort(tools, function(a, b) return a.rank > b.rank end)
	return tools
end

task.spawn(function()
	while true do
		if Settings.AutoPlaceCars then
			local plot = getOwnerPlot()
			if plot then
				local emptySlots = getEmptySlots(plot)
				local carTools = getCarTools()
				for i, slotNumber in ipairs(emptySlots) do
					local entry = carTools[i]
					if not entry then break end
					local uuid = entry.tool:GetAttribute("UUID")
					local itemType = entry.tool:GetAttribute("ItemType")
					if uuid and itemType then
						PlaceItem:FireServer(slotNumber, itemType, uuid)
					end
				end
			end
		end
		task.wait(1)
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoBuySlots then
			local currentLevel = PlayerStateClient.GetPath("UpgradeLevel") or 9
			local nextLevel = currentLevel + 1
			local cost = UpgradeConfig.GetUpgradeCost(nextLevel)
			if cost then
				local cash = PlayerStateClient.Get("Cash") or 0
				if cash >= cost then
					BuyUpgrade:FireServer(nextLevel)
				end
			end
		end
		task.wait(0.5)
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoGift and Settings.GiftTarget ~= "" then
			for _, p in ipairs(Players:GetPlayers()) do
				if p.Name == Settings.GiftTarget then
					autoGiftAll(p)
					break
				end
			end
		end
		task.wait(1)
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoOpenLuckyBlock and Settings.LuckyBlockTarget ~= "" then
			local plot = getOwnerPlot()
			if plot then
				local slotData = PlayerStateClient.GetFromDict("Plot.Slots", 1)
				if slotData and slotData.Occupied then
					if slotData.Type == "Car" then
						RemoveItem:FireServer("Car", 1)
					elseif slotData.Type == "Block" then
						equipPickaxe()
						PickaxeRemote:FireServer("Damage")
					end
				else
					local blocks = PlayerStateClient.Get("Blocks")
					local uuid = blocks and (function()
						for u, d in pairs(blocks) do
							if d.Name == Settings.LuckyBlockTarget then return u end
						end
					end)()
					if uuid then
						PlaceItem:FireServer(1, "Block", uuid)
					end
				end
			end
		end
		task.wait(0.8)
	end
end)

task.spawn(function()
	while true do
		if Settings.AutoSellCars then
			for _, carName in ipairs(Settings.CarsToSell) do
				local cars = PlayerStateClient.Get("Cars")
				if cars then
					for uuid, car in pairs(cars) do
						if car.Name == carName and (car.Mutation == nil or car.Mutation == "Normal") then
							SellCar:FireServer(uuid)
						end
					end
				end
			end
		end
		task.wait(0.1)
	end
end)

