local GUIDS_CLAIMED   = {}
local ICON_CACHE         = {}
local equippedCache   = {}
local cratePriceCache = {}

local blacklistSet = {}
do
    local petCfg = CFG and CFG.AUTO_EQUIP_PETS
    if petCfg then
        for _, name in ipairs(petCfg.BLACKLIST or {}) do
            blacklistSet[name] = true
        end
    end
end

local seedPriceMap = {}
for _, entry in ipairs(SeedData) do
    if entry.SeedName and entry.PurchasePrice then
        seedPriceMap[entry.SeedName] = entry.PurchasePrice
    end
end

local gearPriceMap = {}
for _, entry in ipairs(GearShopData.Data) do
    if entry.ItemName and entry.Cost then
        gearPriceMap[entry.ItemName] = entry.Cost
    end
end

local function getCratePrice(crateName)
    local cached = cratePriceCache[crateName]
    if cached ~= nil then
        return cached ~= false and cached or nil
    end
    local entry = CrateData.GetData(crateName)
    local price = entry and (entry.Cost or entry.Price) or false
    cratePriceCache[crateName] = price
    return price ~= false and price or nil
end

local function getBalance()
    return replica and replica.Data and replica.Data.Sheckles or 0
end

local function formatNumber(n)
    n = tonumber(n) or 0
    if n >= 1e9 then return string.format("%.1fB", n / 1e9)
    elseif n >= 1e6 then return string.format("%.1fM", n / 1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n / 1e3)
    else return tostring(math.round(n)) end
end

local function getStockValue(itemsFolder, itemName)
    local child = itemsFolder:FindFirstChild(itemName)
    return child and child.Value or 0
end

local function getToolFromBackpackByAttr(attrKey, attrValue)
    local char = LocalPlayer.Character
    local function scan(parent)
        for _, v in pairs(parent:GetChildren()) do
            if v:IsA("Tool") and v:GetAttribute(attrKey) == attrValue then
                return v
            end
        end
        return nil
    end
    return scan(Backpack) or (char and scan(char)) or nil
end

local function getAllToolsFromBackpackByAttr(attrKey, attrValue)
    local results = {}
    local char = LocalPlayer.Character
    local function scan(parent)
        for _, v in pairs(parent:GetChildren()) do
            if v:IsA("Tool") and v:GetAttribute(attrKey) == attrValue then
                table.insert(results, v)
            end
        end
    end
    scan(Backpack)
    if char then scan(char) end
    return results
end

local function equipAndActivateTool(tool)
    local char = LocalPlayer.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end

    humanoid:EquipTool(tool)
    local start = os.clock()
    local runs = 10
    
    repeat
        runs = runs - 1
    
        if runs == 0 then
            runs = 10
            task.wait()
        end
    until tool.Parent == char or (os.clock() - start) > 0.1

    tool:Activate()
    task.wait()
    humanoid:UnequipTools()
    return true
end

local function claimGuid(guid)
    if GUIDS_CLAIMED[guid] then return false end
    GUIDS_CLAIMED[guid] = true
    return true
end

local function calcOneIn(spawnChance)
    if not spawnChance or spawnChance <= 0 then return 0 end
    return math.round(1 / (spawnChance / 100))
end

local function parseWildPetName(instanceName)
    local petName, guid = instanceName:match("^WildPet_(.+)_WildPet_(.+)$")
    if not petName or petName == "" or not guid or guid == "" then return nil, nil end
    return petName, guid
end

local function getIconUrl(iconAssetId)
    if not iconAssetId or iconAssetId == "N/A" or iconAssetId == "" then return nil end
    local assetNumber = tostring(iconAssetId):match("rbxassetid://(%d+)")
    if not assetNumber then return nil end
    if ICON_CACHE[assetNumber] ~= nil then
        return ICON_CACHE[assetNumber] ~= false and ICON_CACHE[assetNumber] or nil
    end
    local thumbnailUrl = nil
    pcall(function()
        local r = request({
            Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetNumber .. "&size=420x420&format=Png&isCircular=false",
            Method = "GET"
        })
        if r and r.Success then
            local ok, decoded = pcall(HttpService.JSONDecode, HttpService, r.Body)
            if ok and decoded and decoded.data and decoded.data[1] then
                thumbnailUrl = decoded.data[1].imageUrl
            end
        end
    end)
    ICON_CACHE[assetNumber] = thumbnailUrl or false
    return thumbnailUrl
end

local function getOwnedPets()
    local pets = {}
    local inventoryData = replica and replica.Data and replica.Data.Inventory
    if not inventoryData or not inventoryData.Pets then return pets end
    for petId, petInfo in pairs(inventoryData.Pets) do
        if type(petInfo) == "table" and type(petInfo.Name) == "string" then
            table.insert(pets, { Id = petId, Name = petInfo.Name, Equipped = petInfo.Equipped or false })
        end
    end
    return pets
end

local function getDesiredPets()
    local cfg = CFG.AUTO_EQUIP_PETS
    local maxSlots = LocalPlayer:GetAttribute("MaxEquippedPets") or 1
    local ownedPets = getOwnedPets()
    local ownedByName = {}
    for _, pet in ipairs(ownedPets) do
        if not ownedByName[pet.Name] then ownedByName[pet.Name] = {} end
        table.insert(ownedByName[pet.Name], pet)
    end
    local desired = {}
    for _, name in ipairs(cfg.PRIORITY or {}) do
        if #desired >= maxSlots then break end
        if not blacklistSet[name] and ownedByName[name] and #ownedByName[name] > 0 then
            table.insert(desired, ownedByName[name][1])
        end
    end
    return desired
end

local function refreshEquippedCache()
    local ok, result = pcall(function()
        return Remotes.Pets.GetEquippedPets:Fire()
    end)
    if ok and type(result) == "table" then
        table.clear(equippedCache)
        for _, pet in ipairs(result) do
            if type(pet) == "table" and type(pet.Name) == "string" then
                equippedCache[pet.Name] = pet
            end
        end
    end
end

local function shouldBuyPet(data)
    local cfg = CFG.AUTO_BUY_PETS
    if not cfg or not cfg.ENABLED then return false end
    for _, name in ipairs(cfg.NAMES) do
        if data.DisplayName == name then return true end
    end
    for _, rarity in ipairs(cfg.RARITIES) do
        if data.Rarity == rarity then return true end
    end
    return false
end

local function sendPetWebhook(data, price, oneIn)
    local cfg = CFG.AUTO_BUY_PETS
    if oneIn < cfg.MINIMUM_LUCK_SENT then return end
    if not cfg.WEBHOOK_URL or cfg.WEBHOOK_URL == "" then return end
    local article = data.DisplayName:match("^[AEIOUaeiou]") and "an" or "a"
    local title = "🐾 Captured " .. article .. " 1 in " .. formatNumber(oneIn) .. " " .. data.DisplayName .. "!"
    local fields = {
        { name = "Player",        value = "||" .. LocalPlayer.Name .. "||", inline = true },
        { name = "Price",         value = formatNumber(price),              inline = true },
        { name = "Rarity",        value = tostring(data.Rarity),            inline = true },
        { name = "server-job-id", value = tostring(game.JobId),             inline = false },
    }
    if cfg.NOTE and cfg.NOTE ~= "" then
        table.insert(fields, { name = "Note", value = cfg.NOTE, inline = false })
    end
    local embed = {
        title = title,
        color = 0x5865F2,
        fields = fields,
        footer = { text = "discord.gg/idiothub" }
    }
    local thumbnailUrl = getIconUrl(data.Image)
    if thumbnailUrl then embed.thumbnail = { url = thumbnailUrl } end
    local mention = (cfg.DISCORD_ID and cfg.DISCORD_ID ~= "") and ("<@" .. cfg.DISCORD_ID .. ">") or nil
    local payload
    local ok = pcall(function()
        payload = HttpService:JSONEncode({ content = mention, embeds = { embed } })
    end)
    if not ok or not payload then return end
    pcall(function()
        request({
            Url = cfg.WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = payload
        })
    end)
end

local function playerAlive()
    local char     = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    return humanoid ~= nil and humanoid.Health > 0
end

getgenv().tweenSpeed = getgenv().tweenSpeed or 30
getgenv().tweening = getgenv().tweening or false
getgenv().stuffPositions = getgenv().stuffPositions or {
    ["Seeds"] = CFrame.new(264, 147, -145),
    ["Sell"] = CFrame.new(270, 147, -127)
}

local TELEPORT_THRESHOLD_SQ = 16

local function xzDistanceSq(a, b)
    local dx = a.X - b.X
    local dz = a.Z - b.Z
    return dx * dx + dz * dz
end

local function computePlotCenter()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if not plotId then return nil end

    local gardens = workspace:FindFirstChild("Gardens")
    local plot = gardens and gardens:FindFirstChild("Plot" .. plotId)
    if not plot then return nil end

    local spawnPoint = plot:FindFirstChild("SpawnPoint")
    if spawnPoint then
        return spawnPoint.Position
    end

    local prim = plot:FindFirstChildWhichIsA("BasePart") or plot.PrimaryPart
    return prim and prim.Position
end

if not getgenv().stuffPositions["Garden"] then
    local pos = computePlotCenter()
    if pos then
        getgenv().stuffPositions["Garden"] = CFrame.new(pos)
    end
end

local function getBottomRectClosestPoint(part, point)
    local size = part.Size
    local cf = part.CFrame * CFrame.new(0, -size.Y / 2, 0)
    local localPoint = cf:PointToObjectSpace(point)
    local halfX, halfZ = size.X / 2, size.Z / 2
    local clampedX = math.clamp(localPoint.X, -halfX, halfX)
    local clampedZ = math.clamp(localPoint.Z, -halfZ, halfZ)
    return cf:PointToWorldSpace(Vector3.new(clampedX, 0, clampedZ))
end

local function pointInBottomRectXZ(part, point)
    local size = part.Size
    local cf = part.CFrame * CFrame.new(0, -size.Y / 2, 0)
    local localPoint = cf:PointToObjectSpace(point)
    return math.abs(localPoint.X) <= size.X / 2 and math.abs(localPoint.Z) <= size.Z / 2
end

local function moveTowards(from, to, maxDistance)
    local offset = to - from
    local distance = offset.Magnitude
    if distance <= maxDistance then
        return to
    end
    return from + offset.Unit * maxDistance
end

local function tweenTo(hrp, targetPos)
    local remainingDistance = (hrp.Position - targetPos).Magnitude
    local TWEEN_SPEED = getgenv().tweenSpeed

    if remainingDistance <= TWEEN_SPEED then
        hrp.CFrame = CFrame.new(targetPos)
        return
    end

    getgenv().tweening = true

    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(remainingDistance / TWEEN_SPEED, Enum.EasingStyle.Linear),
        { CFrame = CFrame.new(targetPos) }
    )

    tween:Play()
    tween.Completed:Wait()

    getgenv().tweening = false
end

if not getgenv().CONFIG.TESTING then 
    getgenv().CONFIG.TESTING = false
end
local canTeleportDirect = getgenv().CONFIG.TESTING
local function teleport(target, teleportDirect)
    if teleportDirect == nil then
        teleportDirect = canTeleportDirect
    end

    if getgenv().tweening then
        return false
    end

    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return false
    end

    if not teleportDirect then
        if typeof(target) == "string" then
            local cf = getgenv().stuffPositions and getgenv().stuffPositions[target]
            if not cf then
                return false
            end

            if xzDistanceSq(hrp.Position, cf.Position) > TELEPORT_THRESHOLD_SQ then
                Remotes.TeleportButton.Request:Fire(target)
            end

            return true
        end

        local targetPos = typeof(target) == "CFrame" and target.Position or target

        if xzDistanceSq(hrp.Position, targetPos) > TELEPORT_THRESHOLD_SQ then
            local bestDistance = (hrp.Position - targetPos).Magnitude
            local bestTeleport

            for _, thing in ipairs(workspace.Teleports:GetChildren()) do
                local pos
                if thing:IsA("BasePart") then
                    pos = thing.Position
                else
                    local part = thing:FindFirstChildWhichIsA("BasePart")
                    pos = part and part.Position
                end

                if pos then
                    local distance = (pos - targetPos).Magnitude
                    if distance < bestDistance then
                        bestDistance = distance
                        bestTeleport = thing
                    end
                end
            end

            if bestTeleport then
                Remotes.TeleportButton.Request:Fire(bestTeleport)
                repeat
                    character = LocalPlayer.Character
                    hrp = character and character:FindFirstChild("HumanoidRootPart")
                    if not hrp then
                        task.wait()
                    end
                until hrp
            end
        end

        tweenTo(hrp, targetPos)
        return true
    end

    local targetPos
    if typeof(target) == "string" then
        local cf = getgenv().stuffPositions and getgenv().stuffPositions[target]
        if not cf then
            return false
        end
        targetPos = cf.Position
    elseif typeof(target) == "CFrame" then
        targetPos = target.Position
    else
        targetPos = target
    end

    local safezonePart = workspace.Map.SafeZones.Part
    local gardenCF = getgenv().stuffPositions and getgenv().stuffPositions["Garden"]

    local safezoneEdge = getBottomRectClosestPoint(safezonePart, targetPos)
    local safezoneDistance = (safezoneEdge - targetPos).Magnitude

    local gardenDistance = gardenCF and (gardenCF.Position - targetPos).Magnitude or math.huge
    local currentDistance = (hrp.Position - targetPos).Magnitude

    if safezoneDistance <= gardenDistance and safezoneDistance <= currentDistance then
        Remotes.TeleportButton.Request:Fire("Seeds")
        task.wait()

        character = LocalPlayer.Character
        hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            return false
        end

        hrp.CFrame = CFrame.new(safezoneEdge)
        task.wait()

        local stepPos = moveTowards(hrp.Position, targetPos, 90)
        hrp.CFrame = CFrame.new(stepPos)

        tweenTo(hrp, targetPos)
        return true
    end

    if gardenDistance <= currentDistance then
        Remotes.TeleportButton.Request:Fire("Garden")
        task.wait()

        character = LocalPlayer.Character
        hrp = character and character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            return false
        end

        local stepPos = moveTowards(hrp.Position, targetPos, 90)
        hrp.CFrame = CFrame.new(stepPos)

        tweenTo(hrp, targetPos)
        return true
    end

    local closeToGarden = gardenCF and (hrp.Position - gardenCF.Position).Magnitude <= 3
    local insideSafezone = pointInBottomRectXZ(safezonePart, hrp.Position)

    if not closeToGarden and not insideSafezone then
        tweenTo(hrp, targetPos)
    end

    return true
end

local function getPlot(targetUserId)
    local player = Players:GetPlayerByUserId(targetUserId)
    if not player then return nil end
    local plotId = player:GetAttribute("PlotId")
    if not plotId then return nil end
    local gardens = workspace:FindFirstChild("Gardens")
    return gardens and gardens:FindFirstChild("Plot" .. plotId)
end

local function isTableEmpty(tbl)
    return type(tbl) == "table" and next(tbl) == nil
end

local function count(tbl)
    if type(tbl) ~= "table" then return 0 end
    local c = 0
    for _ in pairs(tbl) do
        c = c + 1
    end
    return c
end

local function matchesList(list, value)
    if #list == 0 then return true end
    for _, entry in list do
        if entry == value then return true end
    end
    return false
end

local function checkFruitCollect(cfg, mutation, variant, age, maxAge)
    local eligible = matchesList(cfg.MUTATIONS_TO_COLLECT, mutation or "Normal")
        and matchesList(cfg.VARIANTS_TO_COLLECT, variant or "Normal")
    if not eligible then return false end
    local instant = (mutation and cfg.INSTANT_COLLECT_MUTATED)
        or (variant and cfg.INSTANT_COLLECT_VARIANTS)
    return instant or (maxAge > 0 and age >= maxAge)
end

local function getBackpackFruitCount(ignoreFavs)
    ignoreFavs = ignoreFavs or false
    local total = 0
    for _, tool in ipairs(Backpack:GetChildren()) do
        local isFruit = tool:GetAttribute("Fruit") ~= nil and tool:GetAttribute("FruitName") ~= nil
        if isFruit then
            if ignoreFavs and tool:GetAttribute("IsFavorite") == true then
                continue
            end
            total += 1
        end
    end
    return total
end

local function getFruits()
    local fruits = {}
    for _, tool in ipairs(Backpack:GetChildren()) do
        if tool:GetAttribute("Fruit") ~= nil and tool:GetAttribute("FruitName") ~= nil then
            table.insert(fruits, tool)
        end
    end
    return fruits
end

local function getSellValue(tool)
    if not tool then return nil end
    local fruitName = tool:GetAttribute("FruitName")
    if not fruitName then return nil end
    return FruitValueCalc(
        fruitName,
        tool:GetAttribute("SizeMultiplier") or 1,
        tool:GetAttribute("Mutation"),
        LocalPlayer,
        tool:GetAttribute("DecayAlpha")
    )
end


do
