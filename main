    local function runAutoBuySeeds()
        local cfg = CFG.AUTO_BUY_SEEDS
        if not cfg or not cfg.ENABLED then return end
        for seedName, wantCount in pairs(cfg) do
            if seedName == "ENABLED" then continue end
            local price = seedPriceMap[seedName]
            if not price then continue end
            local stock = getStockValue(SeedShopItems, seedName)
            if stock <= 0 then continue end
            local toBuy = math.min(wantCount, stock)
            for i = 1, toBuy do
                if getBalance() < price then break end
                Remotes.SeedShop.PurchaseSeed:Fire(seedName)
                task.wait(0.08)
            end
        end
    end

    local function runAutoBuyGears()
        local cfg = CFG.AUTO_BUY_GEARS
        if not cfg or not cfg.ENABLED then return end
        for gearName, wantCount in pairs(cfg) do
            if gearName == "ENABLED" then continue end
            local price = gearPriceMap[gearName]
            if not price then continue end
            local stock = getStockValue(GearShopItems, gearName)
            if stock <= 0 then continue end
            local toBuy = math.min(wantCount, stock)
            for i = 1, toBuy do
                if getBalance() < price then break end
                Remotes.GearShop.PurchaseGear:Fire(gearName)
                task.wait(0.08)
            end
        end
    end

    local function runAutoBuyCrates()
        local cfg = CFG.AUTO_BUY_CRATES
        if not cfg or not cfg.ENABLED then return end
        for crateName, wantCount in pairs(cfg) do
            if crateName == "ENABLED" then continue end
            local price = getCratePrice(crateName)
            if not price then continue end
            local stock = getStockValue(CrateShopItems, crateName)
            if stock <= 0 then continue end
            local toBuy = math.min(wantCount, stock)
            for i = 1, toBuy do
                if getBalance() < price then break end
                Remotes.CrateShop.PurchaseCrate:Fire(crateName)
                task.wait(0.08)
            end
        end
    end

    LC:Add("AutoBuySeeds", {
