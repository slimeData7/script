local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace         = game:GetService("Workspace")

local LocalPlayer   = Players.LocalPlayer
local PlayerScripts = LocalPlayer:FindFirstChildOfClass("PlayerScripts")
local PlayerGui     = LocalPlayer:FindFirstChildOfClass("PlayerGui")

local DRY_RUN = false
local VERBOSE = true

local KEEP = {
    [ReplicatedStorage] = {
        "Assets.Fruits", "Assets.Plants",
        "ClientModules.PlayerStateClient",
        "SharedData.PetData", "SharedData.PetSlotPrices",
        "SharedModules.CalculateOvertimeGrowth", "SharedModules.CalculateStealDuration",
        "SharedModules.CrateData", "SharedModules.Flags.StealFlags",
        "SharedModules.FruitProxyUtil", "SharedModules.FruitValueCalc",
        "SharedModules.GearShopData", "SharedModules.GrowRateData",
        "SharedModules.InArea", "SharedModules.MutationData",
        "SharedModules.Networking", "SharedModules.RarityData",
        "SharedModules.SeedData", "SharedModules.SellValueData",
        "SharedModules.SprinklerData",
        "StockValues.CrateShop.Items", "StockValues.GearShop.Items",
        "StockValues.SeedShop.Items",
    },
    [PlayerScripts] = {
        "Controllers.FruitVisualizerController", "Controllers.GardenSyncController",
        "Controllers.PlantVisualizerController", "Controllers.SeedHandleController",
        "Controllers.SprinklerHandleController", "Controllers.StealController",
    },
    [Workspace] = {
        "Gardens",
        "Map",
        "Teleports",
        "Baseplate",
        "_PetVisualClient"
    },
    [PlayerGui] = {
        "IdiotHubGui"
    },
}
local FORCE_KEEP = {
    Workspace.CurrentCamera,
    Workspace:FindFirstChildOfClass("Terrain"),
    LocalPlayer.Character,
}

local protected = {}

local function protect(inst)
    if not inst then return end
    protected[inst] = true
    for _, d in ipairs(inst:GetDescendants()) do protected[d] = true end
    local p = inst.Parent
    while p do protected[p] = true; p = p.Parent end
end

local function resolve(root, path)
    local node = root
    for name in string.gmatch(path, "[^%.]+") do
        if not node then return nil end
        node = node:FindFirstChild(name)
    end
    return node
end

for root, paths in pairs(KEEP) do
    if root then
        protected[root] = true
        for _, path in ipairs(paths) do
            local inst = resolve(root, path)
            if inst then protect(inst)
            elseif VERBOSE then warn(("[prune] keep-path not found: %s"):format(path)) end
        end
    end
end
for _, inst in ipairs(FORCE_KEEP) do protect(inst) end

local count = 0
local function prune(root)
    if not root then return end
    for _, inst in ipairs(root:GetDescendants()) do
        local parent = inst.Parent
        if parent and protected[parent] and not protected[inst] then
            if DRY_RUN then
            else
                pcall(function() inst:Destroy() end)
            end
            count += 1
        end
    end
end

for _, root in ipairs({ ReplicatedStorage, Workspace, PlayerScripts, PlayerGui }) do
    prune(root)
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local CollectionService = game:GetService("CollectionService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")

local Player = Players.LocalPlayer

local Bindable = loadstring(game:HttpGet("https://raw.githubusercontent.com/Somerandomidiot/RobloxScripts/refs/heads/main/modules/BindableVar.lua"))()
local Numbers = loadstring(game:HttpGet("https://raw.githubusercontent.com/Somerandomidiot/RobloxScripts/refs/heads/main/modules/Numbers"))()

do
    local RunService = game:GetService("RunService")
    local RTask = task
    local Bindable = getgenv().Bindable or Bindable or loadstring(game:HttpGet("https://raw.githubusercontent.com/Somerandomidiot/RobloxScripts/refs/heads/main/modules/BindableVar.lua"))()
    getgenv().Bindable = Bindable

    local existing = getgenv().LoopController
    if existing then
        if existing.Connections then
            for _, c in pairs(existing.Connections) do
                pcall(function() c:Disconnect() end)
            end
        end
        existing.WhileActive = false
        if existing.ActiveExecutions then
            for _, exec in pairs(existing.ActiveExecutions) do
                if type(exec) == "table" and exec.Cancel then
                    pcall(exec.Cancel, exec)
                end
            end
        end
        if existing._runASAPThread
            and coroutine.status(existing._runASAPThread) ~= "dead" then
            pcall(coroutine.close, existing._runASAPThread)
        end
        if existing._activeSyncCoroutine
            and coroutine.status(existing._activeSyncCoroutine) ~= "dead" then
            pcall(coroutine.close, existing._activeSyncCoroutine)
        end
        if existing._extraConnections then
            for _, conn in pairs(existing._extraConnections) do
                if conn and conn.Disconnect then
                    pcall(function() conn:Disconnect() end)
                end
            end
        end
        if existing._extraThreads then
            for _, handle in pairs(existing._extraThreads) do
                if type(handle) == "table" and handle.Cancel then
                    pcall(handle.Cancel, handle)
                end
            end
        end
        for k in pairs(existing) do existing[k] = nil end
    else
        getgenv().LoopController = {}
    end

    local LC = getgenv().LoopController

    local _execIdCounter = 0
    local function newExecution(taskObj, thread)
        _execIdCounter = _execIdCounter + 1
        local exec = {
            Id        = _execIdCounter,
            Task      = taskObj,
            Thread    = thread,
            Done      = false,
            Cancelled = false,
        }
        function exec:Cancel()
            if self.Done then return end
            self.Cancelled = true
            if self.Thread and coroutine.status(self.Thread) ~= "dead" then
                pcall(coroutine.close, self.Thread)
            end
        end
        function exec:Finish()
            self.Done   = true
            self.Thread = nil
        end
        return exec
    end

    LC.Tasks        = {}
    LC.Order        = {}
    LC.AsyncOrder   = {}
    LC.TempTasks    = {}

    LC.Count        = 0
    LC.AsyncCount   = 0

    LC.ActiveExecutions = {}

    LC.Frame        = 0
    LC.AsyncFrame   = 0

    LC.Running      = false
    LC.Connections  = {}

    LC.TempTaskCleanup = {}
    LC.LastCleanup  = 0

    LC.RunASAPQueue      = {}
    LC._runASAPActive    = false
    LC._runASAPPaused    = false
    LC._runASAPThread    = nil

    LC._currentForcedExec = nil

    LC.SyncIndex    = 1
    LC.AsyncIndex   = 1

    LC._syncPauseRefs  = 0
    LC._asyncPauseRefs = 0

    LC.LoopMode    = "Heartbeat"
    LC.WhileActive = false
    LC._destroyed  = false

    LC._estimatedFPS = 60

    LC.HeartbeatMaxExecutions = nil
    LC.WhileMaxExecutions     = nil

    LC._activeSyncCoroutine = nil

    LC._extraConnections = {}
    LC._extraThreads     = {}

    local function smallSpin()
        for _ = 1, 500 do end
    end

    function LC:IsSyncPaused()
        return self._syncPauseRefs > 0
    end

    function LC:IsAsyncPaused()
        return self._asyncPauseRefs > 0
    end

    function LC:_pauseInc(sync, async)
        if sync  then self._syncPauseRefs  = self._syncPauseRefs  + 1 end
        if async then self._asyncPauseRefs = self._asyncPauseRefs + 1 end
    end

    function LC:_pauseDec(sync, async)
        if sync  then self._syncPauseRefs  = math.max(0, self._syncPauseRefs  - 1) end
        if async then self._asyncPauseRefs = math.max(0, self._asyncPauseRefs - 1) end
    end

    function LC:_registerExecution(exec)
        self.ActiveExecutions[exec.Id] = exec
    end

    function LC:_unregisterExecution(exec)
        exec:Finish()
        self.ActiveExecutions[exec.Id] = nil
    end

    function LC:_reapDeadExecutions()
        for id, exec in pairs(self.ActiveExecutions) do
            if exec.Thread and coroutine.status(exec.Thread) == "dead" then
                self:_unregisterExecution(exec)
            end
        end
    end

    function LC:_hasActiveExecution(taskName)
        for _, exec in pairs(self.ActiveExecutions) do
            if not exec.Done and exec.Task.Name == taskName then
                return true
            end
        end
        return false
    end

    function LC:_cancelExecutionsForTask(taskName)
        for _, exec in pairs(self.ActiveExecutions) do
            if exec.Task.Name == taskName then
                exec:Cancel()
            end
        end
        self:_reapDeadExecutions()
    end

    local function rebuildPriorities(order)
        for i = 1, #order do
            order[i].Priority = i
        end
        return #order
    end

    local function resolvePegs(order)
        local pegsBefore = {}
        local pegsAfter  = {}
        local nonPegged  = {}

        for _, t in ipairs(order) do
            if t.Pegged and t.PeggedAnchor then
                if t.PeggedSide == "Before" then
                    pegsBefore[t.PeggedAnchor] = pegsBefore[t.PeggedAnchor] or {}
                    table.insert(pegsBefore[t.PeggedAnchor], t)
                else
                    pegsAfter[t.PeggedAnchor] = pegsAfter[t.PeggedAnchor] or {}
                    table.insert(pegsAfter[t.PeggedAnchor], t)
                end
            else
                table.insert(nonPegged, t)
            end
        end

        local newOrder = {}
        for _, t in ipairs(nonPegged) do
            local name = t.Name
            if pegsBefore[name] then
                for _, pt in ipairs(pegsBefore[name]) do table.insert(newOrder, pt) end
            end
            table.insert(newOrder, t)
            if pegsAfter[name] then
                for _, pt in ipairs(pegsAfter[name]) do table.insert(newOrder, pt) end
            end
        end

        return newOrder
    end

    local function applyResolvePegs(self, order)
        local newOrder = resolvePegs(order)
        return newOrder, rebuildPriorities(newOrder)
    end

    local function insertAt(self, order, index, t)
        table.insert(order, index, t)
        return applyResolvePegs(self, order)
    end

    local function insertByPriority(self, order, t)
        local p = t.Priority or (#order + 1)
        p = math.clamp(p, 1, #order + 1)
        table.insert(order, p, t)
        return applyResolvePegs(self, order)
    end

    local function findIndexInList(order, name)
        for i = 1, #order do
            if order[i].Name == name then return i end
        end
    end

    local function normalizeData(name, data)
        local t = {}
        t.Name            = name
        t.Function        = data.Function  or function() end
        t.Condition       = data.Condition or function() return true end
        t.Protect         = data.Protect ~= false
        t.OnError         = data.OnError   or function() end
        t.OnRemove        = data.OnRemove  or function() end
        t.Interval        = data.Interval        or 0
        t.LoopInterval    = data.LoopInterval     or 0
        t.FrameInterval   = data.FrameInterval    or 0
        t.Before          = data.Before
        t.After           = data.After
        t.Priority        = data.Priority
        t.Async           = data.Async         == true
        t.AllowMultiple   = data.AllowMultiple == true
        t.Timeout         = data.Timeout         or 0
        t.AutoRemove      = data.AutoRemove    == true
        t.RemoveCondition = data.RemoveCondition
        t.RemoveOnFail    = data.RemoveOnFail  ~= false
        t.StopOthers      = data.StopOthers    == true
        t.Data            = data.Data            or {}
        t.Created         = os.clock()
        t.LastRun         = 0
        t.LastLoopCheck   = 0
        t.LastFrameRun    = 0
        t.Pegged          = data.Pegged        == true
        t.PeggedAnchor    = t.Pegged and (data.Before or data.After) or nil
        t.PeggedSide      = t.Pegged and (data.Before and "Before" or data.After and "After") or nil
        t.ParentCondition = data.ParentCondition
        t.RunASAP         = data.RunASAP       == true
        t.Forced          = data.Forced        == true
        t.RunsFast        = data.RunsFast      == true

        if typeof(data.Enabled) == "table" and data.Enabled.Value ~= nil then
            t.Enabled = data.Enabled
        else
            t.Enabled = Bindable(data.Enabled ~= false)
        end

        return t
    end

    local function addToList(self, order, t)
        if t.Before and t.After then
            warn("[LoopController] " .. t.Name .. ": has both Before and After — ignoring After")
            t.After = nil
        end

        if t.Before then
            local idx = findIndexInList(order, t.Before)
            if idx then return insertAt(self, order, idx, t) end
        end

        if t.After then
            local idx = findIndexInList(order, t.After)
            if idx then return insertAt(self, order, idx + 1, t) end
        end

        return insertByPriority(self, order, t)
    end

    function LC:_startRunASAPProcessor()
        if self._runASAPActive or #self.RunASAPQueue == 0 then return end
        self._runASAPActive = true

        RTask.spawn(function()
            self._runASAPThread = coroutine.running()

            while #self.RunASAPQueue > 0 and not self._destroyed do
                local entry = table.remove(self.RunASAPQueue, 1)
                local name  = entry.name
                local t     = entry.task

                self:_pauseInc(true, true)
                self._runASAPPaused = true

                if t.StopOthers then
                    for _, exec in pairs(self.ActiveExecutions) do
                        exec:Cancel()
                    end
                    self:_reapDeadExecutions()
                else
                    local waited = 0
                    while not self._destroyed do
                        self:_reapDeadExecutions()
                        local allDone = true
                        for _, exec in pairs(self.ActiveExecutions) do
                            if not exec.Done then
                                allDone = false
                                break
                            end
                        end
                        if allDone then break end
                        waited = waited + 1
                        if waited % 200 == 0 then
                            RTask.wait()
                        else
                            smallSpin()
                        end
                    end
                end

                if self._destroyed then
                    self:_pauseDec(true, true)
                    self._runASAPPaused = false
                    break
                end

                if t.Protect then
                    local ok, err = pcall(t.Function)
                    if not ok then t.OnError(name, "Function", err) end
                else
                    t.Function()
                end

                self:_pauseDec(true, true)
                self._runASAPPaused = false
            end

            self._runASAPThread = nil
            self._runASAPActive = false
        end)
    end

    function LC:Add(name, data)
        if self.Tasks[name] then
            warn("[LoopController] Add('" .. name .. "'): task already exists, replacing")
            self:Remove(name)
        end

        local t = normalizeData(name, data)
        self.Tasks[name] = t

        if t.Async then
            local newOrder, count = addToList(self, self.AsyncOrder, t)
            self.AsyncOrder = newOrder
            self.AsyncCount = count
        else
            local newOrder, count = addToList(self, self.Order, t)
            self.Order = newOrder
            self.Count = count
        end

        return t
    end

    function LC:Remove(name)
        if self.TempTasks[name] then
            return self:RemoveTemp(name, "manual")
        end

        self:_cancelExecutionsForTask(name)

        local t = self.Tasks[name]
        if t and t.OnRemove then
            pcall(t.OnRemove, "removed")
        end

        local idx = findIndexInList(self.Order, name)
        if idx then
            table.remove(self.Order, idx)
            if self.SyncIndex > idx then
                self.SyncIndex = math.max(1, self.SyncIndex - 1)
            end
            self.Count = rebuildPriorities(self.Order)
        end

        for i = #self.AsyncOrder, 1, -1 do
            if self.AsyncOrder[i] and self.AsyncOrder[i].Name == name then
                table.remove(self.AsyncOrder, i)
                if self.AsyncIndex > i then
                    self.AsyncIndex = math.max(1, self.AsyncIndex - 1)
                end
                break
            end
        end
        self.AsyncCount = rebuildPriorities(self.AsyncOrder)

        self.Tasks[name] = nil
    end

    function LC:AddTemp(name, data)
        if self.Tasks[name] then
            warn("[LoopController] AddTemp('" .. name .. "'): already exists, replacing")
            self:RemoveTemp(name, "replaced")
        end
        for i = #self.RunASAPQueue, 1, -1 do
            if self.RunASAPQueue[i].name == name then
                warn("[LoopController] AddTemp('" .. name .. "'): already in RunASAP queue, replacing")
                local removed = table.remove(self.RunASAPQueue, i)
                pcall(removed.task.OnRemove, "replaced")
                break
            end
        end

        data.Priority   = data.Priority or 1
        data.AutoRemove = true

        local t = normalizeData(name, data)
        t.IsTemp = true

        if t.Forced then
            RTask.spawn(function()
                self:_pauseInc(true, true)

                if self._runASAPThread
                    and coroutine.status(self._runASAPThread) ~= "dead" then
                    pcall(coroutine.close, self._runASAPThread)
                    self._runASAPThread = nil
                    if self._runASAPPaused then
                        self:_pauseDec(true, true)
                        self._runASAPPaused = false
                    end
                    self._runASAPActive = false
                end

                if self._currentForcedExec then
                    self._currentForcedExec:Cancel()
                    self:_pauseDec(true, true)
                    self._currentForcedExec = nil
                end

                for _, exec in pairs(self.ActiveExecutions) do
                    exec:Cancel()
                end
                self:_reapDeadExecutions()

                local exec = newExecution(t, coroutine.running())
                self:_registerExecution(exec)
                self._currentForcedExec = exec

                if t.Protect then
                    local ok, err = pcall(t.Function)
                    if not ok then t.OnError(name, "Function", err) end
                else
                    t.Function()
                end

                if not exec.Done then
                    self:_unregisterExecution(exec)
                end
                if self._currentForcedExec == exec then
                    self._currentForcedExec = nil
                end

                self:_pauseDec(true, true)

                if #self.RunASAPQueue > 0 then
                    self:_startRunASAPProcessor()
                end
            end)

            return t
        end

        if t.RunASAP then
            table.insert(self.RunASAPQueue, {name = name, task = t})
            if not self._runASAPActive then
                self:_startRunASAPProcessor()
            end
            return t
        end

        self.Tasks[name] = t
        self.TempTasks[name] = t

        local targetOrder = t.Async and self.AsyncOrder or self.Order
        local newOrder, count = addToList(self, targetOrder, t)

        if t.Async then
            self.AsyncOrder = newOrder
            self.AsyncCount = count
        else
            self.Order = newOrder
            self.Count = count
        end

        self.TempTaskCleanup[name] = {
            timeout   = t.Timeout,
            created   = t.Created,
            condition = t.RemoveCondition,
        }

        local insertedIdx = findIndexInList(t.Async and self.AsyncOrder or self.Order, name)
        if insertedIdx then
            if t.Async then
                if insertedIdx < (self.AsyncIndex or 1) then
                    self.AsyncIndex = insertedIdx
                end
            else
                if insertedIdx < (self.SyncIndex or 1) then
                    self.SyncIndex = insertedIdx
                end
            end
        end

        return t
    end

    function LC:RemoveTemp(name, reason)
        for i = #self.RunASAPQueue, 1, -1 do
            if self.RunASAPQueue[i].name == name then
                local entry = table.remove(self.RunASAPQueue, i)
                pcall(entry.task.OnRemove, reason or "manual")
                return true
            end
        end

        local t = self.TempTasks[name]
        if not t then return false end

        self:_cancelExecutionsForTask(name)
        pcall(t.OnRemove, reason or "manual")

        self.TempTasks[name]       = nil
        self.TempTaskCleanup[name] = nil

        local targetOrder = t.Async and self.AsyncOrder or self.Order

        for i = #targetOrder, 1, -1 do
            if targetOrder[i] and targetOrder[i].Name == name then
                table.remove(targetOrder, i)
                if t.Async then
                    if self.AsyncIndex and i <= self.AsyncIndex then
                        self.AsyncIndex = math.max(1, self.AsyncIndex - 1)
                    end
                    self.AsyncCount = rebuildPriorities(targetOrder)
                else
                    if self.SyncIndex and i <= self.SyncIndex then
                        self.SyncIndex = math.max(1, self.SyncIndex - 1)
                    end
                    self.Count = rebuildPriorities(targetOrder)
                end
                break
            end
        end

        self.Tasks[name] = nil
        return true
    end

    function LC:CleanupTempTasks()
        local now = os.clock()
        local toRemove = {}

        for name, info in pairs(self.TempTaskCleanup) do
            local t = self.Tasks[name]
            if not t then
                toRemove[#toRemove + 1] = name
            else
                if info.timeout and info.timeout > 0 and now - info.created > info.timeout then
                    toRemove[#toRemove + 1] = name
                elseif info.condition then
                    local ok, result = pcall(info.condition)
                    if ok and result then
                        toRemove[#toRemove + 1] = name
                    end
                end
            end
        end

        for _, name in ipairs(toRemove) do
            self:RemoveTemp(name, "cleanup")
        end
    end

    local function runAsyncTask(self, taskObj, frame, conditionPassed)
        local now = os.clock()

        if frame - taskObj.LastFrameRun  < taskObj.FrameInterval  then return false end
        if now   - taskObj.LastLoopCheck < taskObj.LoopInterval    then return false end
        if now   - taskObj.LastRun       < taskObj.Interval        then return false end

        if not conditionPassed then
            if taskObj.Protect then
                local ok, res = pcall(taskObj.Condition)
                conditionPassed = ok and res
                if not ok then taskObj.OnError(taskObj.Name, "Condition", res) end
            else
                conditionPassed = taskObj.Condition()
            end
            if not conditionPassed then return false end
        end

        taskObj.LastLoopCheck = now
        taskObj.LastRun       = now
        taskObj.LastFrameRun  = frame

        if not taskObj.AllowMultiple and self:_hasActiveExecution(taskObj.Name) then
            return true
        end

        local exec = newExecution(taskObj, nil)

        local thread = coroutine.create(function()
            if taskObj.Protect then
                local ok, err = pcall(taskObj.Function)
                if not ok then
                    taskObj.OnError(taskObj.Name, "Function", err)
                    if taskObj.RemoveOnFail then
                        self:_unregisterExecution(exec)
                        if taskObj.IsTemp then self:RemoveTemp(taskObj.Name, "error")
                        else self:Remove(taskObj.Name) end
                        return
                    end
                end
            else
                taskObj.Function()
            end

            if not exec.Done then
                self:_unregisterExecution(exec)
            end

            if taskObj.AutoRemove and not exec.Cancelled then
                if taskObj.IsTemp then self:RemoveTemp(taskObj.Name, "completed")
                else self:Remove(taskObj.Name) end
            end
        end)

        exec.Thread = thread
        self:_registerExecution(exec)

        local ok, err = coroutine.resume(thread)
        if not ok then
            taskObj.OnError(taskObj.Name, "Thread", tostring(err))
            if not exec.Done then
                self:_unregisterExecution(exec)
            end
        end

        return true
    end

    local function runList(self, order, count, frame, isAsync, indexKey)
        local now = os.clock()
        local condCache = {}

        if now - self.LastCleanup > 5 then
            self:CleanupTempTasks()
            self:_reapDeadExecutions()
            self.LastCleanup = now
        end

        if not isAsync then
            if self._activeSyncCoroutine then
                local st = coroutine.status(self._activeSyncCoroutine)
                if st == "suspended" then
                    return
                end
                self._activeSyncCoroutine = nil
            end
        end

        local pegsBefore  = {}
        local pegsAfter   = {}
        local peggedNames = {}

        for i = 1, count do
            local t = order[i]
            if t and t.Pegged and t.PeggedAnchor then
                peggedNames[t.Name] = true
                if t.PeggedSide == "Before" then
                    pegsBefore[t.PeggedAnchor] = pegsBefore[t.PeggedAnchor] or {}
                    table.insert(pegsBefore[t.PeggedAnchor], t)
                else
                    pegsAfter[t.PeggedAnchor] = pegsAfter[t.PeggedAnchor] or {}
                    table.insert(pegsAfter[t.PeggedAnchor], t)
                end
            end
        end

        local function evalCondition(t)
            if not t then return false end
            local cached = condCache[t.Name]
            if cached ~= nil then return cached end
            local result
            if t.Protect then
                local ok, res = pcall(t.Condition)
                result = ok and res
                if not ok then
                    t.OnError(t.Name, "Condition", res)
                    result = false
                end
            else
                result = t.Condition()
            end
            condCache[t.Name] = result
            return result
        end

        local limit
        if isAsync then
            limit = 1
        else
            local maxExec = (self.LoopMode == "while")
                and self.WhileMaxExecutions
                or  self.HeartbeatMaxExecutions

            if maxExec == nil then
                limit = math.huge
            elseif maxExec <= 1 then
                limit = 1
            else
                limit = maxExec
            end
        end

        local function tryRun(t, condAlreadyPassed)
            if not t then return false end

            if frame - t.LastFrameRun  < t.FrameInterval  then return false end
            if now   - t.LastLoopCheck < t.LoopInterval   then return false end

            t.LastLoopCheck = now

            local conditionPassed = condAlreadyPassed or evalCondition(t)
            if not conditionPassed then return false end
            if now - t.LastRun < t.Interval then return false end

            if isAsync then
                return runAsyncTask(self, t, frame, true), false
            end

            t.LastRun      = now
            t.LastFrameRun = frame

            local exec = newExecution(t, nil)
            self:_registerExecution(exec)

            local thread = coroutine.create(function()
                if t.Protect then
                    local ok, err = pcall(t.Function)
                    if not ok then
                        t.OnError(t.Name, "Function", err)
                        if t.RemoveOnFail then
                            self:_unregisterExecution(exec)
                            if t.IsTemp then self:RemoveTemp(t.Name, "error")
                            else self:Remove(t.Name) end
                            return
                        end
                    end
                else
                    t.Function()
                end

                if not exec.Done then
                    self:_unregisterExecution(exec)
                end

                if t.AutoRemove and not exec.Cancelled then
                    if t.IsTemp then self:RemoveTemp(t.Name, "completed")
                    else self:Remove(t.Name) end
                end
            end)

            exec.Thread = thread

            local ok, err = coroutine.resume(thread)
            if not ok then
                t.OnError(t.Name, "Thread", tostring(err))
                if not exec.Done then
                    self:_unregisterExecution(exec)
                end
                return true, false
            end

            local didYield = coroutine.status(thread) ~= "dead"
            if didYield then
                self._activeSyncCoroutine = thread
            end

            return true, didYield
        end

        local ran = 0
        local i   = self[indexKey] or 1

        while i <= count and ran < limit do
            local t = order[i]
            self[indexKey] = i

            if t and not peggedNames[t.Name] and t.Enabled.Value then
                local parentAllowed = true
                if t.ParentCondition then
                    local parentTask = self.Tasks[t.ParentCondition]
                    parentAllowed = parentTask
                        and parentTask.Enabled.Value
                        and evalCondition(parentTask)
                end

                if parentAllowed then
                    local conditionPassed = evalCondition(t)
                    local intervalPassed  = (now   - t.LastRun      >= t.Interval)
                                        and (frame - t.LastFrameRun >= t.FrameInterval)

                    local before = pegsBefore[t.Name]
                    if before and conditionPassed and intervalPassed then
                        for _, peg in ipairs(before) do
                            if peg and peg.Enabled.Value then
                                tryRun(peg)
                            end
                        end
                    end

                    if conditionPassed and intervalPassed then
                        local didRun, didYield = tryRun(t, true)
                        if didRun then
                            ran = ran + 1

                            if not didYield then
                                local after = pegsAfter[t.Name]
                                if after then
                                    for _, peg in ipairs(after) do
                                        if peg and peg.Enabled.Value then
                                            tryRun(peg)
                                        end
                                    end
                                end
                            end

                            self[indexKey] = i + 1

                            if didYield then
                                return
                            end

                            if isAsync or not t.RunsFast or ran >= limit then
                                return
                            end
                        end
                    end
                end
            end

            i = i + 1
        end

        self[indexKey] = 1
    end

    function LC:Step()
        if self:IsSyncPaused() then return end
        self.Frame = self.Frame + 1
        runList(self, self.Order, self.Count, self.Frame, false, "SyncIndex")
    end

    function LC:StepAsync()
        if self:IsAsyncPaused() then return end
        self.AsyncFrame = self.AsyncFrame + 1
        runList(self, self.AsyncOrder, self.AsyncCount, self.AsyncFrame, true, "AsyncIndex")
    end

    local function CreatePauseHandle(targets, force)
        local handle = { Targets = targets, Forced = false }

        if targets.Sync  then LC:_pauseInc(true,  false) end
        if targets.Async then LC:_pauseInc(false, true)  end

        function handle:Resume()
            if targets.Sync  then LC:_pauseDec(true,  false) end
            if targets.Async then LC:_pauseDec(false, true)  end
        end

        function handle:WaitForPause(options)
            local skipIfForced = options and options.skipIfForced
            if skipIfForced and self.Forced then return self end

            local timeout = options and options.timeout
            local start   = os.clock()
            local spinCount = 0

            while true do
                LC:_reapDeadExecutions()

                local allDone = true
                for _, exec in pairs(LC.ActiveExecutions) do
                    if not exec.Done then
                        local isSyncExec  = not exec.Task.Async
                        local isAsyncExec =     exec.Task.Async
                        if (self.Targets.Sync  and isSyncExec) or
                           (self.Targets.Async and isAsyncExec) then
                            allDone = false
                            break
                        end
                    end
                end

                if allDone then break end
                if timeout and os.clock() - start > timeout then return false end

                spinCount = spinCount + 1
                if spinCount % 200 == 0 then
                    RTask.wait()
                else
                    smallSpin()
                end
            end

            return self
        end

        function handle:Force()
            self.Forced = true

            for _, exec in pairs(LC.ActiveExecutions) do
                local isSyncExec  = not exec.Task.Async
                local isAsyncExec =     exec.Task.Async
                if (self.Targets.Sync  and isSyncExec) or
                   (self.Targets.Async and isAsyncExec) then
                    exec:Cancel()
                end
            end

            LC:_reapDeadExecutions()
            return self
        end

        if force then handle:Force() end

        return handle
    end

    function LC:PauseAll(force)   return CreatePauseHandle({Sync = true, Async = true}, force) end
    function LC:PauseSync(force)  return CreatePauseHandle({Sync = true},               force) end
    function LC:PauseAsync(force) return CreatePauseHandle({Async = true},              force) end

    function LC:Pause(...)
        local targets = {}
        for _, v in ipairs({...}) do
            if type(v) == "string" then
                local lo = v:lower()
                if lo == "sync"  then targets.Sync  = true end
                if lo == "async" then targets.Async = true end
            end
        end
        return CreatePauseHandle(targets, false)
    end

    function LC:Resume(startPriority)
        if startPriority and type(startPriority) == "number" then
            self.SyncIndex  = startPriority
            self.AsyncIndex = startPriority
        end
        self._syncPauseRefs  = 0
        self._asyncPauseRefs = 0
    end

    function LC:Restart()
        self.SyncIndex       = 1
        self.AsyncIndex      = 1
        self._syncPauseRefs  = 0
        self._asyncPauseRefs = 0
    end

    function LC:WaitForRemoval(name, timeout)
        local start = os.clock()
        local spinCount = 0
        while self.Tasks[name] do
            if timeout and os.clock() - start > timeout then return false end
            spinCount = spinCount + 1
            if spinCount % 200 == 0 then
                RTask.wait()
            else
                smallSpin()
            end
        end
        return true
    end

    function LC:WaitForTask(name, timeout)
        warn("[LoopController] WaitForTask is deprecated — use WaitForRemoval (waits for removal, not execution)")
        return self:WaitForRemoval(name, timeout)
    end

    function LC:IsEnabled(t)
        if type(t) == "table"  then return t.Enabled.Value end
        if type(t) == "string" then
            local tk = self.Tasks[t]
            if tk then return tk.Enabled.Value end
        end
        return false
    end

    function LC:Set(name, state)
        local t = self.Tasks[name]
        if t then
            if type(t.Enabled) == "table" and type(t.Enabled.Set) == "function" then
                t.Enabled:Set(state)
            else
                t.Enabled.Value = state
            end
        end
    end

    function LC:GetTask(name)    return self.Tasks[name] end

    function LC:GetTempTasks()
        local temps = {}
        for name, t in pairs(self.TempTasks) do temps[name] = t end
        return temps
    end

    function LC:SetMaxExecutions(n)
        self:SetHeartbeatMaxExecutions(n)
        self:SetWhileMaxExecutions(n)
    end

    function LC:SetHeartbeatMaxExecutions(n)
        if n == nil then
            self.HeartbeatMaxExecutions = nil
        elseif type(n) == "number" then
            self.HeartbeatMaxExecutions = math.max(0, math.floor(n))
        end
    end
    LC.SetHBMaxExecutions = LC.SetHeartbeatMaxExecutions
    LC.SetHbMaxExecutions = LC.SetHeartbeatMaxExecutions

    function LC:SetWhileMaxExecutions(n)
        if n == nil then
            self.WhileMaxExecutions = nil
        elseif type(n) == "number" then
            self.WhileMaxExecutions = math.max(0, math.floor(n))
        end
    end

    local function resolveSignal(sig)
        if typeof(sig) == "RBXScriptSignal" then
            return sig
        elseif type(sig) == "string" then
            local ok, svcSignal = pcall(function() return RunService[sig] end)
            if ok and typeof(svcSignal) == "RBXScriptSignal" then
                return svcSignal
            end
        end
        return nil
    end

    local function removeFromList(list, value)
        for i = #list, 1, -1 do
            if list[i] == value then
                table.remove(list, i)
                return
            end
        end
    end

    function LC.On(sig, fn)
        local signal = resolveSignal(sig)
        if not signal then
            warn("[LoopController] On: could not resolve signal '" .. tostring(sig) .. "'")
            return nil
        end

        local conn = signal:Connect(function(...)
            RTask.spawn(fn, ...)
        end)

        table.insert(LC._extraConnections, conn)
        return conn
    end

    function LC.Once(sig, fn)
        local signal = resolveSignal(sig)
        if not signal then
            warn("[LoopController] Once: could not resolve signal '" .. tostring(sig) .. "'")
            return nil
        end

        local conn
        conn = signal:Connect(function(...)
            if conn then
                conn:Disconnect()
                removeFromList(LC._extraConnections, conn)
            end
            RTask.spawn(fn, ...)
        end)

        table.insert(LC._extraConnections, conn)
        return conn
    end

    function LC.Every(intervalSeconds, fn)
        local active = true
        local handle = { Active = true }

        local thread = RTask.spawn(function()
            while active and not LC._destroyed do
                RTask.wait(intervalSeconds)
                if not active or LC._destroyed then break end
                RTask.spawn(fn)
            end
        end)

        handle.Thread = thread
        function handle:Cancel()
            if not self.Active then return end
            self.Active = false
            active = false
            if self.Thread then
                pcall(RTask.cancel, self.Thread)
                self.Thread = nil
            end
            removeFromList(LC._extraThreads, self)
        end

        table.insert(LC._extraThreads, handle)
        return handle
    end

    function LC.Delay(delaySeconds, fn)
        local handle = { Active = true }

        local thread = RTask.delay(delaySeconds, function()
            if not handle.Active or LC._destroyed then return end
            handle.Active = false
            removeFromList(LC._extraThreads, handle)
            fn()
        end)

        handle.Thread = thread
        function handle:Cancel()
            if not self.Active then return end
            self.Active = false
            if self.Thread then
                pcall(RTask.cancel, self.Thread)
                self.Thread = nil
            end
            removeFromList(LC._extraThreads, self)
        end

        table.insert(LC._extraThreads, handle)
        return handle
    end

    function LC:Destroy()
        for _, exec in pairs(self.ActiveExecutions) do
            exec:Cancel()
        end
        self.ActiveExecutions = {}

        for _, conn in pairs(self.Connections) do
            if conn and conn.Disconnect then
                pcall(conn.Disconnect, conn)
            end
        end
        self.Connections = {}

        self.WhileActive     = false
        self._syncPauseRefs  = 0
        self._asyncPauseRefs = 0
        self.Tasks           = {}
        self.Order           = {}
        self.AsyncOrder      = {}
        self.TempTasks       = {}
        self.TempTaskCleanup = {}

        self.RunASAPQueue = {}
        if self._runASAPThread
            and coroutine.status(self._runASAPThread) ~= "dead" then
            pcall(coroutine.close, self._runASAPThread)
        end
        self._runASAPThread   = nil
        self._runASAPActive   = false
        self._runASAPPaused   = false
        self._currentForcedExec = nil

        if self._activeSyncCoroutine
            and coroutine.status(self._activeSyncCoroutine) ~= "dead" then
            pcall(coroutine.close, self._activeSyncCoroutine)
        end
        self._activeSyncCoroutine = nil

        for _, conn in pairs(self._extraConnections) do
            if conn and conn.Disconnect then
                pcall(function() conn:Disconnect() end)
            end
        end
        self._extraConnections = {}

        for _, handle in pairs(self._extraThreads) do
            if type(handle) == "table" and handle.Cancel then
                pcall(handle.Cancel, handle)
            end
        end
        self._extraThreads = {}

        self._destroyed      = true
    end

    function LC:SetLoopMode(mode)
        if self._destroyed then return end

        if mode == nil then
            mode = (self.LoopMode == "Heartbeat") and "while" or "Heartbeat"
        end

        self.LoopMode = mode

        if self.Connections.Main then
            self.Connections.Main:Disconnect()
            self.Connections.Main = nil
        end

        self.WhileActive = false

        if mode == "Heartbeat" then
            self.Connections.Main = RunService.Heartbeat:Connect(function(dt)
                if self._destroyed then return end
                self._estimatedFPS = dt > 0 and (1 / dt) or 60
                if not self.Running then
                    self.Running = true
                    self:Step()
                    self.Running = false
                end
                self:StepAsync()
            end)
        elseif mode == "while" then
            self.WhileActive = true
            RTask.spawn(function()
                while self.WhileActive and not self._destroyed do
                    local dt = RunService.Heartbeat:Wait()
                    self._estimatedFPS = dt > 0 and (1 / dt) or 60
                    if not self.Running then
                        self.Running = true
                        self:Step()
                        self.Running = false
                    end
                    self:StepAsync()
                end
            end)
        end
    end

    LC:SetLoopMode(LC.LoopMode)
end

