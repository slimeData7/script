do
    local function runAutoBuySlots()
        local cfg = CFG.AUTO_BUY_SLOTS
        if not cfg or not cfg.ENABLED then return end
        local maxSlots = cfg.MAX_SLOTS or 6
        local currentSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
        if type(currentSlots) ~= "number" or currentSlots <= 0 then
            currentSlots = PetSlotPrices.BaseMax
        end
        currentSlots = math.floor(currentSlots)
        while currentSlots < maxSlots do
            local price = PetSlotPrices.GetNextPrice(currentSlots)
            if not price then break end
            if getBalance() < price then break end
            Remotes.Pets.RequestPurchasePetSlot:Fire()
            task.wait(0.5)
            local newSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
            if type(newSlots) == "number" and newSlots > currentSlots then
                currentSlots = math.floor(newSlots)
            else
                break
            end
        end
    end

    LC:Add("AutoBuySlots", {
        Async = true,
        Condition = function()
            local cfg = CFG.AUTO_BUY_SLOTS
            if not cfg or not cfg.ENABLED then return false end
            local maxSlots = cfg.MAX_SLOTS or 6
            local currentSlots = LocalPlayer:GetAttribute("MaxEquippedPets") or 0
            return currentSlots < maxSlots
        end,
        Function = runAutoBuySlots,
    })
end

do
    local _eggsDirty       = true
    local _packsDirty      = true
    local _cratesOpenDirty = true
    local _petsDirty       = true

    local function markPetsDirty()
        _petsDirty = true
    end

    local function runAutoOpenEggs()
        local cfg = CFG.AUTO_OPEN_EGGS
        if not cfg or not cfg.ENABLED then return end
        for eggName, wantCount in pairs(cfg) do
            if eggName == "ENABLED" then continue end
            local opened = 0
            while opened < wantCount do
                local tool = getToolFromBackpackByAttr("Egg", eggName)
                if not tool then break end
                if not tool.Parent then continue end
                equipAndActivateTool(tool)
                opened += 1
                task.wait(0.5)
            end
        end
    end

    local function runAutoOpenSeedPacks()
        local cfg = CFG.AUTO_OPEN_SEEDPACKS
        if not cfg or not cfg.ENABLED then return end
        local lastPackOpenTime = 0
        local packServerCooldown = 1.0
        for packName, wantCount in pairs(cfg) do
            if packName == "ENABLED" then continue end
            local opened = 0
            while opened < wantCount do
                local tool = getToolFromBackpackByAttr("SeedPack", packName)
                if not tool then tool = getToolFromBackpackByAttr("PackName", packName) end
                if not tool then break end
                if not tool.Parent then continue end
                local elapsed = os.clock() - lastPackOpenTime
                local waitNeeded = packServerCooldown - elapsed
                if waitNeeded > 0 then task.wait(waitNeeded) end
                local packId = tool:GetAttribute("PackId") or tool:GetAttribute("Id") or tool:GetAttribute("UUID")
                if not packId then break end
                local ok, result = pcall(function()
                    return Remotes.SeedPack.OpenSeedPack:InvokeServer(packId)
                end)
                lastPackOpenTime = os.clock()
                if ok then
                    opened += 1
                    if type(result) == "table" then
                        local sw = result.Cooldown or result.WaitTime or result.NextOpen or result.Timer
                        if type(sw) == "number" and sw > 0 then
                            packServerCooldown = sw
                        end
                    end
                else
                    task.wait(1)
                end
            end
        end
    end

    local function runAutoOpenCrates()
        local cfg = CFG.AUTO_OPEN_CRATES
        if not cfg or not cfg.ENABLED then return end
        for crateName, wantCount in pairs(cfg) do
            if crateName == "ENABLED" then continue end
            local opened = 0
            while opened < wantCount do
                local tool = getToolFromBackpackByAttr("Crate", crateName)
                if not tool then break end
                if not tool.Parent then continue end
                equipAndActivateTool(tool)
                opened += 1
                task.wait(0.5)
            end
        end
    end

    local function syncPets()
        local cfg = CFG.AUTO_EQUIP_PETS
        if not cfg or not cfg.ENABLED then return end
        local desired = getDesiredPets()
        local desiredNames = {}
        for _, pet in ipairs(desired) do
            desiredNames[pet.Name] = pet
        end
        for petName in pairs(equippedCache) do
            if not desiredNames[petName] then
                Remotes.Pets.RequestUnequipByName:Fire(petName)
                task.wait(0.25)
            end
        end
        for _, pet in ipairs(desired) do
            if not equippedCache[pet.Name] then
                if equipPetByName(pet.Name) then
                    equippedCache[pet.Name] = { Name = pet.Name }
                end
                task.wait(0.25)
            end
        end
    end

    LC.On(Backpack.ChildAdded, function()
        task.wait()
        _eggsDirty = true
        _packsDirty = true
        _cratesOpenDirty = true
        markPetsDirty()
    end)
    

    table.insert(LC._extraConnections,
        Remotes.Pets.PetEquipped.OnClientEvent:Connect(function(petName, petData)
            if type(petName) ~= "string" then return end
            equippedCache[petName] = petData or {}
            markPetsDirty()
        end)
    )
    
    table.insert(LC._extraConnections,
        Remotes.Pets.PetUnequipped.OnClientEvent:Connect(function(petName)
            if type(petName) ~= "string" then return end
            equippedCache[petName] = nil
        end)
    )

    LC.On(LocalPlayer.CharacterAdded, function(char)
        char:WaitForChild("Humanoid")
        task.wait(0.5)
        refreshEquippedCache()
        markPetsDirty()
    end)

    task.spawn(refreshEquippedCache)

    LC.Every(45, function()
        local cfg = CFG.AUTO_EQUIP_PETS
        if cfg and cfg.ENABLED then
            refreshEquippedCache()
            markPetsDirty()
        end
    end)

    LC:Add("AutoOpenEggs", {
        Condition = function()
            local cfg = CFG.AUTO_OPEN_EGGS
            return _eggsDirty and cfg ~= nil and cfg.ENABLED and playerAlive()
        end,
        Function = function()
            _eggsDirty = false
            runAutoOpenEggs()
        end,
    })

    LC:Add("AutoOpenSeedPacks", {
        Condition = function()
            local cfg = CFG.AUTO_OPEN_SEEDPACKS
            return _packsDirty and cfg ~= nil and cfg.ENABLED and playerAlive()
        end,
        Function = function()
            _packsDirty = false
            runAutoOpenSeedPacks()
        end,
    })

    LC:Add("AutoOpenCrates", {
        Condition = function()
            local cfg = CFG.AUTO_OPEN_CRATES
            return _cratesOpenDirty and cfg ~= nil and cfg.ENABLED and playerAlive()
        end,
        Function = function()
            _cratesOpenDirty = false
            runAutoOpenCrates()
        end,
    })

    LC:Add("AutoEquipPets", {
        Async = true,
        Condition = function()
            local cfg = CFG.AUTO_EQUIP_PETS
            return _petsDirty and cfg ~= nil and cfg.ENABLED and playerAlive()
        end,
        Function = function()
            _petsDirty = false
            syncPets()
        end,
    })
end

do
    local function tryBuyPet(refPart)
        local cfg = CFG.AUTO_BUY_PETS
        if not cfg or not cfg.ENABLED then return end
        if not claimGuid(refPart) then return end
    
        local petName = refPart:GetAttribute("PetName")
        local data = petName and PetData[petName]
        if not data then return end
        if not shouldBuyPet(data) then return end
    
        local price = refPart:GetAttribute("Price") or data.BasePrice
        if not price or getBalance() < price then return end
    
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
    
        local oneIn = calcOneIn(data.SpawnChance)
    
        teleport(refPart.Position + Vector3.new(0, 3, 0))
        if not refPart.Parent then return end
        teleport(refPart.Position + Vector3.new(0, 3, 0))
    
        Remotes.Pets.WildPetTame:Fire(refPart)
        task.spawn(sendPetWebhook, data, price, oneIn)
    end

    if wildPetRef then
        for _, refPart in ipairs(wildPetRef:GetChildren()) do
            LC:AddTemp("WildPet_" .. refPart.Name, {
                RunASAP = true,
                Function = function() tryBuyPet(refPart) end,
            })
        end
    
        table.insert(LC._extraConnections,
            wildPetRef.ChildAdded:Connect(function(refPart)
                LC:AddTemp(("WildPet_%s_%d"):format(refPart.Name, os.clock() * 1000), {
                    RunASAP = true,
                    Function = function() tryBuyPet(refPart) end,
                })
            end)
        )
    end
end

do 
    local _fruitCountAll    = 0
    local _fruitCountNonFav = 0
    local _seedInventory    = {}
    local _bpConns          = {}
    
    local function _isFruit(t)
        return t:GetAttribute("Fruit") ~= nil and t:GetAttribute("FruitName") ~= nil
    end
    
    local function _isSeed(t)
        return t:IsA("Tool") and t:GetAttribute("SeedTool") ~= nil
    end
    
    local function _onToolAdded(tool)
        if _isFruit(tool) then
            _fruitCountAll += 1
            if tool:GetAttribute("IsFavorite") ~= true then
                _fruitCountNonFav += 1
            end
        end
        if _isSeed(tool) then
            local name = tool:GetAttribute("SeedTool")
            local list = _seedInventory[name]
            if not list then list = {}; _seedInventory[name] = list end
            list[#list + 1] = tool
        end
    end
    
    local function _onToolRemoved(tool)
        if _isFruit(tool) then
            _fruitCountAll    = math.max(0, _fruitCountAll - 1)
            if tool:GetAttribute("IsFavorite") ~= true then
                _fruitCountNonFav = math.max(0, _fruitCountNonFav - 1)
            end
        end
        if _isSeed(tool) then
            local name = tool:GetAttribute("SeedTool")
            local list = _seedInventory[name]
            if list then
                local i = table.find(list, tool)
                if i then
                    list[i]      = list[#list]
                    list[#list]  = nil
                end
                if #list == 0 then _seedInventory[name] = nil end
            end
        end
    end
    
    local function _setupBackpack(bp)
        for _, c in _bpConns do c:Disconnect() end
        _bpConns = {}
        _fruitCountAll, _fruitCountNonFav, _seedInventory = 0, 0, {}
    
        for _, t in bp:GetChildren() do _onToolAdded(t) end
        _bpConns[1] = bp.ChildAdded:Connect(_onToolAdded)
        _bpConns[2] = bp.ChildRemoved:Connect(_onToolRemoved)
    end
    
    do
        local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
        if bp then _setupBackpack(bp) end
        LocalPlayer.ChildAdded:Connect(function(c)
            if c:IsA("Backpack") then _setupBackpack(c) end
        end)
    end
    
    local function getFruitCount(ignoreFavs)
        return ignoreFavs and _fruitCountNonFav or _fruitCountAll
    end
    
    local GARDEN_TTL      = 2
    local _gardenDirty    = true
    local _lastGardenPoll = 0
    local _plantCounts    = {}
    local _harvestTargets = {}
    
    local function _rebuildGardenCache()
        if not GardenSyncCtrl then return end
        local garden = GardenSyncCtrl:GetGarden(userId)
        if not garden then return end
    
        _plantCounts    = {}
        _harvestTargets = {}
    
        local cfg      = getgenv().CONFIG.AUTOHARVEST
        local doHarvest = cfg and cfg.ENABLED
    
        for plantId, p in garden do
            local name = p.PlantName
            if name then
                _plantCounts[name] = (_plantCounts[name] or 0) + 1
            end
            if doHarvest then
                if p.Fruits then
                    for fruitId, f in p.Fruits do
                        if checkFruitCollect(cfg, f.Mutation, f.Variant, f.Age or 0, f.MaxAge or 0) then
                            local ht = _harvestTargets
                            ht[#ht + 1] = { plantId = plantId, fruitId = fruitId }
                        end
                    end
                else
                    if checkFruitCollect(cfg, p.Mutation, p.Variant, p.Age or 0, p.MaxAge or 0) then
                        local ht = _harvestTargets
                        ht[#ht + 1] = { plantId = plantId, fruitId = "" }
                    end
                end
            end
        end
    
        _gardenDirty = false
    end
    
    local function tickGarden()
        local now = os.clock()
        if _gardenDirty or now - _lastGardenPoll >= GARDEN_TTL then
            _lastGardenPoll = now
            _rebuildGardenCache()
        end
    end
    
    local function markGardenDirty() _gardenDirty = true end
    
    local _plantAreaParams = nil
    local _plantsParams    = nil
    
    local function _buildPlantAreaParams()
        local tagged = CollectionService:GetTagged("PlantArea")
        _plantAreaParams = RaycastParams.new()
        _plantAreaParams.FilterType = Enum.RaycastFilterType.Include
        _plantAreaParams.FilterDescendantsInstances = tagged
    
        CollectionService:GetInstanceAddedSignal("PlantArea"):Connect(function(inst)
            local arr = _plantAreaParams.FilterDescendantsInstances
            arr[#arr + 1] = inst
            _plantAreaParams.FilterDescendantsInstances = arr
        end)
    end
    
    local function _buildPlantsParams()
        local gardens = workspace:FindFirstChild("Gardens")
        if not gardens then return end
    
        local folders = {}
        for _, plot in gardens:GetChildren() do
            local f = plot:FindFirstChild("Plants")
            if f then folders[#folders + 1] = f end
        end
    
        _plantsParams = RaycastParams.new()
        _plantsParams.FilterType = Enum.RaycastFilterType.Include
        _plantsParams.FilterDescendantsInstances = folders
    
        gardens.ChildAdded:Connect(function(plot)
            local f = plot:FindFirstChild("Plants")
            if not f then
                local conn
                conn = plot.ChildAdded:Connect(function(child)
                    if child.Name == "Plants" then
                        conn:Disconnect()
                        local arr = _plantsParams.FilterDescendantsInstances
                        arr[#arr + 1] = child
                        _plantsParams.FilterDescendantsInstances = arr
                    end
                end)
            else
                local arr = _plantsParams.FilterDescendantsInstances
                arr[#arr + 1] = f
                _plantsParams.FilterDescendantsInstances = arr
            end
        end)
    end
    
    local function _ensureStaticParams()
        if not _plantAreaParams then _buildPlantAreaParams() end
        if not _plantsParams    then _buildPlantsParams()    end
    end
    
    local DENSITY_CELL = 5
    
    local _densGrid = {}
    local _occGrid  = {}
    
    local function _dk(x, z)
        return math.floor(x / DENSITY_CELL) .. "," .. math.floor(z / DENSITY_CELL)
    end
    
    local function _ok(x, z)
        return math.floor(x + 0.5) .. "," .. math.floor(z + 0.5)
    end
    
    local function _densAdd(pos)
        local k = _dk(pos.X, pos.Z)
        _densGrid[k] = (_densGrid[k] or 0) + 1
    end
    
    local function _densRemove(pos)
        local k = _dk(pos.X, pos.Z)
        local v = (_densGrid[k] or 1) - 1
        _densGrid[k] = v > 0 and v or nil
    end
    
    local function densityAt(pos)
        local cx = math.floor(pos.X / DENSITY_CELL)
        local cz = math.floor(pos.Z / DENSITY_CELL)
        local s  = 0
        for dx = -1, 1 do
            for dz = -1, 1 do
                s += _densGrid[(cx + dx) .. "," .. (cz + dz)] or 0
            end
        end
        return s
    end
    
    local function _occMark(pos)   _occGrid[_ok(pos.X, pos.Z)] = true  end
    local function _occClear(pos)  _occGrid[_ok(pos.X, pos.Z)] = nil   end
    
    local function isOccupied(pos)
        local cx = math.floor(pos.X + 0.5)
        local cz = math.floor(pos.Z + 0.5)
        for dx = -1, 1 do
            for dz = -1, 1 do
                if _occGrid[(cx + dx) .. "," .. (cz + dz)] then return true end
            end
        end
        return false
    end
    
    local _pfConns       = {}
    local _candidDirty   = true
    
    local function _plantPos(child)
        if child:IsA("Model") then
            local pp = child.PrimaryPart
            return pp and child:GetPivot().Position
        elseif child:IsA("BasePart") then
            return child.Position
        end
    end
    
    local function _onPlantAdded(child)
        local pos = _plantPos(child)
        if not pos then
            task.defer(function()
                if not child.Parent then return end
                local p = _plantPos(child)
                if p then
                    _densAdd(p); _occMark(p)
                    _candidDirty = true
                end
            end)
            return
        end
        _densAdd(pos); _occMark(pos)
        _candidDirty = true
    end
    
    local function _onPlantRemoved(child)
        local pos = _plantPos(child)
        if pos then
            _densRemove(pos); _occClear(pos)
            _candidDirty = true
            markGardenDirty()
        end
    end
    
    local function _watchPlantsFolder(folder)
        for _, c in _pfConns do c:Disconnect() end
        _pfConns    = {}
        _densGrid   = {}
        _occGrid    = {}
        _candidDirty = true
    
        for _, child in folder:GetChildren() do
            local pos = _plantPos(child)
            if pos then _densAdd(pos); _occMark(pos) end
        end
    
        _pfConns[1] = folder.ChildAdded:Connect(_onPlantAdded)
        _pfConns[2] = folder.ChildRemoved:Connect(_onPlantRemoved)
    end
    
    local _candidates    = {}
    local _candidSorted  = {}
    local _cachedPlotId  = nil
    local _cachedPlot    = nil
    local _cachedIgnPos  = nil
    local _cachedPF      = nil
    
    local function _precomputeCandidates(plot, ignorePos)
        _candidates  = {}
        _candidDirty = true
    
        local plantAreas = {}
        for _, part in CollectionService:GetTagged("PlantArea") do
            if part:IsDescendantOf(plot) then
                plantAreas[#plantAreas + 1] = part
            end
        end
        if #plantAreas == 0 then
            warn("[AutoPlant] no PlantArea parts found in plot omg :(")
            return
        end
    
        local hasFolders = _plantsParams ~= nil
            and #(_plantsParams.FilterDescendantsInstances) > 0
    
        for _, area in plantAreas do
            local ap   = area.Position
            local as   = area.Size
            local stX  = math.max(1, math.floor(as.X / 2))
            local stZ  = math.max(1, math.floor(as.Z / 2))
    
            for ix = 0, stX do
                for iz = 0, stZ do
                    local ox  = ((ix / stX) - 0.5) * as.X * 0.85
                    local oz  = ((iz / stZ) - 0.5) * as.Z * 0.85
                    local org = Vector3.new(ap.X + ox, ap.Y + 50, ap.Z + oz)
                    local hit = workspace:Raycast(org, Vector3.new(0, -100, 0), _plantAreaParams)
    
                    if hit and hit.Instance:IsDescendantOf(plot) then
                        local plantPos = hit.Position
                        local blocked  = false
    
                        if not ignorePos and hasFolders then
                            local eHit = workspace:Raycast(
                                plantPos + Vector3.new(0, 50, 0),
                                Vector3.new(0, -100, 0),
                                _plantsParams
                            )
                            if eHit then
                                local d = (Vector2.new(eHit.Position.X, eHit.Position.Z)
                                    - Vector2.new(plantPos.X, plantPos.Z)).Magnitude
                                if d < 1 then blocked = true end
                            end
                        end
    
                        if not blocked then
                            _candidates[#_candidates + 1] = plantPos
                        end
                    end
                end
            end
        end
    end
    
    local function getSortedCandidates()
        if not _candidDirty then return _candidSorted end
    
        local n      = #_candidates
        local scored = table.create(n)
        for i = 1, n do
            scored[i] = { idx = i, score = densityAt(_candidates[i]) }
        end
        table.sort(scored, function(a, b) return a.score > b.score end)
        _candidSorted = scored
        _candidDirty  = false
        return scored
    end
    
    local function _ensurePlotCache(plotId, plot, ignorePos)
        if _cachedPlotId == plotId
            and _cachedPlot  == plot
            and _cachedIgnPos == ignorePos
        then return end
    
        _cachedPlotId  = plotId
        _cachedPlot    = plot
        _cachedIgnPos  = ignorePos
    
        local pf = plot:FindFirstChild("Plants")
        if pf and pf ~= _cachedPF then
            _cachedPF = pf
            _watchPlantsFolder(pf)
        end
    
        _precomputeCandidates(plot, ignorePos)
    end
    
    do
        local _cfg = getgenv().CONFIG.AUTOHARVEST

        LC:Add("AutoHarvest", {
            
            Condition = function()
                if not _cfg or not _cfg.ENABLED then return false end
                if not playerAlive() or not GardenSyncCtrl then return false end
                if getFruitCount(true) >= 100 then return false end

                tickGarden()
                return #_harvestTargets > 0
            end,
            Function = function()
                local collectFruit = Remotes.Garden.CollectFruit
                if not collectFruit then return end
                if #_harvestTargets == 0 then return end

                teleport("Garden")

                local fire       = collectFruit.Fire
                local fruitCount = getFruitCount(true)
                local collected  = 0

                for i = 1, #_harvestTargets do
                    local t = _harvestTargets[i]
                    fire(collectFruit, t.plantId, t.fruitId)
                    fruitCount += 1
                    collected  += 1
                    if fruitCount >= 90 then break end
                end

                if collected > 0 then markGardenDirty() end
            end,
        })
    end
    
    do
        local _cfg       = getgenv().CONFIG.AUTOPLANT
        local _seedTools = {}
    
        local function buildSeedToolList()
            local tools = {}
            for name, toolList in _seedInventory do
                if table.find(_cfg.IGNORE, name) then continue end
                local maxAllowed = _cfg.PLANTS[name] or _cfg.PLANTS["All"]
                if not maxAllowed then continue end
    
                local current   = _plantCounts[name] or 0
                local remaining = maxAllowed - current
                if remaining <= 0 then continue end
    
                for _, tool in toolList do
                    if remaining <= 0 then break end
                    local stack  = tool:GetAttribute("Count") or 1
                    local useAmt = math.min(stack, remaining)
                    if useAmt > 0 then
                        tools[#tools + 1] = { tool = tool, amount = useAmt }
                        remaining -= useAmt
                    end
                end
            end
            return tools
        end

        LC:Add("AutoPlant", {
            Condition = function()
                if not _cfg or not _cfg.ENABLED then return false end
                if not playerAlive() then return false end
                if not LocalPlayer:FindFirstChildOfClass("Backpack") then return false end
                tickGarden()
                _seedTools = buildSeedToolList()
                return #_seedTools > 0
            end,
            Function = function()
                local ignorePos = _cfg.IGNOREPOSITION == true

                local plotId = LocalPlayer:GetAttribute("PlotId")
                if not plotId then return end
                local gardens = workspace:FindFirstChild("Gardens")
                local plot    = gardens and gardens:FindFirstChild("Plot" .. plotId)
                if not plot then return end

                local char = LocalPlayer.Character
                if not char then return end
                local hrp      = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                if not hrp or not humanoid then return end

                _ensureStaticParams()
                _ensurePlotCache(plotId, plot, ignorePos)

                if #_candidates == 0 then
                    return
                end

                local sorted  = getSortedCandidates()
                local sortIdx = 1

                local function nextSpot()
                    while sortIdx <= #sorted do
                        local pos = _candidates[sorted[sortIdx].idx]
                        sortIdx += 1
                        if not isOccupied(pos) then return pos end
                    end
                    return nil
                end

                local function tryEquip(tool)
                    if not tool or not tool.Parent then
                        return false
                    end
                
                    humanoid:EquipTool(tool)
                
                    local deadline = os.clock() + 0.25
                
                    repeat
                        local eq = char:FindFirstChildWhichIsA("Tool")
                
                        if eq and eq:GetAttribute("SeedTool") ~= nil then
                            return true
                        end
                    until os.clock() > deadline
                
                    return false
                end

                local placed = 0

                local function _doPlanting()
                    for _, entry in _seedTools do
                        local seedTool = entry.tool
                        local count    = entry.amount
                        if count <= 0 then continue end
                
                        if not tryEquip(seedTool) then
                            warn("[AutoPlant] failed to equip", seedTool.Name, "— skipping :(")
                            continue
                        end
                
                        local toolNow = char:FindFirstChildWhichIsA("Tool")
                        if not toolNow or not toolNow:GetAttribute("SeedTool") then
                            warn("[AutoPlant] seed tool not in hand after equip — skipping")
                            continue
                        end
                
                        for _ = 1, count do
                            local spot = nextSpot()
                            if not spot then
                                return
                            end
                
                            toolNow = char:FindFirstChildWhichIsA("Tool")
                            if not toolNow or not toolNow:GetAttribute("SeedTool") then
                                if not tryEquip(seedTool) then break end
                                toolNow = char:FindFirstChildWhichIsA("Tool")
                                if not toolNow then break end
                            end
                
                            teleport(CFrame.new(spot + Vector3.new(0, 3, 0)))
                            Remotes.Plant.PlantSeed:Fire(spot, toolNow:GetAttribute("SeedTool"), toolNow)
                
                            _occMark(spot)
                            _densAdd(spot)
                            _candidDirty = true
                            placed += 1
                        end
                    end
                end
                _doPlanting()
                if placed > 0 then markGardenDirty() end
            end,
        })
    end
end

do
    local _fruitReg       = {}
    local _fruitConns     = {}
    local _sellValueCache = {}

    local _favQueue     = {}
    local _favQueueSwap = {}
    local _sellSet      = {}

    local SELL_MISS = {}

    local function _getCachedSellValue(tool)
        local v = _sellValueCache[tool]
        if v ~= nil then
            return v ~= SELL_MISS and v or nil
        end
        local r = _fruitReg[tool]
        if not r then return nil end
        local computed = FruitValueCalc(
            r.name,
            tool:GetAttribute("SizeMultiplier") or 1,
            r.mutation,
            LocalPlayer,
            tool:GetAttribute("DecayAlpha")
        )
        _sellValueCache[tool] = computed ~= nil and computed or SELL_MISS
        return computed
    end

    local function _markFavDirty(tool, rec)
        if not rec.isFavorite then
            _favQueue[tool] = true
        end
    end

    local function _registerFruit(tool)
        if _fruitReg[tool] then return end

        local isFav = tool:GetAttribute("IsFavorite") == true
        local rec = {
            id         = tool:GetAttribute("Id"),
            name       = tool:GetAttribute("FruitName"),
            mutation   = tool:GetAttribute("Mutation"),
            weight     = tool:GetAttribute("Weight"),
            isFavorite = isFav,
        }
        _fruitReg[tool] = rec

        if not isFav then
            _favQueue[tool] = true
            _sellSet[tool]  = true
        end

        local conns = table.create(5)
        _fruitConns[tool] = conns

        conns[1] = tool:GetAttributeChangedSignal("IsFavorite"):Connect(function()
            local fav = tool:GetAttribute("IsFavorite") == true
            rec.isFavorite = fav
            if fav then
                _favQueue[tool]     = nil
                _favQueueSwap[tool] = nil
                _sellSet[tool]      = nil
            else
                _favQueue[tool] = true
                _sellSet[tool]  = true
            end
        end)

        conns[2] = tool:GetAttributeChangedSignal("Mutation"):Connect(function()
            rec.mutation          = tool:GetAttribute("Mutation")
            _sellValueCache[tool] = nil
            _markFavDirty(tool, rec)
        end)

        conns[3] = tool:GetAttributeChangedSignal("Weight"):Connect(function()
            rec.weight = tool:GetAttribute("Weight")
            _markFavDirty(tool, rec)
        end)

        conns[4] = tool:GetAttributeChangedSignal("SizeMultiplier"):Connect(function()
            _sellValueCache[tool] = nil
            _markFavDirty(tool, rec)
        end)

        conns[5] = tool:GetAttributeChangedSignal("DecayAlpha"):Connect(function()
            _sellValueCache[tool] = nil
            _markFavDirty(tool, rec)
        end)
    end

    local function _unregisterFruit(tool)
        local conns = _fruitConns[tool]
        if not conns then return end

        for _, c in conns do c:Disconnect() end
        _fruitConns[tool]     = nil
        _fruitReg[tool]       = nil
        _favQueue[tool]       = nil
        _favQueueSwap[tool]   = nil
        _sellSet[tool]        = nil
        _sellValueCache[tool] = nil
    end

    local _bpConns = {}

    local function _setupBackpack(bp)
        for _, c in _bpConns do c:Disconnect() end
        _bpConns = {}

        for _, conns in _fruitConns do
            for _, c in conns do c:Disconnect() end
        end
        table.clear(_fruitReg)
        table.clear(_fruitConns)
        table.clear(_sellValueCache)
        table.clear(_favQueue)
        table.clear(_favQueueSwap)
        table.clear(_sellSet)

        for _, tool in bp:GetChildren() do
            if tool:GetAttribute("Fruit") ~= nil
            and tool:GetAttribute("FruitName") ~= nil then
                _registerFruit(tool)
            end
        end

        _bpConns[1] = bp.ChildAdded:Connect(function(tool)
            if tool:GetAttribute("Fruit") ~= nil
            and tool:GetAttribute("FruitName") ~= nil then
                _registerFruit(tool)
            end
        end)

        _bpConns[2] = bp.ChildRemoved:Connect(_unregisterFruit)
    end

    do
        local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
        if bp then _setupBackpack(bp) end
        LocalPlayer.ChildAdded:Connect(function(c)
            if c:IsA("Backpack") then _setupBackpack(c) end
        end)
    end

    do
        local _favCfg   = nil
        local _mutSet   = {}
        local _lastMuts = nil

        LC:Add("AutoFavorite", {
            Interval = 0.9,

            Condition = function()
                _favCfg = getgenv().CONFIG.AUTOFAVORITE
                if not _favCfg or not _favCfg.ENABLED or not playerAlive() then
                    return false
                end
                return next(_favQueue) ~= nil
            end,

            Function = function()
                local cfg    = _favCfg
                local checks = cfg.CHECKS
                local minW   = cfg.MIN_WEIGHT     or 0
                local minS   = cfg.MIN_SELL_PRICE or 0
                local remote = Remotes.Backpack.SetFruitFavorite

                local muts = cfg.MUTATIONS
                if muts ~= _lastMuts then
                    table.clear(_mutSet)
                    for _, m in muts do _mutSet[m] = true end
                    _lastMuts = muts
                end

                local processing = _favQueue
                _favQueue        = _favQueueSwap
                _favQueueSwap    = processing

                for tool in processing do
                    local rec = _fruitReg[tool]
                    if not rec or rec.isFavorite then continue end

                    local shouldFav = false

                    for _, check in checks do
                        if check == "Mutation" then
                            local mut = rec.mutation
                            if mut and _mutSet[mut] then shouldFav = true end

                        elseif check == "Weight" then
                            local w = rec.weight
                            if w and w >= minW then shouldFav = true end

                        elseif check == "SellPrice" then
                            local sp = _getCachedSellValue(tool)
                            if sp and sp >= minS then shouldFav = true end
                        end

                        if shouldFav then break end
                    end

                    if shouldFav then
                        rec.isFavorite = true
                        tool:SetAttribute("IsFavorite", true)
                        remote:Fire(rec.id, true)
                    end
                end

                table.clear(processing)
            end,
        })

        local _sellCfg    = nil
        local _wanted     = {}
        local _lastFruits = nil

        LC:Add("AutoSell", {
            Interval = 5,

            Condition = function()
                _sellCfg = getgenv().CONFIG.AUTOSELL
                if not _sellCfg or not _sellCfg.ENABLED or not playerAlive() then
                    return false
                end
                return next(_sellSet) ~= nil
            end,

            Function = function()
                local cfg  = _sellCfg
                local mode = cfg.MODE

                if mode == "All" then
                    Remotes.NPCS.SellAll:Fire()
                    task.wait(cfg.DELAY or 0.9)
                    return
                end

                local fruitList = cfg.FRUITS
                if fruitList ~= _lastFruits then
                    table.clear(_wanted)
                    for _, n in fruitList do _wanted[n] = true end
                    _lastFruits = fruitList
                end

                local sellFruit = Remotes.NPCS.SellFruit

                for tool, _ in _sellSet do
                    local rec = _fruitReg[tool]
                    if rec and _wanted[rec.name] then
                        sellFruit:Fire(rec.id)
                    end
                end
            end,
        })
    end
end

do 
    local LP = LocalPlayer
    local GSync = GardenSyncCtrl
    local Remote = Remotes.Place.PlaceSprinkler
    local CS = CollectionService
    local CFG = getgenv().CONFIG.AUTOSPRINKLER

    local RadiusMap = {}
    for _, entry in pairs(SprinklerData) do
        if entry.SprinklerName then
            RadiusMap[entry.SprinklerName] = entry.Radius
        else
            for _, inner in pairs(entry) do
                if inner.SprinklerName then
                    RadiusMap[inner.SprinklerName] = inner.Radius
                end
            end
        end
    end

    local function getPlotInfo()
        local plotId = LP:GetAttribute("PlotId")
        local plot   = workspace.Gardens:FindFirstChild("Plot" .. tostring(plotId))
        return plotId, plot, plot and plot:FindFirstChild("SpawnPoint")
    end

    local function getPlantAreas(plot)
        local out = {}
        for _, p in ipairs(CS:GetTagged("PlantArea")) do
            if p:IsDescendantOf(plot) and p:IsA("BasePart") then
                out[#out + 1] = p
            end
        end
        return out
    end

    local function getPlantPositions(spawnCF)
        local out    = {}
        local garden = GSync:GetGarden(LP.UserId)
        if type(garden) ~= "table" then return out end
        for _, data in pairs(garden) do
            if data.Positions then
                out[#out + 1] = spawnCF:PointToWorldSpace(
                    Vector3.new(data.Positions.PosX, data.Positions.PosY, data.Positions.PosZ)
                )
            end
        end
        return out
    end

    local function buildCandidates(plantAreas, plantPositions)
        local STEP    = 5
        local DR2     = 15 * 15
        local out     = {}

        for _, part in ipairs(plantAreas) do
            local sz  = part.Size
            local cf  = part.CFrame
            local hY  = sz.Y * 0.5
            local hX  = sz.X * 0.5
            local hZ  = sz.Z * 0.5
            local xSt = math.floor(sz.X / STEP)
            local zSt = math.floor(sz.Z / STEP)

            for xi = 0, xSt do
                for zi = 0, zSt do
                    local wp = cf:PointToWorldSpace(Vector3.new(
                        -hX + xi * STEP, hY, -hZ + zi * STEP
                    ))
                    local density = 0
                    local wx, wz  = wp.X, wp.Z
                    for _, pp in ipairs(plantPositions) do
                        local dx = wx - pp.X
                        local dz = wz - pp.Z
                        if dx*dx + dz*dz <= DR2 then
                            density = density + 1
                        end
                    end
                    out[#out + 1] = { Position = wp, Density = density }
                end
            end
        end

        table.sort(out, function(a, b) return a.Density > b.Density end)
        return out
    end

    local function buildSprinklerState(synced, spawnCF)
        local counts   = {}
        local occupied = {}
        for _, s in pairs(synced) do
            local name = s.SprinklerName
            counts[name] = (counts[name] or 0) + 1
            local pos = s.Positions
            if pos and RadiusMap[name] then
                local r = RadiusMap[name]
                occupied[#occupied + 1] = {
                    Pos  = spawnCF:PointToWorldSpace(Vector3.new(pos.PosX, pos.PosY, pos.PosZ)),
                    R2   = r * r,
                    Name = name,
                }
            end
        end
        return counts, occupied
    end

    local function isCovered(occupied, pos, name)
        local px, pz = pos.X, pos.Z
        for _, o in ipairs(occupied) do
            if o.Name == name then
                local dx = o.Pos.X - px
                local dz = o.Pos.Z - pz
                if dx*dx + dz*dz < o.R2 then
                    return true
                end
            end
        end
        return false
    end

    local function batchBackpackTools()
        local map = {}
        for _, tool in ipairs(LP.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local sn = tool:GetAttribute("Sprinkler")
                if sn then
                    local list = map[sn]
                    if list then
                        list[#list + 1] = tool
                    else
                        map[sn] = { tool }
                    end
                end
            end
        end
        return map
    end

    LC:Add("AutoSprinkler", {
        Interval = 1.0,

        Condition = function()
            if not CFG.ENABLED then
                return false
            end
            if not playerAlive() then
                return false
            end

            local synced = GSync:GetSprinklers(LP.UserId) or {}

            local counts = {}
            for _, s in pairs(synced) do
                local n = s.SprinklerName
                counts[n] = (counts[n] or 0) + 1
            end

            for sName, maxCount in pairs(CFG.SPRINKLERS) do
                local foundTool = false
                for _, tool in ipairs(LP.Backpack:GetChildren()) do
                    if tool:IsA("Tool") and tool:GetAttribute("Sprinkler") == sName then
                        foundTool = true
                        if (counts[sName] or 0) < maxCount then
                            return true
                        end
                        break
                    end
                end
            end

            return false
        end,

        Function = function()
            local plotId, plot, spawnPoint = getPlotInfo()
            if not spawnPoint then
                return
            end

            local plotCenter = getgenv().stuffPositions["Garden"]
            if not plotCenter then
                return
            end

            local synced = GSync:GetSprinklers(LP.UserId) or {}

            local existingCounts, occupied = buildSprinklerState(synced, spawnPoint.CFrame)

            local toolMap = batchBackpackTools()

            local sortedTypes = {}
            for sName, maxCount in pairs(CFG.SPRINKLERS) do
                local tools   = toolMap[sName] or {}
                local needed  = maxCount - (existingCounts[sName] or 0)
                local toPlace = math.min(needed, #tools)

                if toPlace > 0 then
                    sortedTypes[#sortedTypes + 1] = {
                        Name    = sName,
                        ToPlace = toPlace,
                        Radius  = RadiusMap[sName] or 0,
                        Tools   = tools,
                    }
                end
            end

            if #sortedTypes == 0 then
                return
            end

            table.sort(sortedTypes, function(a, b) return a.Radius > b.Radius end)

            teleport("Garden")

            local plantAreas = getPlantAreas(plot)
            if #plantAreas == 0 then
                return
            end

            local candidates = buildCandidates(plantAreas, getPlantPositions(spawnPoint.CFrame))
            if #candidates == 0 then
                return
            end

            local char = LP.Character
            for _, st in ipairs(sortedTypes) do
                local placed = 0
                local tools  = st.Tools
                local name   = st.Name
                local r      = st.Radius

                for _, cand in ipairs(candidates) do
                    if placed >= st.ToPlace then
                        break
                    end

                    local covered = isCovered(occupied, cand.Position, name)

                    if not covered then
                        local tool = tools[placed + 1]

                        if tool.Parent ~= char then
                            char.Humanoid:EquipTool(tool)
                        end

                        teleport(cand.Position + Vector3.new(0, 2, 0), 0)
                        Remote:Fire(cand.Position, name, tool, plotId)

                        occupied[#occupied + 1] = {
                            Pos  = cand.Position,
                            R2   = r * r,
                            Name = name,
                        }
                        placed = placed + 1
                    end
                end
            end
        end,
    })
end
