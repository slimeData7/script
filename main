BlockTab:CreateSection("Lucky Block Opener")

BlockTab:CreateToggle({
	Name = "Auto Open Lucky Block",
	CurrentValue = false,
	Flag = "AutoOpenLuckyBlock",
	Callback = function(value)
		Settings.AutoOpenLuckyBlock = value
	end,
})

local BlockDropdown
BlockDropdown = BlockTab:CreateDropdown({
	Name = "Lucky Block Type",
	Options = getAvailableLuckyBlocks(),
	CurrentOption = {},
	Flag = "LuckyBlockTarget",
	Callback = function(option)
		Settings.LuckyBlockTarget = option[1] or ""
	end,
})

task.spawn(function()
	while true do
		task.wait(5)
		BlockDropdown:Refresh(getAvailableLuckyBlocks())
	end
end)

