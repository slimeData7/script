local function applyOptimization()
    pcall(function() settings().Rendering.QualityLevel = 1 end)
    pcall(function()
        Lighting.GlobalShadows   = false
        Lighting.FogEnd          = 9e9
        Lighting.Brightness      = 0
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
    end)
    pcall(function()
        local LODController = workspace:FindFirstChildOfClass("LODController")
        if LODController then LODController.FramesBudget = 0 end
    end)
end

local function teleportToServer(jobId, attempt)
    attempt = attempt or 1
    localStats.status = "Hopping → " .. jobId:sub(1, 8) .. "..."
    dprint("Teleport attempt", attempt, "->", jobId)

    local ok, err = pcall(TeleportService.TeleportToPlaceInstance, TeleportService, placeId, jobId, lp)

    if not ok then
        dprint("Teleport error:", err)
        if Config.RetryFailedTeleport and attempt < Config.MaxTeleportRetries then
            task.wait(2 ^ attempt)
            return teleportToServer(jobId, attempt + 1)
        end
        releaseClaim(jobId)
        markFailed(jobId)
        localStats.totalFailed = localStats.totalFailed + 1
        localStats.status      = "Failed: " .. jobId:sub(1, 8)
        saveAccountStats()
        return false
    end

    markVisited(jobId)
    localStats.totalJoined = localStats.totalJoined + 1
    localStats.status      = "Joined #" .. localStats.totalJoined
    dprint("Teleport dispatched. joined =", localStats.totalJoined)
    saveAccountStats()
    task.wait(10)
    return true
end

local function run()
    print("[ServerHop] Starting — Account:", accountKey, "Mode:", Config.FetchMode)

    buildUI()
    applyOptimization()
    loadAccountStats()
    loadLocalSets()

    markVisited(game.JobId)

    task.wait(math.random(0, 3) + (tonumber(accountKey:sub(-3)) or 0) % 5)

    if Config.SearchForLuck then
        local found = checkAndHandleLuck()
        if found and Config.StopOnLuckServer then
            print("[ServerHop] Luck on current server. Stopped.")
            return
        end
    end

    if shouldRefetch() then refillSharedQueue() end

    while not hopLock do
        if shouldRefetch() then
            refillSharedQueue()
        end

        local q = readJSON(FILE_SHARED_QUEUE)
        localQueueSize = (q and type(q.data) == "table") and #q.data or 0

        if localQueueSize == 0 then
            print("[ServerHop] Queue empty. Stopping.")
            localStats.status = "No servers found"
            break
        end

        local jobId = popFromSharedQueue()
        if not jobId then
            task.wait(1)
            continue
        end

        if not tryClaimServer(jobId) then
            dprint("Claim failed for", jobId, "— already taken")
            task.wait(0.3)
            continue
        end

        local success = teleportToServer(jobId)

        if success then
            task.wait(3)
            if Config.SearchForLuck then checkAndHandleLuck() end
            if hopLock then break end
        end

        task.wait(0.5)
    end

    print("[ServerHop] Session ended.")
    localStats.status = "Session ended"
end

run()
