local function loadLocalSets()
    if not Config.PersistAcrossRejoins then return end
    local sv = readJSON(FILE_SHARED_VISITED)
    if sv and not isStale(sv) then
        local d = sv.data
        if type(d) == "table" then
            for id, v in pairs(d) do
                if id ~= "_ts" then localVisited[id] = v end
            end
        end
    end
    local sf = readJSON(FILE_SHARED_FAILED)
    if sf and not isStale(sf) then
        local d = sf.data
        if type(d) == "table" then
            for id, v in pairs(d) do
                if id ~= "_ts" then localFailed[id] = v end
            end
        end
    end
end

