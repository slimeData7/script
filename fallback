end

local function isVisited(jobId)
    if localVisited[jobId] then return true end
    if not Config.PersistAcrossRejoins then return false end
    local sv = readJSON(FILE_SHARED_VISITED)
    if sv and type(sv.data) == "table" and sv.data[jobId] then
        localVisited[jobId] = sv.data[jobId]
        return true
    end
    return false
end

local function isFailed(jobId)
    if localFailed[jobId] then return true end
    if not Config.PersistAcrossRejoins then return false end
    local sf = readJSON(FILE_SHARED_FAILED)
    if sf and type(sf.data) == "table" and sf.data[jobId] then
        localFailed[jobId] = sf.data[jobId]
        return true
    end
    return false
end

local function tryClaimServer(jobId)
    local claimed = readJSON(FILE_SHARED_CLAIMED)
    local now = ts()
    local data = {}
    if claimed and type(claimed.data) == "table" then
        for id, entry in pairs(claimed.data) do
            if id ~= "_ts" and type(entry) == "table" and (now - (entry.at or 0)) < CLAIM_TTL then
                data[id] = entry
            end
        end
    end
    if data[jobId] then return false end
    data[jobId] = { by = accountKey, at = now }
    writeJSON(FILE_SHARED_CLAIMED, wrap({ data = data }))
    task.wait(0.15)
    local verify = readJSON(FILE_SHARED_CLAIMED)
    if verify and type(verify.data) == "table" then
        local entry = verify.data[jobId]
        if entry and entry.by == accountKey then return true end
    end
    return false
end

local function releaseClaim(jobId)
    local claimed = readJSON(FILE_SHARED_CLAIMED)
    if not claimed or type(claimed.data) ~= "table" then return end
    claimed.data[jobId] = nil
    writeJSON(FILE_SHARED_CLAIMED, wrap({ data = claimed.data }))
end

local function tryAcquireFetchLock()
    local lock = readJSON(FILE_FETCH_LOCK)
    local now = ts()
    if lock and type(lock.holder) == "string" then
        local age = now - (lock.at or 0)
        if age < FETCH_LOCK_TTL then
            dprint("Fetch lock held by", lock.holder, "age", age)
            return false
        end
    end
    writeJSON(FILE_FETCH_LOCK, { holder = accountKey, at = now })
    task.wait(0.2)
    local verify = readJSON(FILE_FETCH_LOCK)
    if verify and verify.holder == accountKey then return true end
    return false
end

local function releaseFetchLock()
    local lock = readJSON(FILE_FETCH_LOCK)
    if lock and lock.holder == accountKey then
        fileDelete(FILE_FETCH_LOCK)
    end
end

local function getSharedQueueSize()
    local q = readJSON(FILE_SHARED_QUEUE)
    if q and type(q.data) == "table" then return #q.data end
    return 0
end

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=100&excludeFullGames=true",
        placeId
    )
    if cursor and cursor ~= "" then url = url .. "&cursor=" .. cursor end
    local res = safeRequest({ Url = url, Method = "GET" })
    if not res or not res.Body then return nil, nil end
    if res.StatusCode == 429 then
        dprint("429 rate limit on fetch")
        task.wait(10)
        return nil, nil
    end
    if res.StatusCode ~= 200 then return nil, nil end
    local d = jdec(res.Body)
    if not d then return nil, nil end
    return d.data, d.nextPageCursor
end

local function fetchServers()
    local collected = {}
    local seen      = {}
    local cursor    = nil
    local pages     = 0
    local maxCount  = MAX_SERVERS_PER_MODE[Config.FetchMode] or 300
    local maxPages  = 1
    if Config.FetchMode == "CursorFetch"   then maxPages = 3  end
    if Config.FetchMode == "AdvancedFetch" then maxPages = 10 end

    local sv = readJSON(FILE_SHARED_VISITED)
    local sf = readJSON(FILE_SHARED_FAILED)
    local sc = readJSON(FILE_SHARED_CLAIMED)
    local sharedVisited = (sv and type(sv.data) == "table") and sv.data or {}
    local sharedFailed  = (sf and type(sf.data) == "table") and sf.data or {}
    local sharedClaimed = (sc and type(sc.data) == "table") and sc.data or {}
    local now = ts()

    repeat
        local servers, nextCursor = fetchPage(cursor)
        if not servers then break end
        for _, server in ipairs(servers) do
            local id = server.id
            if id and not seen[id] then
                seen[id] = true
                local playing    = server.playing    or 0
                local maxPlayers = server.maxPlayers or 0
                local skip = false
                if id == game.JobId                                             then skip = true end
                if playing < Config.MinPlayers                                  then skip = true end
                if playing >= maxPlayers                                         then skip = true end
                if Config.MaxPlayers and playing > Config.MaxPlayers            then skip = true end
                if Config.SkipVisitedServers and sharedVisited[id]              then skip = true end
                if sharedFailed[id]                                             then skip = true end
                if sharedClaimed[id] and (now - (sharedClaimed[id].at or 0)) < CLAIM_TTL then skip = true end
                if not skip then
                    table.insert(collected, id)
                    if #collected >= maxCount then break end
                end
            end
        end
        cursor = nextCursor
        pages  = pages + 1
        if #collected >= maxCount then break end
        if cursor then task.wait(0.5) end
    until not cursor or cursor == "" or pages >= maxPages

    return collected
end

local function refillSharedQueue()
    if not tryAcquireFetchLock() then
        dprint("Another account is fetching. Waiting.")
        local waited = 0
        repeat
            task.wait(2)
            waited = waited + 2
        until getSharedQueueSize() >= 10 or waited >= FETCH_LOCK_TTL
        return
    end

    localStats.status = "Fetching servers..."
    dprint("Acquired fetch lock. Fetching.")

    local newIds = fetchServers()
    dprint("Fetched", #newIds, "servers")

    local existing = readJSON(FILE_SHARED_QUEUE)
    local existingSet = {}
    local merged = {}

    if existing and type(existing.data) == "table" and not isStale(existing) then
        for _, id in ipairs(existing.data) do
            if not existingSet[id] then
                existingSet[id] = true
                table.insert(merged, id)
            end
        end
    end

    for _, id in ipairs(newIds) do
        if not existingSet[id] then
            existingSet[id] = true
            table.insert(merged, id)
        end
    end

    writeJSON(FILE_SHARED_QUEUE, wrap({ data = merged, refetchAt = ts() + QUEUE_REFILL_COOLDOWN }))
    releaseFetchLock()
    localQueueSize = #merged
end

local function popFromSharedQueue()
    local q = readJSON(FILE_SHARED_QUEUE)
    if not q or type(q.data) ~= "table" or #q.data == 0 then return nil end

    local sv = readJSON(FILE_SHARED_VISITED)
    local sf = readJSON(FILE_SHARED_FAILED)
    local sc = readJSON(FILE_SHARED_CLAIMED)
    local sharedVisited = (sv and type(sv.data) == "table") and sv.data or {}
    local sharedFailed  = (sf and type(sf.data) == "table") and sf.data or {}
    local sharedClaimed = (sc and type(sc.data) == "table") and sc.data or {}
    local now = ts()

    local picked = nil
    local remaining = {}

    for _, id in ipairs(q.data) do
        if not picked then
            local skip = false
            if Config.SkipVisitedServers and sharedVisited[id]                          then skip = true end
            if sharedFailed[id]                                                          then skip = true end
            if sharedClaimed[id] and (now - (sharedClaimed[id].at or 0)) < CLAIM_TTL   then skip = true end
            if not skip then
                picked = id
            else
                table.insert(remaining, id)
            end
        else
            table.insert(remaining, id)
        end
    end

    if not picked then return nil end

    writeJSON(FILE_SHARED_QUEUE, wrap({ data = remaining, refetchAt = q.refetchAt }))
    localQueueSize = #remaining
    return picked
end

local function shouldRefetch()
    local q = readJSON(FILE_SHARED_QUEUE)
    if not q then return true end
    if isStale(q) then return true end
    if type(q.data) == "table" and #q.data < 5 then return true end
    if type(q.refetchAt) == "number" and ts() >= q.refetchAt then return true end
    return false
end

local function hasLuckBeenReported(jobId)
    local d = readJSON(FILE_SHARED_LUCK)
    if not d or type(d.data) ~= "table" then return false end
    return d.data[jobId] ~= nil
end

local function markLuckReported(jobId)
    local d = readJSON(FILE_SHARED_LUCK)
    local data = {}
    if d and type(d.data) == "table" then
        for k, v in pairs(d.data) do
            if k ~= "_ts" then data[k] = v end
        end
    end
    data[jobId] = { at = ts() }
    evictOldest(data, MAX_LUCK_SEEN_ENTRIES)
    writeJSON(FILE_SHARED_LUCK, wrap({ data = data }))
end

local function getLuckInfo()
    local ok, LuckLadder = pcall(function()
        return require(ReplicatedStorage.Source.Features.LuckLadder.LuckLadderServiceClient)
    end)
    if not ok or not LuckLadder then return false, nil, nil end
    local active, mult, remaining = false, "N/A", 0
    pcall(function()
        active    = LuckLadder:isActive()
        mult      = LuckLadder:getCurrentMultiplier()
        remaining = LuckLadder:getTimeRemaining()
    end)
    return active, mult, remaining
end

local function formatTime(sec)
    sec = tonumber(sec)
    if not sec or sec <= 0 then return "Ended" end
    return string.format("%02d:%02d", math.floor(sec / 60), math.floor(sec % 60))
end

local function getAssetThumbnail()
    local res = safeRequest({
        Url    = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. ASSET_ID .. "&size=420x420&format=Png&isCircular=false",
        Method = "GET",
    })
    if not res or not res.Body then return nil end
    local d = jdec(res.Body)
    return d and d.data and d.data[1] and d.data[1].imageUrl or nil
end

local function buildEmbed(mult, remaining, jobId, thumb)
    local playerCount = #Players:GetPlayers()
    local maxPlayers  = Players.MaxPlayers
    local joinLink    = string.format("https://www.roblox.com/games/start?placeId=%d&gameInstanceId=%s", placeId, jobId)
    local execCmd     = string.format('game:GetService("TeleportService"):TeleportToPlaceInstance(%d, "%s", game:GetService("Players").LocalPlayer)', placeId, jobId)
    return {
        embeds = {{
            color     = 65280,
            title     = "Luck Server Found 🍀",
            thumbnail = thumb and { url = thumb } or nil,
            fields    = {
                { name = "Active",            value = "true",                                                  inline = true  },
                { name = "Multiplier",        value = tostring(mult),                                          inline = true  },
                { name = "Time Remaining",    value = formatTime(remaining),                                   inline = true  },
                { name = "Players",           value = tostring(playerCount) .. " / " .. tostring(maxPlayers), inline = true  },
                { name = "Click to Join",     value = "[Join Server](" .. joinLink .. ")",                     inline = true  },
                { name = "Paste in Executor", value = "```\n" .. execCmd .. "\n```",                           inline = false },
            },
            footer = { text = FOOTER_TEXT },
        }}
    }
end

local function fireWebhook(url, payload)
    if not url or url == "" then return end
    local body = jenc(payload)
    if not body then return end
    safeRequest({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
end

local function sendLuckWebhook(mult, remaining, jobId)
    if hasLuckBeenReported(jobId) then
        dprint("Luck already reported for", jobId)
        return
    end
    markLuckReported(jobId)
    local thumb = getAssetThumbnail()
    local payload = buildEmbed(mult, remaining, jobId, thumb)
    fireWebhook(PUBLIC_WEBHOOK, payload)
    if Config.LuckWebhook and Config.LuckWebhook ~= "" then
        local priv = buildEmbed(mult, remaining, jobId, thumb)
        if Config.UserId and Config.UserId ~= "" then
            priv.content = "<@" .. Config.UserId .. ">"
        end
        fireWebhook(Config.LuckWebhook, priv)
    end
end

local function checkAndHandleLuck()
    if not Config.SearchForLuck then return false end
    local active, mult, remaining = getLuckInfo()
    if not active then return false end
    print("[ServerHop] Luck active! x" .. tostring(mult) .. " | " .. formatTime(remaining))
    localStats.lucksFound = localStats.lucksFound + 1
    localStats.status     = "LUCK FOUND x" .. tostring(mult)
    saveAccountStats()
    task.spawn(sendLuckWebhook, mult, remaining, game.JobId)
    if Config.StopOnLuckServer then
        hopLock           = true
        localStats.status = "Stopped on luck server"
    end
    return true
end

