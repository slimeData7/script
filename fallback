end

local function ts()
    return os.time()
end

local function jenc(v)
    local ok, r = pcall(HttpService.JSONEncode, HttpService, v)
    return ok and r or nil
end

local function jdec(s)
    local ok, r = pcall(HttpService.JSONDecode, HttpService, s)
    return ok and r or nil
end

local function fileRead(path)
    if not (isfile and isfile(path)) then return nil end
    local ok, c = pcall(readfile, path)
    return (ok and c and c ~= "") and c or nil
end

local function fileWrite(path, content)
    if writefile then pcall(writefile, path, content) end
end

local function fileDelete(path)
    if isfile and isfile(path) and delfile then pcall(delfile, path) end
end

local function readJSON(path)
    local c = fileRead(path)
    if not c then return nil end
    return jdec(c)
end

local function writeJSON(path, data)
    local s = jenc(data)
    if s then fileWrite(path, s) end
end

local function isStale(t, maxAge)
    if type(t) ~= "table" or type(t._ts) ~= "number" then return true end
    return (ts() - t._ts) > (maxAge or FILE_MAX_AGE)
end

local function wrap(data)
    data._ts = ts()
    return data
end

local function evictOldest(tbl, maxSize)
    local keys = {}
    for k in pairs(tbl) do
        if k ~= "_ts" then table.insert(keys, k) end
    end
    if #keys <= maxSize then return end
    table.sort(keys, function(a, b)
        local va = tbl[a]
        local vb = tbl[b]
        local ta = type(va) == "table" and (va.at or 0) or 0
        local tb = type(vb) == "table" and (vb.at or 0) or 0
        return ta < tb
    end)
    local toRemove = #keys - maxSize
    for i = 1, toRemove do
        tbl[keys[i]] = nil
    end
end

local function listEvict(list, maxSize)
    while #list > maxSize do
        table.remove(list, 1)
    end
end

local function safeRequest(options)
    local ok, r = pcall(request, options)
    if not ok then dprint("request err:", r) return nil end
    return r
end

