local function tryBuyPet(wildPet)
	local cfg = CFG.AUTO_BUY_PETS
	if not cfg or not cfg.ENABLED then return end
	if not wildPetRef then
		print("[AutoBuyPets] WildPetRef not found, skipping")
		return
	end

	local petName, guid = parseWildPetName(wildPet.Name)
	if not petName or not guid then return end
	if not claimGuid(guid) then return end

	local data = PetData[petName]
	if not data then
		print("[AutoBuyPets] No PetData for: " .. petName)
		return
	end
	if not shouldBuyPet(data) then
		print("[AutoBuyPets] " .. petName .. " (" .. tostring(data.Rarity) .. ") not in buy list")
		return
	end

	local refPart = wildPetRef:FindFirstChild("WildPet_" .. guid)
	if not refPart then
		print("[AutoBuyPets] No refPart for guid: " .. guid)
		return
	end

	local price = refPart:GetAttribute("Price") or data.BasePrice
	if not price then
		print("[AutoBuyPets] No price for " .. petName .. ", skipping")
		return
	end

	local balance = getBalance()
	if balance < price then
		print("[AutoBuyPets] Can't afford " .. petName .. " | Price: " .. formatNumber(price) .. " | Balance: " .. formatNumber(balance))
		return
	end

	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then
		print("[AutoBuyPets] No HumanoidRootPart, skipping " .. petName)
		return
	end

	local oneIn = calcOneIn(data.SpawnChance)
	print("[AutoBuyPets] Taming " .. petName .. " (" .. tostring(data.Rarity) .. ") | Price: " .. formatNumber(price) .. " | 1 in " .. formatNumber(oneIn))

	root.CFrame = CFrame.new(refPart.Position + Vector3.new(0, 3, 0))
	task.wait(0.2)

	if not refPart.Parent then
		print("[AutoBuyPets] " .. petName .. " despawned before tame")
		return
	end

	Networking.Pets.WildPetTame:Fire(refPart)
	print("[AutoBuyPets] Tame fired for " .. petName)
	task.spawn(sendPetWebhook, data, price, oneIn)
end

