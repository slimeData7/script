local function runAutoEquipPets()
	local cfg = CFG.AUTO_EQUIP_PETS
	if not cfg or not cfg.ENABLED then return end

	print("[AutoEquipPets] Running...")

	if cfg.UNEQUIP_OTHERS then
		print("[AutoEquipPets] Unequipping all pets first")
		local ok, err = pcall(function()
			Networking.Pets.RequestUnequipAll:Fire()
		end)
		if not ok then
			print("[AutoEquipPets] UnequipAll failed: " .. tostring(err) .. " | Trying per-pet unequip fallback")
			local ok2, err2 = pcall(function()
				Networking.Pets.RequestUnequipAllPets:Fire()
			end)
			if not ok2 then
				print("[AutoEquipPets] Fallback also failed: " .. tostring(err2))
			end
		end
		task.wait(0.3)
	end

	for _, petName in ipairs(cfg.PETS) do
		print("[AutoEquipPets] Equipping: " .. petName)
		Networking.Pets.RequestEquipByName:Fire(petName)
		task.wait(0.2)
	end

	print("[AutoEquipPets] Done")
end

local function runAutoUpgradePets()
	local cfg = CFG.AUTO_UPGRADE_PETS
	if not cfg or not cfg.ENABLED then return end

	local maxLevel = cfg.MAX_LEVEL or 5
	print("[AutoUpgradePets] Running | Max level: " .. maxLevel)

	local equippedCfg = CFG.AUTO_EQUIP_PETS
	if not equippedCfg or not equippedCfg.PETS then
		print("[AutoUpgradePets] No AUTO_EQUIP_PETS.PETS list found, skipping")
		return
	end

	for _, petName in ipairs(equippedCfg.PETS) do
		print("[AutoUpgradePets] Upgrading: " .. petName)
		for level = 1, maxLevel do
			local balance = getBalance()
			print("[AutoUpgradePets] " .. petName .. " upgrade attempt " .. level .. " | Balance: " .. formatNumber(balance))
			local ok, result = pcall(function()
				return Networking.Pets.RequestUpgradeByName:InvokeServer(petName, level)
			end)
			if ok then
				print("[AutoUpgradePets] " .. petName .. " upgrade " .. level .. " result: " .. tostring(result))
				if type(result) == "table" and result.Success == false then
					print("[AutoUpgradePets] Server rejected upgrade at level " .. level .. ", stopping for " .. petName)
					break
				end
			else
				print("[AutoUpgradePets] Upgrade failed: " .. tostring(result))
				break
			end
			task.wait(0.3)
		end
	end

	print("[AutoUpgradePets] Done")
end

