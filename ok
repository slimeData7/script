local function runAutoBuySlots()
	local cfg = CFG.AUTO_BUY_SLOTS
	if not cfg or not cfg.ENABLED then return end
	local maxSlots = cfg.MAX_SLOTS or 6
	local currentSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
	if type(currentSlots) ~= "number" or currentSlots <= 0 then
		currentSlots = PetSlotPrices.BaseMax
	end
	currentSlots = math.floor(currentSlots)
	while currentSlots < maxSlots do
		local price = PetSlotPrices.GetNextPrice(currentSlots)
		if not price then break end
		if getBalance() < price then break end
		Networking.Pets.RequestPurchasePetSlot:Fire()
		task.wait(0.5)
		local newSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
		if type(newSlots) == "number" and newSlots > currentSlots then
			currentSlots = math.floor(newSlots)
		else
			break
		end
	end
end

local function runAutoOpenEggs()
	local cfg = CFG.AUTO_OPEN_EGGS
	if not cfg or not cfg.ENABLED then return end
	for eggName, wantCount in pairs(cfg) do
		if eggName == "ENABLED" then continue end
		local opened = 0
		while opened < wantCount do
			local tool = getToolFromBackpackByAttr("Egg", eggName)
			if not tool then break end
			if not tool.Parent then task.wait(0.1) continue end
			equipAndActivateTool(tool)
			opened += 1
			task.wait(0.5)
		end
	end
end

local function runAutoOpenSeedPacks()
	local cfg = CFG.AUTO_OPEN_SEEDPACKS
	if not cfg or not cfg.ENABLED then return end
	local lastPackOpenTime = 0
	local packServerCooldown = 1.0
	for packName, wantCount in pairs(cfg) do
		if packName == "ENABLED" then continue end
		local opened = 0
		while opened < wantCount do
			local tool = getToolFromBackpackByAttr("SeedPack", packName)
			if not tool then tool = getToolFromBackpackByAttr("PackName", packName) end
			if not tool then break end
			if not tool.Parent then task.wait(0.1) continue end
			local elapsed = os.clock() - lastPackOpenTime
			local waitNeeded = packServerCooldown - elapsed
			if waitNeeded > 0 then task.wait(waitNeeded) end
			local packId = tool:GetAttribute("PackId") or tool:GetAttribute("Id") or tool:GetAttribute("UUID")
			if not packId then break end
			local ok, result = pcall(function()
				return Networking.SeedPack.OpenSeedPack:InvokeServer(packId)
			end)
			lastPackOpenTime = os.clock()
			if ok then
				opened += 1
				if type(result) == "table" then
					local sw = result.Cooldown or result.WaitTime or result.NextOpen or result.Timer
					if type(sw) == "number" and sw > 0 then
						packServerCooldown = sw
					end
				end
			else
				task.wait(1)
			end
		end
	end
end

