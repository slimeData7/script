local function runAutoOpenEggs()
	local cfg = CFG.AUTO_OPEN_EGGS
	if not cfg or not cfg.ENABLED then return end

	print("[AutoOpenEggs] Scanning backpack...")

	for eggName, wantCount in pairs(cfg) do
		if eggName == "ENABLED" then continue end

		local tools = getToolsFromBackpack("Egg", eggName)
		if #tools == 0 then tools = getToolsFromBackpack("EggName", eggName) end

		if #tools == 0 then
			print("[AutoOpenEggs] No " .. eggName .. " in backpack")
			continue
		end

		print("[AutoOpenEggs] Found " .. #tools .. "x " .. eggName .. " | Will open up to " .. wantCount)

		local opened = 0
		for _, tool in pairs(tools) do
			if opened >= wantCount then break end
			if not tool.Parent then continue end
			local eggId = tool:GetAttribute("EggId") or tool:GetAttribute("Id") or tool:GetAttribute("UUID")
			if not eggId then
				print("[AutoOpenEggs] No ID attribute on " .. eggName .. ", skipping")
				continue
			end
			local ok, result = pcall(function()
				return Networking.Egg.OpenEgg:InvokeServer(eggId)
			end)
			if ok then
				opened += 1
				print("[AutoOpenEggs] Opened #" .. opened .. " " .. eggName)
			else
				print("[AutoOpenEggs] Failed: " .. tostring(result))
			end
			task.wait(0.35)
		end

		print("[AutoOpenEggs] Done: " .. opened .. "x " .. eggName)
	end
end

local function runAutoOpenSeedPacks()
	local cfg = CFG.AUTO_OPEN_SEEDPACKS
	if not cfg or not cfg.ENABLED then return end

	local lastPackOpenTime = 0
	local packServerCooldown = 1.0

	print("[AutoOpenSeedPacks] Starting...")

	for packName, wantCount in pairs(cfg) do
		if packName == "ENABLED" then continue end

		local opened = 0
		print("[AutoOpenSeedPacks] Target: " .. wantCount .. "x " .. packName)

		while opened < wantCount do
			local tools = getToolsFromBackpack("SeedPack", packName)
			if #tools == 0 then tools = getToolsFromBackpack("PackName", packName) end

			if #tools == 0 then
				print("[AutoOpenSeedPacks] No " .. packName .. " left in backpack, stopping")
				break
			end

			local tool = tools[1]
			if not tool.Parent then task.wait(0.1) continue end

			local packId = tool:GetAttribute("PackId") or tool:GetAttribute("Id") or tool:GetAttribute("UUID")
			if not packId then
				print("[AutoOpenSeedPacks] No ID on " .. packName .. ", stopping")
				break
			end

			local elapsed = os.clock() - lastPackOpenTime
			local waitNeeded = packServerCooldown - elapsed
			if waitNeeded > 0 then
				print("[AutoOpenSeedPacks] Waiting " .. string.format("%.2f", waitNeeded) .. "s cooldown")
				task.wait(waitNeeded)
			end

			local ok, result = pcall(function()
				return Networking.SeedPack.OpenSeedPack:InvokeServer(packId)
			end)
			lastPackOpenTime = os.clock()

			if ok then
				opened += 1
				print("[AutoOpenSeedPacks] Opened #" .. opened .. " " .. packName)
				if type(result) == "table" then
					local sw = result.Cooldown or result.WaitTime or result.NextOpen or result.Timer
					if type(sw) == "number" and sw > 0 then
						packServerCooldown = sw
						print("[AutoOpenSeedPacks] Cooldown updated: " .. sw .. "s")
					end
				end
			else
				print("[AutoOpenSeedPacks] Failed: " .. tostring(result))
				task.wait(1)
			end
		end

		print("[AutoOpenSeedPacks] Done: " .. opened .. "x " .. packName)
	end
end

