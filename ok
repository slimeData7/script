local seedPriceMap = {}
for _, entry in ipairs(SeedData) do
	if entry.SeedName and entry.PurchasePrice then
		seedPriceMap[entry.SeedName] = entry.PurchasePrice
		print("[Init] SeedData mapped: " .. entry.SeedName .. " -> " .. tostring(entry.PurchasePrice))
	end
end

local gearPriceMap = {}
for _, entry in ipairs(GearShopData.Data) do
	if entry.ItemName and entry.Cost then
		gearPriceMap[entry.ItemName] = entry.Cost
		print("[Init] GearData mapped: " .. entry.ItemName .. " -> " .. tostring(entry.Cost))
	end
end

local function getBalance()
	return replica and replica.Data and replica.Data.Sheckles or 0
end

local function formatNumber(n)
	n = tonumber(n) or 0
	if n >= 1e9 then return string.format("%.1fB", n / 1e9)
	elseif n >= 1e6 then return string.format("%.1fM", n / 1e6)
	elseif n >= 1e3 then return string.format("%.1fK", n / 1e3)
	else return tostring(math.round(n)) end
end

local function getStockValue(itemsFolder, itemName)
	local child = itemsFolder:FindFirstChild(itemName)
	if child then
		return child.Value
	end
	return 0
end

local function getToolsFromBackpack(attrKey, attrValue)
	local results = {}
	local char = LocalPlayer.Character
	local function scan(parent)
		for _, v in pairs(parent:GetChildren()) do
			if v:IsA("Tool") then
				local a = v:GetAttribute(attrKey)
				if attrValue == nil and a ~= nil then
					table.insert(results, v)
				elseif a == attrValue then
					table.insert(results, v)
				end
			end
		end
	end
	scan(Backpack)
	if char then scan(char) end
	return results
end

local function runAutoBuySeeds()
	local cfg = CFG.AUTO_BUY_SEEDS
	if not cfg or not cfg.ENABLED then return end

	print("[AutoBuySeeds] Running | Balance: " .. formatNumber(getBalance()))

	for seedName, wantCount in pairs(cfg) do
		if seedName == "ENABLED" then continue end

		local price = seedPriceMap[seedName]
		if not price then
			print("[AutoBuySeeds] " .. seedName .. " not found in SeedData, skipping")
			continue
		end

		local stock = getStockValue(SeedShopItems, seedName)
		if stock <= 0 then
			print("[AutoBuySeeds] " .. seedName .. " out of stock (" .. tostring(stock) .. ")")
			continue
		end

		local balance = getBalance()
		if balance < price then
			print("[AutoBuySeeds] Can't afford " .. seedName .. " | Price: " .. formatNumber(price) .. " | Balance: " .. formatNumber(balance))
			continue
		end

		local toBuy = math.min(wantCount, stock)
		print("[AutoBuySeeds] Buying " .. toBuy .. "x " .. seedName .. " | Price: " .. formatNumber(price) .. " | Stock: " .. stock)

		for i = 1, toBuy do
			local bal = getBalance()
			if bal < price then
				print("[AutoBuySeeds] Ran out of money at " .. seedName .. " #" .. i .. " | Balance: " .. formatNumber(bal))
				break
			end
			Networking.SeedShop.PurchaseSeed:Fire(seedName)
			task.wait(0.08)
		end

		print("[AutoBuySeeds] Done: " .. seedName)
	end
end

