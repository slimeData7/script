local function getBalance()
	return replica and replica.Data and replica.Data.Sheckles or 0
end

local function formatNumber(n)
	n = tonumber(n) or 0
	if n >= 1e9 then return string.format("%.1fB", n / 1e9)
	elseif n >= 1e6 then return string.format("%.1fM", n / 1e6)
	elseif n >= 1e3 then return string.format("%.1fK", n / 1e3)
	else return tostring(math.round(n)) end
end

local function readStock(rawEntry)
	if type(rawEntry) == "number" then return rawEntry end
	if type(rawEntry) == "table" then
		return rawEntry.Count or rawEntry.Stock or rawEntry.Amount or 0
	end
	return 0
end

local function parseStockData(stockData, target)
	if type(stockData) ~= "table" then return end
	for k, v in pairs(stockData) do
		target[k] = readStock(v)
	end
end

local function getSeedPrice(seedName)
	local d = SeedData and SeedData[seedName]
	if not d then return nil end
	return d.Price or d.Cost or d.SeedCost or nil
end

local function getGearPrice(gearName)
	if not GearShopData then return nil end
	for _, item in pairs(GearShopData) do
		if type(item) == "table" and item.ItemName == gearName then
			return item.Cost or item.Price or nil
		end
	end
	return nil
end

local function getCratePrice(crateName)
	if not CrateData then return nil end
	local d = CrateData.GetData and CrateData.GetData(crateName) or CrateData[crateName]
	if not d then return nil end
	return d.Cost or d.Price or nil
end

local function getToolsFromBackpack(attrKey, attrValue)
	local results = {}
	local char = LocalPlayer.Character
	local function scan(parent)
		for _, v in pairs(parent:GetChildren()) do
			if v:IsA("Tool") then
				local a = v:GetAttribute(attrKey)
				if attrValue == nil and a ~= nil then
					table.insert(results, v)
				elseif a == attrValue then
					table.insert(results, v)
				end
			end
		end
	end
	scan(Backpack)
	if char then scan(char) end
	return results
end

local function tryReadInitialStock()
	local ok, stockModule = pcall(function()
		return require(ReplicatedStorage.SharedModules.StockValues)
	end)
	if ok and type(stockModule) == "table" then
		if stockModule.SeedShop then
			parseStockData(stockModule.SeedShop, seedStockCache)
			seedStockReady = true
			print("[Stock] Seed stock loaded from StockValues")
			for k, v in pairs(seedStockCache) do
				print("[Stock]   Seed: " .. k .. " -> " .. tostring(v))
			end
		end
		if stockModule.GearShop then
			parseStockData(stockModule.GearShop, gearStockCache)
			gearStockReady = true
			print("[Stock] Gear stock loaded from StockValues")
			for k, v in pairs(gearStockCache) do
				print("[Stock]   Gear: " .. k .. " -> " .. tostring(v))
			end
		end
		if stockModule.CrateShop then
			parseStockData(stockModule.CrateShop, crateStockCache)
			crateStockReady = true
			print("[Stock] Crate stock loaded from StockValues")
			for k, v in pairs(crateStockCache) do
				print("[Stock]   Crate: " .. k .. " -> " .. tostring(v))
			end
		end
	else
		print("[Stock] StockValues not readable, will wait for restock events only")
	end
end

local function runAutoBuySeeds()
	local cfg = CFG.AUTO_BUY_SEEDS
	if not cfg or not cfg.ENABLED then return end

	if not seedStockReady then
		print("[AutoBuySeeds] Stock not ready yet, skipping until restock event")
		return
	end

	print("[AutoBuySeeds] Running | Balance: " .. formatNumber(getBalance()))

	for seedName, wantCount in pairs(cfg) do
		if seedName == "ENABLED" then continue end

		local price = getSeedPrice(seedName)
		if price == nil then
			print("[AutoBuySeeds] " .. seedName .. " not found in SeedData, skipping")
			continue
		end

		local stock = seedStockCache[seedName] or 0
		if stock <= 0 then
			print("[AutoBuySeeds] " .. seedName .. " out of stock, skipping")
			continue
		end

		local balance = getBalance()
		if balance < price then
			print("[AutoBuySeeds] Can't afford " .. seedName .. " | Price: " .. formatNumber(price) .. " | Balance: " .. formatNumber(balance))
			continue
		end

		local toBuy = math.min(wantCount, stock)
		print("[AutoBuySeeds] Buying " .. toBuy .. "x " .. seedName .. " | Price: " .. formatNumber(price) .. " | Stock: " .. stock)

		for i = 1, toBuy do
			local bal = getBalance()
			if bal < price then
				print("[AutoBuySeeds] Ran out of money at " .. seedName .. " #" .. i .. " | Balance: " .. formatNumber(bal))
				break
			end
			Networking.SeedShop.PurchaseSeed:Fire(seedName)
			task.wait(0.08)
		end

		print("[AutoBuySeeds] Done: " .. seedName)
	end
end

