local function getOwnedPets()
	local pets = {}
	local data = replica and replica.Data and replica.Data.Pets
	if not data then return pets end
	for guid, petInfo in pairs(data) do
		table.insert(pets, { Guid = guid, Name = petInfo.Name or petInfo.DisplayName })
	end
	return pets
end

local function getEquippedPets()
	local pets = {}
	local char = LocalPlayer.Character
	if not char then return pets end
	for _, tool in pairs(char:GetChildren()) do
		if tool:IsA("Tool") then
			local guid = tool:GetAttribute("PetId") or tool:GetAttribute("UUID") or tool:GetAttribute("Guid")
			local name = tool:GetAttribute("PetName") or tool.Name
			if guid then
				table.insert(pets, { Guid = guid, Name = name })
			end
		end
	end
	return pets
end

local function getDesiredPets()
	local cfg = CFG.AUTO_EQUIP_PETS
	local maxSlots = LocalPlayer:GetAttribute("MaxEquippedPets") or 1

	local blacklistSet = {}
	for _, name in ipairs(cfg.BLACKLIST or {}) do
		blacklistSet[name] = true
	end

	local priorityRank = {}
	for i, name in ipairs(cfg.PRIORITY or {}) do
		priorityRank[name] = i
	end

	local owned = getOwnedPets()

	local eligible = {}
	for _, pet in ipairs(owned) do
		if not blacklistSet[pet.Name] then
			table.insert(eligible, pet)
		end
	end

	table.sort(eligible, function(a, b)
		local ra = priorityRank[a.Name] or math.huge
		local rb = priorityRank[b.Name] or math.huge
		return ra < rb
	end)

	local desired = {}
	for i = 1, math.min(maxSlots, #eligible) do
		table.insert(desired, eligible[i])
	end

	return desired
end

local function syncPets()
	local cfg = CFG.AUTO_EQUIP_PETS
	if not cfg or not cfg.ENABLED then return end

	local desired = getDesiredPets()
	local equipped = getEquippedPets()

	local desiredGuids = {}
	for _, pet in ipairs(desired) do
		desiredGuids[pet.Guid] = pet
	end

	local equippedGuids = {}
	for _, pet in ipairs(equipped) do
		equippedGuids[pet.Guid] = pet
	end

	for _, pet in ipairs(equipped) do
		if not desiredGuids[pet.Guid] then
			Networking.Pets.RequestUnequip:Fire(pet.Guid)
			task.wait(0.2)
		end
	end

	for _, pet in ipairs(desired) do
		if not equippedGuids[pet.Guid] then
			Networking.Pets.RequestEquipByName:Fire(pet.Name)
			task.wait(0.2)
		end
	end
end

local function runAutoBuySlots()
	local cfg = CFG.AUTO_BUY_SLOTS
	if not cfg or not cfg.ENABLED then return end
	local maxSlots = cfg.MAX_SLOTS or 6
	local currentSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
	if type(currentSlots) ~= "number" or currentSlots <= 0 then
		currentSlots = PetSlotPrices.BaseMax
	end
	currentSlots = math.floor(currentSlots)
	while currentSlots < maxSlots do
		local price = PetSlotPrices.GetNextPrice(currentSlots)
		if not price then break end
		local balance = getBalance()
		if balance < price then break end
		Networking.Pets.RequestPurchasePetSlot:Fire()
		task.wait(0.5)
		local newSlots = LocalPlayer:GetAttribute("MaxEquippedPets")
		if type(newSlots) == "number" and newSlots > currentSlots then
			currentSlots = math.floor(newSlots)
		else
			break
		end
	end
end

local function claimGuid(guid)
	if GUIDS_CLAIMED[guid] then return false end
	GUIDS_CLAIMED[guid] = true
	return true
end

local function calcOneIn(spawnChance)
	if not spawnChance or spawnChance <= 0 then return 0 end
	return math.round(1 / (spawnChance / 100))
end

local function parseWildPetName(instanceName)
	local petName, guid = instanceName:match("^WildPet_(.+)_WildPet_(.+)$")
	if not petName or petName == "" or not guid or guid == "" then return nil, nil end
	return petName, guid
end

local function getIconUrl(iconAssetId)
	if not iconAssetId or iconAssetId == "N/A" or iconAssetId == "" then return nil end
	local assetNumber = tostring(iconAssetId):match("rbxassetid://(%d+)")
	if not assetNumber then return nil end
	if ICON_CACHE[assetNumber] ~= nil then
		return ICON_CACHE[assetNumber] ~= false and ICON_CACHE[assetNumber] or nil
	end
	local thumbnailUrl = nil
	pcall(function()
		local r = request({
			Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetNumber .. "&size=420x420&format=Png&isCircular=false",
			Method = "GET"
		})
		if r and r.Success then
			local ok, decoded = pcall(HttpService.JSONDecode, HttpService, r.Body)
			if ok and decoded and decoded.data and decoded.data[1] then
				thumbnailUrl = decoded.data[1].imageUrl
			end
		end
	end)
	ICON_CACHE[assetNumber] = thumbnailUrl or false
	return thumbnailUrl
end

local function sendPetWebhook(data, price, oneIn)
	local cfg = CFG.AUTO_BUY_PETS
	if oneIn < cfg.MINIMUM_LUCK_SENT then return end
	if not cfg.WEBHOOK_URL or cfg.WEBHOOK_URL == "" then return end
	local article = data.DisplayName:match("^[AEIOUaeiou]") and "an" or "a"
	local title = "🐾 Captured " .. article .. " 1 in " .. formatNumber(oneIn) .. " " .. data.DisplayName .. "!"
	local fields = {
		{ name = "Player",        value = "||" .. LocalPlayer.Name .. "||", inline = true },
		{ name = "Price",         value = formatNumber(price),              inline = true },
		{ name = "Rarity",        value = tostring(data.Rarity),           inline = true },
		{ name = "server-job-id", value = tostring(game.JobId),            inline = false },
	}
	if cfg.NOTE and cfg.NOTE ~= "" then
		table.insert(fields, { name = "Note", value = cfg.NOTE, inline = false })
	end
	local embed = {
		title = title,
		color = 0x5865F2,
		fields = fields,
		footer = { text = "discord.gg/idiothub" }
	}
	local thumbnailUrl = getIconUrl(data.Image)
	if thumbnailUrl then embed.thumbnail = { url = thumbnailUrl } end
	local mention = (cfg.DISCORD_ID and cfg.DISCORD_ID ~= "") and ("<@" .. cfg.DISCORD_ID .. ">") or nil
	local payload
	local ok = pcall(function()
		payload = HttpService:JSONEncode({ content = mention, embeds = { embed } })
	end)
	if not ok or not payload then return end
	pcall(function()
		request({
			Url = cfg.WEBHOOK_URL,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = payload
		})
	end)
end

local function shouldBuyPet(data)
	local cfg = CFG.AUTO_BUY_PETS
	if not cfg or not cfg.ENABLED then return false end
	for _, name in ipairs(cfg.NAMES) do
		if data.DisplayName == name then return true end
	end
	for _, rarity in ipairs(cfg.RARITIES) do
		if data.Rarity == rarity then return true end
	end
	return false
end

local wildPetRef = workspace:WaitForChild("Map", 30)
if wildPetRef then wildPetRef = wildPetRef:WaitForChild("WildPetRef", 30) end
local wildPetSpawns = wildPetRef and workspace.Map:FindFirstChild("WildPetSpawns")

local function tryBuyPet(wildPet)
	local cfg = CFG.AUTO_BUY_PETS
	if not cfg or not cfg.ENABLED then return end
	if not wildPetRef then return end
	local petName, guid = parseWildPetName(wildPet.Name)
	if not petName or not guid then return end
	if not claimGuid(guid) then return end
	local data = PetData[petName]
	if not data then return end
	if not shouldBuyPet(data) then return end
	local refPart = wildPetRef:FindFirstChild("WildPet_" .. guid)
	if not refPart then return end
	local price = refPart:GetAttribute("Price") or data.BasePrice
	if not price then return end
	local balance = getBalance()
	if balance < price then return end
	local char = LocalPlayer.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local oneIn = calcOneIn(data.SpawnChance)
	root.CFrame = CFrame.new(refPart.Position + Vector3.new(0, 3, 0))
	task.wait(0.2)
	if not refPart.Parent then return end
	Networking.Pets.WildPetTame:Fire(refPart)
	task.spawn(sendPetWebhook, data, price, oneIn)
end

